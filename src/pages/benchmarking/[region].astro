---
import type { GetStaticPaths } from 'astro';
import { Icon } from 'astro-icon/components';

import JsonLd from '~/components/common/JsonLd.astro';
import Layout from '~/layouts/PageLayout.astro';
import { dataDate, dataDisclaimer } from '~/data/benchmarking';
import { regionPages } from '~/utils/entity-pages';

export const prerender = true;

export const getStaticPaths = (() =>
  regionPages.map((page) => ({ params: { region: page.slug }, props: { page } }))) satisfies GetStaticPaths;

const { page } = Astro.props;
const { summary, detail } = page;
const relatedRegions = regionPages.filter((candidate) => candidate.slug !== page.slug).slice(0, 6);

const metadata = {
  title: `${summary.name} AI 战略对标 · 国际对标`,
  description: detail?.overview || `${summary.name} AI 战略、投资、治理模式与核心优势对标。`,
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `${summary.name} AI 战略对标`,
  description: metadata.description,
  dateModified: dataDate,
  inLanguage: 'zh-CN',
  about: [
    { '@type': 'Place', name: summary.nameEn || summary.name },
    { '@type': 'Thing', name: 'AI strategy' },
  ],
};
---

<Layout metadata={metadata} breadcrumbs={[{ label: '国际对标', href: '/benchmarking/' }, { label: summary.name }]}>
  <JsonLd schema={articleSchema} />

  <article class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <header class="mb-8">
      <p class="text-xs uppercase tracking-[0.18em] text-primary font-semibold mb-4">
        International Benchmark · Updated {dataDate}
      </p>
      <h1 class="font-serif text-3xl md:text-5xl leading-tight font-semibold text-gray-900 dark:text-white mb-3">
        {summary.flag}
        {summary.name} AI 战略对标
      </h1>
      {detail?.fullName && <p class="text-base md:text-lg text-gray-500 dark:text-gray-400">{detail.fullName}</p>}
    </header>

    <section class="grid md:grid-cols-2 gap-3 mb-8">
      <div class="bg-surface border border-subtle rounded-lg p-4">
        <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">核心战略</div>
        <div class="font-semibold">{summary.strategy}</div>
        <div class="text-xs text-gray-500 mt-1">{summary.strategyYear}</div>
      </div>
      <div class="bg-surface border border-subtle rounded-lg p-4">
        <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">投资规模</div>
        <div class="font-semibold">{summary.investment}</div>
      </div>
      <div class="bg-surface border border-subtle rounded-lg p-4">
        <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">治理模式</div>
        <div class="font-semibold">{summary.governance}</div>
      </div>
      <div class="bg-surface border border-subtle rounded-lg p-4">
        <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">核心优势</div>
        <div class="font-semibold">{summary.strength}</div>
      </div>
    </section>

    <section class="callout-note rounded-lg p-5 mb-10">
      <h2 class="font-serif text-xl font-semibold text-gray-900 dark:text-white mb-3">一句话判断</h2>
      <p class="text-gray-800 dark:text-gray-200 leading-[1.85]">
        {
          detail?.overview ||
            `${summary.name} 的 AI 战略可概括为：${summary.strategy}；治理模式是 ${summary.governance}；相对优势是 ${summary.strength}。`
        }
      </p>
    </section>

    {
      detail ? (
        <>
          <section class="mb-10">
            <h2 class="font-serif text-xl font-semibold text-gray-900 dark:text-white mb-4">核心战略</h2>
            <div class="space-y-3">
              {detail.strategies.map((strategy) => (
                <div class="bg-surface border border-subtle rounded-lg p-4">
                  <div class="text-xs font-mono text-blue-600 dark:text-blue-400 mb-1">{strategy.year}</div>
                  <h3 class="font-semibold text-gray-900 dark:text-white">{strategy.name}</h3>
                  <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{strategy.description}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="mb-10">
            <h2 class="font-serif text-xl font-semibold text-gray-900 dark:text-white mb-4">投资与资源</h2>
            <div class="overflow-x-auto">
              <table class="w-full text-sm border-collapse">
                <thead>
                  <tr class="bg-slate-100 dark:bg-slate-800">
                    <th class="text-left p-3 border border-subtle">项目</th>
                    <th class="text-left p-3 border border-subtle">金额</th>
                    <th class="text-left p-3 border border-subtle">备注</th>
                  </tr>
                </thead>
                <tbody>
                  {detail.investment.map((item) => (
                    <tr>
                      <td class="p-3 border border-subtle">{item.item}</td>
                      <td class="p-3 border border-subtle font-semibold">{item.amount}</td>
                      <td class="p-3 border border-subtle text-muted">{item.note}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>

          <section class="mb-10">
            <h2 class="font-serif text-xl font-semibold text-gray-900 dark:text-white mb-3">治理模式</h2>
            <p class="text-gray-700 dark:text-gray-300 leading-[1.85]">{detail.governance}</p>
          </section>

          <section class="mb-10 grid md:grid-cols-2 gap-5">
            <div>
              <h2 class="font-serif text-xl font-semibold text-green-700 dark:text-green-300 mb-3">相对新加坡的优势</h2>
              <ul class="space-y-2 text-sm text-gray-700 dark:text-gray-300">
                {detail.strengths.map((item) => (
                  <li>• {item}</li>
                ))}
              </ul>
            </div>
            <div>
              <h2 class="font-serif text-xl font-semibold text-red-700 dark:text-red-300 mb-3">相对新加坡的劣势</h2>
              <ul class="space-y-2 text-sm text-gray-700 dark:text-gray-300">
                {detail.weaknesses.map((item) => (
                  <li>• {item}</li>
                ))}
              </ul>
            </div>
          </section>

          <section class="mb-10">
            <h2 class="font-serif text-xl font-semibold text-gray-900 dark:text-white mb-4">关键举措与机构</h2>
            <div class="grid md:grid-cols-2 gap-5">
              <div class="bg-surface border border-subtle rounded-lg p-4">
                <h3 class="font-semibold mb-3">关键举措</h3>
                <ul class="space-y-2 text-sm text-gray-700 dark:text-gray-300">
                  {detail.keyInitiatives.map((item) => (
                    <li>• {item}</li>
                  ))}
                </ul>
              </div>
              <div class="bg-surface border border-subtle rounded-lg p-4">
                <h3 class="font-semibold mb-3">关键机构</h3>
                <ul class="space-y-2 text-sm text-gray-700 dark:text-gray-300">
                  {detail.keyBodies.map((body) => (
                    <li>
                      <strong>{body.name}</strong> — {body.role}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </section>

          <section class="mb-10">
            <h2 class="font-serif text-xl font-semibold text-gray-900 dark:text-white mb-3">参考来源</h2>
            <ul class="space-y-1 text-sm text-gray-500 dark:text-gray-400">
              {detail.sources.map((source) => (
                <li>• {source}</li>
              ))}
            </ul>
          </section>
        </>
      ) : (
        <section class="callout-muted rounded-lg p-5 mb-10">
          <h2 class="font-semibold mb-2">详情待扩展</h2>
          <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
            本页目前使用总览表数据生成。后续可在 <code>src/data/benchmarking.ts</code> 补充完整
            <code>RegionDetail</code>，页面会自动展开战略、投资、治理、优势/劣势与来源。
          </p>
        </section>
      )
    }

    <section class="mb-10">
      <h2 class="font-serif text-xl font-semibold text-gray-900 dark:text-white mb-4">关联阅读</h2>
      <div class="flex flex-wrap gap-3">
        <a
          href="/benchmarking/"
          class="text-sm text-primary hover:text-secondary border border-primary/30 px-4 py-2 rounded-md"
        >
          国际对标总览
        </a>
        <a
          href="/levers/"
          class="text-sm text-primary hover:text-secondary border border-primary/30 px-4 py-2 rounded-md"
        >
          新加坡国家 AI 抓手
        </a>
        <a
          href="/legal-ai/"
          class="text-sm text-primary hover:text-secondary border border-primary/30 px-4 py-2 rounded-md"
        >
          新加坡 AI 法律框架
        </a>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="font-serif text-xl font-semibold text-gray-900 dark:text-white mb-4">继续比较</h2>
      <div class="grid gap-3 md:grid-cols-2">
        {
          relatedRegions.map((item) => (
            <a
              href={`/benchmarking/${item.slug}/`}
              class="block bg-surface rounded-lg p-4 border border-subtle hover:border-blue-300 hover:shadow-sm transition-all"
            >
              <h3 class="font-semibold text-gray-800 dark:text-white text-sm">
                {item.summary.flag} {item.summary.name}
              </h3>
              <p class="text-xs text-gray-600 dark:text-gray-400 mt-2">{item.summary.strength}</p>
            </a>
          ))
        }
      </div>
    </section>

    <p class="text-xs text-gray-500 dark:text-gray-400 border-t border-subtle pt-5">{dataDisclaimer}</p>

    <nav class="mt-8">
      <a
        href="/benchmarking/"
        class="text-sm text-primary hover:text-secondary font-medium inline-flex items-center gap-1"
      >
        <Icon name="tabler:arrow-left" class="w-4 h-4" />
        返回国际对标
      </a>
    </nav>
  </article>
</Layout>
