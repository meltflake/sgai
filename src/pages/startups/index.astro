---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import { ecosystemStats, exits, investors, unicorns, verticals } from '~/data/startups';
import { getStartupAiRelation, startupEntitySlug } from '~/utils/entity-pages';
import { t } from '~/i18n';

const lang = 'en' as const;
const hrefFor = (entity: { id?: string; name: string; nameEn?: string }) => `/startups/${startupEntitySlug(entity)}/`;

const stats = [
  { value: ecosystemStats.totalStartups, label: 'AI-related startup samples' },
  { value: `#${ecosystemStats.globalRank}`, label: 'Global AI hub rank' },
  { value: ecosystemStats.seaFundingShare, label: 'SEA AI funding share' },
  { value: ecosystemStats.totalVCRaised, label: 'Total VC raised' },
  { value: String(ecosystemStats.unicorns), label: 'Unicorns' },
  { value: ecosystemStats.govCommitment, label: 'Government AI commitment' },
];
---

<Layout
  metadata={{
    title: t(lang, 'startupsPageTitle'),
    description: t(lang, 'startupsPageDesc'),
  }}
  breadcrumbs={[{ label: t(lang, 'navStartups') }]}
  lang={lang}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-6xl">
    <Headline
      title="AI Startup Ecosystem"
      subtitle="A directory of Singapore AI-native, AI-enabled, and adjacent capital ecosystem entities, with growing profiles for companies, projects, exits, and investors."
    />

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-12">
      {
        stats.map((stat) => (
          <div class="bg-surface rounded-lg shadow border border-subtle p-4 text-center">
            <div class="t-stat text-primary">{stat.value}</div>
            <div class="text-xs text-muted mt-1">{stat.label}</div>
          </div>
        ))
      }
    </div>

    <section class="mb-14">
      <div class="flex items-end justify-between gap-4 mb-5">
        <div>
          <p class="text-xs uppercase tracking-wider text-muted font-semibold mb-2">Scale Signals</p>
          <h2 class="t-h3">Unicorns And Listed-Scale Companies</h2>
        </div>
        <span class="text-sm text-muted">{unicorns.length} companies</span>
      </div>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          unicorns.map((u) => (
            <a
              href={hrefFor(u)}
              class="group h-full bg-surface rounded-lg shadow-sm border border-subtle p-5 hover:border-primary hover:shadow-md transition-all"
            >
              <div class="flex items-start justify-between gap-3 mb-4">
                <div>
                  <p class="text-xs text-muted mb-1">Unicorn</p>
                  <h3 class="text-lg font-bold text-gray-900 dark:text-white group-hover:text-primary transition-colors">
                    {u.name}
                  </h3>
                  <span class="mt-2 inline-flex text-xs font-medium bg-primary/10 text-primary px-2 py-0.5 rounded">
                    {getStartupAiRelation(startupEntitySlug(u)).labelEn}
                  </span>
                </div>
                <Icon name="tabler:arrow-up-right" class="w-5 h-5 text-muted group-hover:text-primary shrink-0" />
              </div>
              <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed mb-4">{u.sectorEn || u.sector}</p>
              <dl class="grid grid-cols-2 gap-3 text-xs">
                <div>
                  <dt class="text-muted mb-1">Raised</dt>
                  <dd class="font-semibold text-gray-900 dark:text-white">{u.raised}</dd>
                </div>
                <div>
                  <dt class="text-muted mb-1">Valuation</dt>
                  <dd class="font-semibold text-primary">{u.valuation}</dd>
                </div>
                <div class="col-span-2">
                  <dt class="text-muted mb-1">Status</dt>
                  <dd>{u.statusEn || u.status}</dd>
                </div>
              </dl>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mb-14">
      <div class="mb-6">
        <p class="text-xs uppercase tracking-wider text-muted font-semibold mb-2">Vertical Map</p>
        <h2 class="t-h3">By Vertical</h2>
      </div>
      <div class="space-y-10">
        {
          verticals.map((v) => (
            <section>
              <div class="flex items-center justify-between gap-4 mb-4">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white">
                  {v.icon} {v.nameEn || v.name}
                </h3>
                <span class="text-sm text-muted">{v.startups.length} entities</span>
              </div>
              <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                {v.startups.map((s) => (
                  <a
                    href={hrefFor(s)}
                    class="group h-full bg-surface rounded-lg shadow-sm border border-subtle p-5 hover:border-primary hover:shadow-md transition-all"
                  >
                    <div class="flex flex-wrap items-center gap-2 mb-3">
                      <h4 class="font-bold text-gray-900 dark:text-white group-hover:text-primary transition-colors">
                        {s.name}
                      </h4>
                      {(s.highlightEn || s.highlight) && (
                        <span class="text-xs font-medium bg-primary/10 text-primary px-2 py-0.5 rounded">
                          {s.highlightEn || s.highlight}
                        </span>
                      )}
                      <span class="text-xs font-medium bg-gray-100 dark:bg-slate-800 text-gray-700 dark:text-gray-300 px-2 py-0.5 rounded">
                        {getStartupAiRelation(startupEntitySlug(s)).labelEn}
                      </span>
                    </div>
                    <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
                      {s.descriptionEn || s.description}
                    </p>
                    <div class="flex flex-wrap gap-2 text-xs text-muted">
                      {s.raised && (
                        <span class="bg-gray-100 dark:bg-slate-800 px-2 py-1 rounded">Raised {s.raised}</span>
                      )}
                      {s.investors && (
                        <span class="bg-gray-100 dark:bg-slate-800 px-2 py-1 rounded">Investors {s.investors}</span>
                      )}
                    </div>
                    <div class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-primary">
                      Open profile
                      <Icon name="tabler:arrow-right" class="w-4 h-4" />
                    </div>
                  </a>
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </section>

    <section class="mb-14">
      <div class="flex items-end justify-between gap-4 mb-5">
        <div>
          <p class="text-xs uppercase tracking-wider text-muted font-semibold mb-2">Exit Signals</p>
          <h2 class="t-h3">Notable Exits And Acquisitions</h2>
        </div>
        <span class="text-sm text-muted">{exits.length} records</span>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          exits.map((e) => (
            <a
              href={hrefFor(e)}
              class="group h-full bg-surface rounded-lg shadow-sm border border-subtle p-5 hover:border-primary hover:shadow-md transition-all"
            >
              <div class="flex items-start justify-between gap-3 mb-3">
                <div>
                  <p class="text-xs text-muted mb-1">{e.year || 'Year pending'}</p>
                  <h3 class="text-lg font-bold text-gray-900 dark:text-white group-hover:text-primary transition-colors">
                    {e.name}
                  </h3>
                  <span class="mt-2 inline-flex text-xs font-medium bg-gray-100 dark:bg-slate-800 text-gray-700 dark:text-gray-300 px-2 py-0.5 rounded">
                    {getStartupAiRelation(startupEntitySlug(e)).labelEn}
                  </span>
                </div>
                <Icon name="tabler:arrow-up-right" class="w-5 h-5 text-muted group-hover:text-primary shrink-0" />
              </div>
              <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
                {e.descriptionEn || e.description}
              </p>
              <dl class="grid gap-3 sm:grid-cols-2 text-xs">
                <div>
                  <dt class="text-muted mb-1">Acquirer</dt>
                  <dd class="font-semibold text-gray-900 dark:text-white">{e.acquirerEn || e.acquirer}</dd>
                </div>
                <div>
                  <dt class="text-muted mb-1">Amount</dt>
                  <dd class="font-semibold text-primary">{e.amount}</dd>
                </div>
              </dl>
              {(e.noteEn || e.note) && <p class="mt-4 text-xs leading-relaxed text-muted line-clamp-3">{e.noteEn}</p>}
            </a>
          ))
        }
      </div>
    </section>

    <section class="mb-12">
      <div class="flex items-end justify-between gap-4 mb-5">
        <div>
          <p class="text-xs uppercase tracking-wider text-muted font-semibold mb-2">Capital Network</p>
          <h2 class="t-h3">Investor Ecosystem</h2>
        </div>
        <span class="text-sm text-muted">{investors.length} institutions</span>
      </div>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          investors.map((inv) => (
            <a
              href={hrefFor(inv)}
              class="group h-full bg-surface rounded-lg shadow-sm border border-subtle p-5 hover:border-primary hover:shadow-md transition-all"
            >
              <div class="flex items-start justify-between gap-3 mb-3">
                <div>
                  <span class="text-xs font-medium bg-primary/10 text-primary px-2 py-0.5 rounded">
                    {inv.typeEn || inv.type}
                  </span>
                  <span class="ml-2 text-xs font-medium bg-gray-100 dark:bg-slate-800 text-gray-700 dark:text-gray-300 px-2 py-0.5 rounded">
                    {getStartupAiRelation(startupEntitySlug(inv)).labelEn}
                  </span>
                  <h3 class="text-lg font-bold text-gray-900 dark:text-white group-hover:text-primary transition-colors mt-3">
                    {inv.name}
                  </h3>
                </div>
                <Icon name="tabler:arrow-up-right" class="w-5 h-5 text-muted group-hover:text-primary shrink-0" />
              </div>
              <p class="text-sm mt-3">
                <span class="text-muted">Track record: </span>
                {inv.statsEn || inv.stats}
              </p>
              <p class="text-sm">
                <span class="text-muted">Focus: </span>
                {inv.focusEn || inv.focus}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <p class="mt-8 text-sm text-muted text-center">
      Aggregate statistics use the public baseline as of {ecosystemStats.dataDate}; entity profiles were organized on {
        ecosystemStats.profileUpdated
      }. Some figures are estimates. Funding amounts are drawn from public reporting and actual numbers may differ.
    </p>
  </section>
</Layout>
