---
import Layout from '~/layouts/Layout.astro';
import { getHomePermalink } from '~/utils/permalinks';

const title = '页面未找到';
---

<Layout metadata={{ title, description: '您访问的页面不存在。', robots: { index: false, follow: false } }}>
  <section class="flex items-center h-full p-16">
    <div class="container flex flex-col items-center justify-center px-5 mx-auto my-8">
      <div class="max-w-md text-center">
        <h2 class="mb-8 font-bold text-9xl">
          <span class="sr-only">错误</span>
          <span class="text-primary">404</span>
        </h2>
        <p class="text-3xl font-semibold md:text-3xl">页面未找到</p>
        <p class="mt-4 mb-8 text-lg text-muted dark:text-slate-400">您访问的页面不存在，但您可以回到首页继续浏览。</p>
        <a rel="noopener noreferrer" href={getHomePermalink()} class="btn ml-4">返回首页</a>
      </div>
    </div>
  </section>
</Layout>
