---
// Lever detail page ([lang]). One page per leverPage.slug x non-default locale.

import type { GetStaticPaths } from 'astro';
import { Icon } from 'astro-icon/components';

import JsonLd from '~/components/common/JsonLd.astro';
import RelatedRail from '~/components/data/RelatedRail.astro';
import Layout from '~/layouts/PageLayout.astro';
import { dataDate } from '~/data/levers';
import { NON_DEFAULT_ROUTE_LOCALES, IN_LANGUAGES, pickLocalized, localizedHref, t, type Lang } from '~/i18n';
import { getDebateById, getPolicyById } from '~/utils/graph';
import { leverItemSlug, leverPages, leverSlug } from '~/utils/entity-pages';

export const prerender = true;

export const getStaticPaths = (() =>
  NON_DEFAULT_ROUTE_LOCALES.flatMap((lang) =>
    leverPages.map((page) => ({
      params: { lang, id: page.slug },
      props: { page },
    }))
  )) satisfies GetStaticPaths;

const { page } = Astro.props;
const lang = Astro.params.lang as Lang;
const isZh = lang === 'zh';

const lever = page.lever;
const isLever = page.kind === 'lever';
const itemPolicies = page.kind === 'item' ? (page.item.relatedPolicyIds || []).map(getPolicyById).filter(Boolean) : [];
const itemDebates = page.kind === 'item' ? (page.item.relatedDebateIds || []).map(getDebateById).filter(Boolean) : [];
const projectCount = lever.groups.reduce((sum, group) => sum + group.items.length, 0);

const leverName = pickLocalized(lever, 'name', lang) || lever.name;
const title = isLever
  ? isZh
    ? `抓手 ${lever.number} · ${leverName}`
    : `Lever ${lever.number} · ${leverName}`
  : pickLocalized(page.item, 'name', lang) || page.item.name;
const description = isLever
  ? pickLocalized(lever, 'subtitle', lang) || lever.subtitle
  : pickLocalized(page.item, 'description', lang) || page.item.description;

const metadata = {
  title: `${title} · ${t(lang, 'navLevers')}`,
  description,
};

const schema = {
  '@context': 'https://schema.org',
  '@type': isLever ? 'DefinedTerm' : 'GovernmentService',
  name: title,
  description,
  dateModified: dataDate,
  inLanguage: IN_LANGUAGES[lang],
  isPartOf: {
    '@type': 'CreativeWork',
    name: isZh ? '新加坡国家 AI 抓手图谱' : 'Singapore National AI Levers',
    url: 'https://sgai.md/levers/',
  },
};
---

<Layout
  metadata={metadata}
  breadcrumbs={[{ label: t(lang, 'navLevers'), href: localizedHref('/levers/', lang) }, { label: title }]}
  lang={lang}
>
  <JsonLd schema={schema} />

  <article class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <header class="mb-8">
      <p class="text-xs uppercase tracking-[0.18em] text-primary font-semibold mb-4">
        Lever {lever.number} · Updated {dataDate}
      </p>
      <h1 class="t-display text-gray-900 dark:text-white mb-3">
        {isLever ? `${lever.icon} ${isZh ? '抓手' : 'Lever'} ${lever.number} · ${leverName}` : title}
      </h1>
      <p class="t-lead text-gray-500 dark:text-gray-400">
        {
          isLever
            ? pickLocalized(lever, 'subtitle', lang)
            : isZh
              ? `隶属于抓手 ${lever.number} · ${leverName} / ${pickLocalized(page.group, 'title', lang)}`
              : `Part of Lever ${lever.number} · ${leverName} / ${pickLocalized(page.group, 'title', lang)}`
        }
      </p>
    </header>

    {
      isLever ? (
        <>
          <section class="grid md:grid-cols-3 gap-3 mb-8">
            <div class="bg-surface border border-subtle rounded-lg p-4">
              <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">{isZh ? '项目数' : 'Projects'}</div>
              <div class="t-stat text-primary">{projectCount}</div>
            </div>
            <div class="bg-surface border border-subtle rounded-lg p-4">
              <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">
                {isZh ? '传导模式' : 'Transmission mode'}
              </div>
              <div class="font-semibold">
                {isZh
                  ? lever.transmissionMode === 'direct'
                    ? '国家直接做'
                    : '穿透到企业'
                  : lever.transmissionMode === 'direct'
                    ? 'State-direct'
                    : 'Transmitted to enterprise'}
              </div>
            </div>
            <div class="bg-surface border border-subtle rounded-lg p-4">
              <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">
                {isZh ? '解决瓶颈' : 'Bottleneck solved'}
              </div>
              <div class="font-semibold">{pickLocalized(lever, 'bottleneckSolved', lang)}</div>
            </div>
          </section>

          <section class="callout-note rounded-lg p-5 mb-10">
            <h2 class="t-h3 text-gray-900 dark:text-white mb-3">{isZh ? '抓手定义' : 'Lever Definition'}</h2>
            <p class="text-gray-800 dark:text-gray-200 leading-[1.85]">{pickLocalized(lever, 'whatStateDoes', lang)}</p>
            {lever.insight && (
              <p class="text-gray-800 dark:text-gray-200 leading-[1.85] mt-3">
                {isZh ? '判断：' : 'Take: '}
                {pickLocalized(lever, 'insight', lang)}
              </p>
            )}
          </section>

          <section class="mb-10">
            <h2 class="t-h3 text-gray-900 dark:text-white mb-4">{isZh ? '包含项目' : 'Projects'}</h2>
            <div class="space-y-6">
              {lever.groups.map((group) => (
                <div>
                  <h3 class="font-semibold text-gray-900 dark:text-white mb-3">
                    {pickLocalized(group, 'title', lang)}
                  </h3>
                  <div class="grid md:grid-cols-2 gap-3">
                    {group.items.map((item) => (
                      <a
                        href={localizedHref(`/levers/${leverItemSlug(item)}/`, lang)}
                        class="block bg-surface border border-subtle rounded-lg p-4 hover:border-emerald-300 hover:shadow-sm transition-all"
                      >
                        <h4 class="font-semibold text-gray-900 dark:text-white text-sm">
                          {pickLocalized(item, 'name', lang)}
                        </h4>
                        <p class="text-xs text-gray-500 mt-1">
                          {isZh ? item.ministry : item.ministryEn || item.ministry}
                          {item.scale ? ` · ${pickLocalized(item, 'scale', lang)}` : ''}
                        </p>
                        <p class="text-xs text-gray-600 dark:text-gray-400 mt-2">
                          {pickLocalized(item, 'description', lang)}
                        </p>
                      </a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </section>

          <RelatedRail entity={{ type: 'lever', id: lever.number }} variant="full" hideWhenEmpty={true} lang={lang} />
        </>
      ) : (
        <>
          <section class="grid md:grid-cols-3 gap-3 mb-8">
            <div class="bg-surface border border-subtle rounded-lg p-4">
              <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">{isZh ? '主管机构' : 'Owner'}</div>
              <div class="font-semibold">{isZh ? page.item.ministry : page.item.ministryEn || page.item.ministry}</div>
            </div>
            <div class="bg-surface border border-subtle rounded-lg p-4">
              <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">
                {isZh ? '规模 / KPI' : 'Scale / KPI'}
              </div>
              <div class="font-semibold">{pickLocalized(page.item, 'scale', lang) || '—'}</div>
            </div>
            <div class="bg-surface border border-subtle rounded-lg p-4">
              <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">{isZh ? '父抓手' : 'Parent lever'}</div>
              <a
                href={localizedHref(`/levers/${leverSlug(lever)}/`, lang)}
                class="text-primary hover:text-secondary font-semibold"
              >
                {isZh ? '抓手' : 'Lever'} {lever.number} · {leverName}
              </a>
            </div>
          </section>

          <section class="callout-note rounded-lg p-5 mb-10">
            <h2 class="t-h3 text-gray-900 dark:text-white mb-3">{isZh ? '项目描述' : 'Project Description'}</h2>
            <p class="text-gray-800 dark:text-gray-200 leading-[1.85]">
              {pickLocalized(page.item, 'description', lang)}
            </p>
          </section>

          <section class="grid md:grid-cols-2 gap-5 mb-10">
            <div class="bg-surface border border-subtle rounded-lg p-5">
              <h2 class="t-h3 text-gray-900 dark:text-white mb-3">{isZh ? '国家直接做什么' : 'What the State Does'}</h2>
              <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
                {pickLocalized(lever, 'whatStateDoes', lang)}
              </p>
            </div>
            <div class="bg-surface border border-subtle rounded-lg p-5">
              <h2 class="t-h3 text-gray-900 dark:text-white mb-3">{isZh ? '解决什么瓶颈' : 'Bottleneck Solved'}</h2>
              <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
                {pickLocalized(lever, 'bottleneckSolved', lang)}
              </p>
            </div>
          </section>

          <section class="mb-10">
            <h2 class="t-h3 text-gray-900 dark:text-white mb-4">{isZh ? '关联阅读' : 'Related Reading'}</h2>
            <div class="grid gap-3 md:grid-cols-2">
              {itemPolicies.map((policy) => (
                <a
                  href={
                    policy!.id ? localizedHref(`/policies/${policy!.id}/`, lang) : localizedHref('/policies/', lang)
                  }
                  class="block bg-surface border border-subtle rounded-lg p-4 hover:border-purple-300 hover:shadow-sm transition-all"
                >
                  <h3 class="font-semibold text-gray-900 dark:text-white text-sm">
                    {pickLocalized(policy!, 'title', lang)}
                  </h3>
                  <p class="text-xs text-gray-600 dark:text-gray-400 mt-2">{pickLocalized(policy!, 'summary', lang)}</p>
                </a>
              ))}
              {itemDebates.map((debate) => (
                <a
                  href={localizedHref(`/debates/${debate!.id}/`, lang)}
                  class="block bg-surface border border-subtle rounded-lg p-4 hover:border-amber-300 hover:shadow-sm transition-all"
                >
                  <h3 class="font-semibold text-gray-900 dark:text-white text-sm">
                    {pickLocalized(debate!, 'title', lang)}
                  </h3>
                  <p class="text-xs text-gray-600 dark:text-gray-400 mt-2">{pickLocalized(debate!, 'summary', lang)}</p>
                </a>
              ))}
              {itemPolicies.length === 0 && itemDebates.length === 0 && (
                <a
                  href={localizedHref(`/levers/${leverSlug(lever)}/`, lang)}
                  class="block bg-surface border border-subtle rounded-lg p-4 hover:border-emerald-300 hover:shadow-sm transition-all"
                >
                  <h3 class="font-semibold text-gray-900 dark:text-white text-sm">
                    {isZh ? '查看父抓手' : 'View parent lever'}
                  </h3>
                  <p class="text-xs text-gray-600 dark:text-gray-400 mt-2">{pickLocalized(lever, 'subtitle', lang)}</p>
                </a>
              )}
            </div>
          </section>

          {page.item.sourceUrl && (
            <a
              href={page.item.sourceUrl}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-secondary border border-primary/30 hover:border-primary px-4 py-2 rounded-md transition-colors"
            >
              <Icon name="tabler:external-link" class="w-4 h-4" />
              {isZh ? '来源' : 'Source'}
            </a>
          )}
        </>
      )
    }

    <nav class="mt-12 pt-6 border-t border-subtle">
      <a
        href={localizedHref('/levers/', lang)}
        class="text-sm text-primary hover:text-secondary font-medium inline-flex items-center gap-1"
      >
        <Icon name="tabler:arrow-left" class="w-4 h-4" />
        {t(lang, 'back')}
        {t(lang, 'navLevers')}
      </a>
    </nav>
  </article>
</Layout>
