---
import { Icon } from 'astro-icon/components';

import Headline from '~/components/ui/Headline.astro';
import Layout from '~/layouts/PageLayout.astro';
import {
  benchmarkCaseProfileUpdated,
  benchmarkCases,
  dataDate,
  dataDisclaimer,
  dataDisclaimerEn,
  insights,
  regions,
} from '~/data/benchmarking';
import { NON_DEFAULT_ROUTE_LOCALES, localizedHref, pickLocalized, t, type Lang } from '~/i18n';
import { benchmarkCaseSlug, regionPages, regionSlug } from '~/utils/entity-pages';

export function getStaticPaths() {
  return NON_DEFAULT_ROUTE_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const isZh = lang === 'zh';
const disclaimer = isZh ? dataDisclaimer : dataDisclaimerEn || dataDisclaimer;
const insightCaseIds = ['ai-verify', 'mgx-ai-fund', 'unit-8200-ai-talent-pipeline', 'falcon-llm'];
const caseById = new Map(benchmarkCases.map((caseItem) => [caseItem.id, caseItem]));

function caseHref(caseItem: (typeof benchmarkCases)[number]): string {
  return localizedHref(`/benchmarking/${benchmarkCaseSlug(caseItem)}/`, lang);
}

function insightHref(index: number): string {
  const caseItem = caseById.get(insightCaseIds[index]);
  return caseItem ? caseHref(caseItem) : localizedHref('/benchmarking/', lang);
}
---

<Layout
  metadata={{
    title: t(lang, 'benchmarkingPageTitle'),
    description: t(lang, 'benchmarkingPageDesc'),
  }}
  breadcrumbs={[{ label: t(lang, 'navBenchmarking') }]}
  lang={lang}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-6xl">
    <Headline
      title={t(lang, 'benchmarkingPageTitle')}
      subtitle={isZh
        ? '从国家战略下钻到具体公司、项目、机构和基础设施。'
        : 'From national strategy down to concrete companies, projects, institutions, and infrastructure.'}
      classes={{ title: 'text-3xl md:text-4xl', subtitle: 'text-lg md:text-xl' }}
    />

    <div class="mb-12 grid gap-4 md:grid-cols-[1.25fr_0.75fr]">
      <div class="callout-note rounded-lg p-6">
        <p class="font-serif text-lg leading-[1.85] text-gray-900 dark:text-white">
          {
            isZh
              ? '真正有用的对标，不是"某国 AI 很强"这种空话，而是看它把哪个具体对象做成了国家能力：一只基金、一所大学、一个模型、一套测试框架、一个政府 AI 助手，或一个供应链节点。'
              : 'Useful benchmarking is not "Country X is strong at AI". It asks which concrete object became a national capability: a fund, a university, a model, a testing framework, a government assistant, or a supply-chain node.'
          }
        </p>
      </div>
      <dl class="grid gap-3 sm:grid-cols-3 md:grid-cols-1">
        <div class="rounded-lg border border-subtle bg-surface p-4">
          <dt class="text-xs uppercase tracking-wider text-muted">{isZh ? '案例档案' : 'Case profiles'}</dt>
          <dd class="mt-1 text-2xl font-bold text-gray-900 dark:text-white">{benchmarkCases.length}</dd>
        </div>
        <div class="rounded-lg border border-subtle bg-surface p-4">
          <dt class="text-xs uppercase tracking-wider text-muted">{isZh ? '地区背景' : 'Region profiles'}</dt>
          <dd class="mt-1 text-2xl font-bold text-gray-900 dark:text-white">{regionPages.length}</dd>
        </div>
        <div class="rounded-lg border border-subtle bg-surface p-4">
          <dt class="text-xs uppercase tracking-wider text-muted">{isZh ? '档案更新' : 'Profiles updated'}</dt>
          <dd class="mt-1 text-sm font-semibold text-gray-900 dark:text-white">{benchmarkCaseProfileUpdated}</dd>
        </div>
      </dl>
    </div>

    <div class="mb-12">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between mb-5">
        <div>
          <h2 class="t-h3">{isZh ? '标杆案例库' : 'Benchmark Case Library'}</h2>
          <p class="text-sm text-muted mt-1">
            {
              isZh
                ? '每张卡片对应一个可继续丰富的公司、项目或机构档案。'
                : 'Each card maps to a profile that can grow over time.'
            }
          </p>
        </div>
        <a href="#region-overview" class="text-sm text-primary hover:text-secondary inline-flex items-center gap-1">
          {isZh ? '看地区总览' : 'View region overview'}
          <Icon name="tabler:arrow-down" class="w-4 h-4" />
        </a>
      </div>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          benchmarkCases.map((caseItem) => (
            <a
              href={caseHref(caseItem)}
              class="group flex h-full flex-col rounded-lg border border-subtle bg-surface p-5 hover:border-primary/50 hover:shadow-sm transition-all"
            >
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-xs text-muted">
                    {caseItem.flag} {pickLocalized(caseItem, 'region', lang)} · {pickLocalized(caseItem, 'type', lang)}
                  </p>
                  <h3 class="mt-2 text-lg font-bold text-gray-900 dark:text-white group-hover:text-primary">
                    {pickLocalized(caseItem, 'name', lang)}
                  </h3>
                </div>
                <Icon name="tabler:arrow-up-right" class="w-5 h-5 text-muted group-hover:text-primary shrink-0" />
              </div>
              <p class="mt-3 text-sm leading-relaxed text-gray-700 dark:text-gray-300">
                {pickLocalized(caseItem, 'headline', lang)}
              </p>
              <dl class="mt-4 grid gap-2 text-xs">
                {caseItem.facts.slice(0, 2).map((fact) => (
                  <div class="flex items-start justify-between gap-3 border-t border-subtle pt-2">
                    <dt class="text-muted">{pickLocalized(fact, 'label', lang)}</dt>
                    <dd class="text-right font-medium text-gray-900 dark:text-white">
                      {pickLocalized(fact, 'value', lang)}
                    </dd>
                  </div>
                ))}
              </dl>
              <span class="mt-auto pt-5 text-sm font-medium text-primary inline-flex items-center gap-1">
                {isZh ? '打开档案' : 'Open profile'}
                <Icon name="tabler:arrow-right" class="w-4 h-4" />
              </span>
            </a>
          ))
        }
      </div>
    </div>

    <div class="mb-12">
      <h2 class="t-h3 mb-4">{isZh ? '关键洞察' : 'Key Insights'}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {
          insights.map((insight, index) => (
            <a
              href={insightHref(index)}
              class="group rounded-lg border border-subtle bg-surface p-5 hover:border-primary/50 hover:shadow-sm transition-all"
            >
              <div class="flex items-start justify-between gap-3">
                <h3 class="font-bold text-lg text-gray-900 dark:text-white group-hover:text-primary">
                  {pickLocalized(insight, 'title', lang)}
                </h3>
                <Icon name="tabler:arrow-up-right" class="w-5 h-5 text-muted group-hover:text-primary shrink-0" />
              </div>
              <p class="text-muted text-sm leading-relaxed mt-2">{pickLocalized(insight, 'text', lang)}</p>
            </a>
          ))
        }
      </div>
    </div>

    <div id="region-overview" class="mb-12 scroll-mt-24">
      <h2 class="t-h3 mb-4">{isZh ? '总览对比表' : 'Overview Comparison'}</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse min-w-[900px]">
          <thead>
            <tr class="bg-slate-100 dark:bg-slate-800">
              <th class="text-left p-3 border border-subtle">{isZh ? '地区' : 'Region'}</th>
              <th class="text-left p-3 border border-subtle">{isZh ? '核心战略' : 'Core strategy'}</th>
              <th class="text-left p-3 border border-subtle">{isZh ? '年份' : 'Year'}</th>
              <th class="text-left p-3 border border-subtle">{isZh ? '投资规模' : 'Investment'}</th>
              <th class="text-left p-3 border border-subtle">{isZh ? '治理模式' : 'Governance'}</th>
              <th class="text-left p-3 border border-subtle">{isZh ? '核心优势' : 'Strength'}</th>
              <th class="text-left p-3 border border-subtle">{isZh ? 'AI 排名' : 'AI ranking'}</th>
            </tr>
          </thead>
          <tbody>
            {
              regions.map((r, i) => (
                <tr
                  class={
                    i === 0
                      ? 'bg-blue-50 dark:bg-blue-900/20 font-semibold'
                      : 'hover:bg-slate-50 dark:hover:bg-slate-800/50'
                  }
                >
                  <td class="p-3 border border-subtle whitespace-nowrap">
                    <a
                      href={localizedHref(`/benchmarking/${regionSlug(r)}/`, lang)}
                      class="text-primary hover:text-secondary inline-flex items-center gap-1"
                    >
                      <span>
                        {r.flag} {pickLocalized(r, 'name', lang)}
                      </span>
                      <Icon name="tabler:arrow-up-right" class="w-3.5 h-3.5" />
                    </a>
                  </td>
                  <td class="p-3 border border-subtle">{pickLocalized(r, 'strategy', lang)}</td>
                  <td class="p-3 border border-subtle">{r.strategyYear}</td>
                  <td class="p-3 border border-subtle">{pickLocalized(r, 'investment', lang)}</td>
                  <td class="p-3 border border-subtle">{pickLocalized(r, 'governance', lang)}</td>
                  <td class="p-3 border border-subtle">{pickLocalized(r, 'strength', lang)}</td>
                  <td class="p-3 border border-subtle text-muted">{r.aiRanking || '—'}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>

    <div class="mb-12">
      <h2 class="t-h3 mb-5">{isZh ? '地区背景页' : 'Region Background Pages'}</h2>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          regionPages.map((page) => (
            <a
              href={localizedHref(`/benchmarking/${page.slug}/`, lang)}
              class="group rounded-lg border border-subtle bg-surface p-5 hover:border-primary/50 hover:shadow-sm transition-all"
            >
              <p class="text-xs text-muted">
                {page.summary.strategyYear} · {pickLocalized(page.summary, 'governance', lang)}
              </p>
              <h3 class="mt-2 text-lg font-bold text-gray-900 dark:text-white group-hover:text-primary">
                {page.summary.flag} {pickLocalized(page.summary, 'name', lang)}
              </h3>
              <p class="mt-2 text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
                {pickLocalized(page.summary, 'strength', lang)}
              </p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary">
                {isZh ? '查看国家 / 地区档案' : 'View region profile'}
                <Icon name="tabler:arrow-right" class="w-4 h-4" />
              </span>
            </a>
          ))
        }
      </div>
    </div>

    <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800 border border-subtle">
      <p class="text-sm text-muted">⚠️ {disclaimer}</p>
      <p class="text-xs text-muted mt-1">
        {isZh ? '基础数据更新' : 'Base data updated'}: {dataDate};{' '}
        {isZh ? '案例档案整理' : 'case profiles curated'}: {benchmarkCaseProfileUpdated}
      </p>
    </div>
  </section>
</Layout>
