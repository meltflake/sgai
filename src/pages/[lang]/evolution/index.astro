---
import Layout from '~/layouts/PageLayout.astro';
import EvolutionPage from '~/components/evolution/EvolutionPage.astro';
import { NON_DEFAULT_ROUTE_LOCALES, t, type Lang } from '~/i18n';

export function getStaticPaths() {
  return NON_DEFAULT_ROUTE_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
---

<Layout
  metadata={{
    title: t(lang, 'evolutionPageTitle'),
    description: t(lang, 'evolutionPageDesc'),
  }}
  breadcrumbs={[{ label: t(lang, 'evolutionPageTitle') }]}
  lang={lang}
>
  <EvolutionPage lang={lang} />
</Layout>
