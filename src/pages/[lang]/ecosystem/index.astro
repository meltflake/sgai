---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import { Icon } from 'astro-icon/components';
import { ecosystemCategories } from '~/data/ecosystem';
import { NON_DEFAULT_ROUTE_LOCALES, localizedHref, pickLocalized, t, type Lang } from '~/i18n';

export function getStaticPaths() {
  return NON_DEFAULT_ROUTE_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
---

<Layout
  metadata={{
    title: t(lang, 'ecosystemPageTitle'),
    description: t(lang, 'ecosystemPageDesc'),
  }}
  breadcrumbs={[{ label: t(lang, 'navEcosystem') }]}
  lang={lang}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-6xl">
    <Headline title={`🗺️ ${t(lang, 'ecosystemPageTitle')}`} subtitle={t(lang, 'ecosystemSubtitle')} />

    <div class="space-y-12">
      {
        ecosystemCategories.map((cat) => (
          <div>
            <div class="mb-4">
              <h2 class="t-h2 border-b-2 border-blue-600 dark:border-blue-400 pb-2">
                {cat.icon} {pickLocalized(cat, 'name', lang)}
              </h2>
              <p class="text-sm text-muted mt-2">{pickLocalized(cat, 'description', lang)}</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
              {cat.entities.map((entity) => {
                const hasDetail = Boolean(entity.id);
                const detailHref = hasDetail ? localizedHref(`/ecosystem/${entity.id}/`, lang) : null;
                const displayName = pickLocalized(entity, 'name', lang) ?? entity.name;
                const displayDesc = pickLocalized(entity, 'description', lang) ?? entity.description;
                const readMoreLabel = t(lang, 'ecosystemReadMore');
                const visitLabel = t(lang, 'ecosystemVisitWebsite').replace('{name}', displayName ?? '');
                return (
                  <div class="relative bg-surface rounded-lg shadow-md border border-subtle hover:shadow-lg transition-shadow">
                    {detailHref ? (
                      <a href={detailHref} class="block p-5 pr-10">
                        <h3 class="text-base font-bold mb-1 text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                          {displayName}
                        </h3>
                        <p class="text-sm text-muted">{displayDesc}</p>
                        <p class="text-xs text-blue-600 dark:text-blue-400 mt-3 font-medium">{readMoreLabel}</p>
                      </a>
                    ) : (
                      <div class="block p-5 pr-10">
                        <h3 class="text-base font-bold mb-1">
                          {entity.url ? (
                            <a
                              href={entity.url}
                              target="_blank"
                              rel="noopener"
                              class="text-blue-600 dark:text-blue-400 hover:underline"
                            >
                              {displayName} ↗
                            </a>
                          ) : (
                            displayName
                          )}
                        </h3>
                        <p class="text-sm text-muted">{displayDesc}</p>
                      </div>
                    )}
                    {hasDetail && entity.url && (
                      <a
                        href={entity.url}
                        target="_blank"
                        rel="noopener"
                        title={visitLabel}
                        aria-label={visitLabel}
                        class="absolute top-3 right-3 inline-flex items-center justify-center w-7 h-7 rounded-md text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/30 transition-colors"
                      >
                        <Icon name="tabler:external-link" class="w-4 h-4" />
                      </a>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        ))
      }
    </div>

    <p class="mt-12 text-sm text-muted text-center">{t(lang, 'ecosystemSourceFootnote')}</p>
  </section>
</Layout>
