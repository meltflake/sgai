---
import Layout from '~/layouts/PageLayout.astro';
import TimelinePage from '~/components/timeline/TimelinePage.astro';
import { NON_DEFAULT_ROUTE_LOCALES, t, type Lang } from '~/i18n';

export function getStaticPaths() {
  return NON_DEFAULT_ROUTE_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
---

<Layout
  metadata={{
    title: t(lang, 'timelinePageTitle'),
    description: t(lang, 'timelinePageDesc'),
  }}
  breadcrumbs={[{ label: t(lang, 'timelinePageTitle') }]}
  lang={lang}
>
  <TimelinePage lang={lang} />
</Layout>
