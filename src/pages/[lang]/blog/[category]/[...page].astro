---
import type { GetStaticPaths } from 'astro';
import type { Page } from 'astro';
import type { Post } from '~/types';
import { blogCategoryRobots, blogPostsPerPage, fetchPosts } from '~/utils/blog';
import { CATEGORY_BASE } from '~/utils/permalinks';

import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Headline from '~/components/blog/Headline.astro';
import Pagination from '~/components/blog/Pagination.astro';
import { NON_DEFAULT_ROUTE_LOCALES, type Lang } from '~/i18n';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await fetchPosts();
  // Same per-lang split as the [tag] route — without it, /ja/blog/<zh-slug>/
  // listing pages render zh post excerpts under JA chrome and fail Layer D.
  return NON_DEFAULT_ROUTE_LOCALES.flatMap((lang) => {
    const langPosts = allPosts.filter((p) => (p.lang ?? 'zh') === lang);
    const categories: Record<string, { slug: string; title: string }> = {};
    for (const post of langPosts) {
      if (post.category?.slug) categories[post.category.slug] = post.category;
    }
    return Object.keys(categories).flatMap((categorySlug) =>
      paginate(
        langPosts.filter((post) => post.category?.slug && categorySlug === post.category.slug),
        {
          params: { lang, category: categorySlug, blog: CATEGORY_BASE || undefined },
          pageSize: blogPostsPerPage,
          props: { category: categories[categorySlug] },
        }
      )
    );
  });
}) satisfies GetStaticPaths;

const { page, category } = Astro.props as { page: Page<Post>; category: { slug: string; title: string } };
const lang = Astro.params.lang as Lang;
const currentPage = page.currentPage ?? 1;

const metadata = {
  title: `Category '${category.title}' ${currentPage > 1 ? ` — Page ${currentPage}` : ''}`,
  robots: {
    index: blogCategoryRobots?.index,
    follow: blogCategoryRobots?.follow,
  },
};
---

<Layout metadata={metadata} lang={lang}>
  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline>{category.title}</Headline>
    <BlogList posts={page.data} />
    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
  </section>
</Layout>
