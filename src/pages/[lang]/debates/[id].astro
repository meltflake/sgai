---
// Debate detail page ([lang]). One page per Debate.id x non-default locale.

import type { GetStaticPaths } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import RelatedRail from '~/components/data/RelatedRail.astro';
import { Icon } from 'astro-icon/components';
import { debates } from '~/data/debates';
import { getDebateTranscript, getDebateTranscriptParagraphs } from '~/data/debate-transcripts';
import { findPersonId, getPerson, personDisplayName } from '~/utils/people';
import { NON_DEFAULT_ROUTE_LOCALES, IN_LANGUAGES, t, pickLocalized, localizedHref, type Lang } from '~/i18n';

export const prerender = true;

export const getStaticPaths = (() =>
  NON_DEFAULT_ROUTE_LOCALES.flatMap((lang) =>
    debates.map((debate) => ({
      params: { lang, id: debate.id },
      props: { debate },
    }))
  )) satisfies GetStaticPaths;

const { debate } = Astro.props;
const lang = Astro.params.lang as Lang;
const isZh = lang === 'zh';

const transcript = getDebateTranscript(debate.id);
const transcriptZh = getDebateTranscriptParagraphs(debate.id, 'zh');
const transcriptEn = getDebateTranscriptParagraphs(debate.id, 'en');
const originalParagraphs = transcriptEn.length
  ? transcriptEn
  : isZh
    ? debate.summary
      ? [debate.summary]
      : []
    : debate.transcriptEn
      ? [debate.transcriptEn]
      : [];

const typeMapZh: Record<string, string> = {
  'Oral Answers to Questions': '口头答复',
  'Written Answers to Questions': '书面答复',
  Budget: '预算辩论',
  Motion: '动议',
};
const typeMapEn: Record<string, string> = {
  'Oral Answers to Questions': 'Oral Answer',
  'Written Answers to Questions': 'Written Answer',
  Budget: 'Budget Debate',
  Motion: 'Motion',
};
const typeMap = isZh ? typeMapZh : typeMapEn;

const topicZh: Record<string, string> = {
  'AI Economy & Industry': 'AI 经济与产业',
  'AI & Employment': 'AI 与就业',
  'AI Governance & Regulation': 'AI 治理与监管',
  'AI & National Security': 'AI 与国家安全',
  'AI in Public Sector': 'AI 与公共部门',
  'AI Infrastructure & Research': 'AI 基础设施与研究',
  'AI Safety & Ethics': 'AI 安全与伦理',
  'AI in Education': 'AI 与教育',
  'AI in Healthcare': 'AI 与医疗',
  'AI Strategy': 'AI 战略',
  'Deepfakes & Disinformation': '深度伪造与虚假信息',
  'Generative AI': '生成式 AI',
};
const topicEn: Record<string, string> = {
  'AI Economy & Industry': 'AI Economy & Industry',
  'AI & Employment': 'AI & Employment',
  'AI Governance & Regulation': 'AI Governance & Regulation',
  'AI & National Security': 'AI & National Security',
  'AI in Public Sector': 'AI in Public Sector',
  'AI Infrastructure & Research': 'AI Infrastructure & Research',
  'AI Safety & Ethics': 'AI Safety & Ethics',
  'AI in Education': 'AI in Education',
  'AI in Healthcare': 'AI in Healthcare',
  'AI Strategy': 'AI Strategy',
  'Deepfakes & Disinformation': 'Deepfakes & Disinformation',
  'Generative AI': 'Generative AI',
};
const topicMap = isZh ? topicZh : topicEn;

const controversyLabelsZh: Record<number, string> = {
  1: '信息发布',
  2: '温和质询',
  3: '实质辩论',
  4: '激烈争议',
  5: '高度对立',
};
const controversyLabelsEn: Record<number, string> = {
  1: 'Information',
  2: 'Mild query',
  3: 'Substantive debate',
  4: 'Heated dispute',
  5: 'High polarisation',
};
const controversyLabels = isZh ? controversyLabelsZh : controversyLabelsEn;

const speakers = debate.speakers.map((raw) => {
  const pid = findPersonId(raw);
  const p = pid ? getPerson(pid) : undefined;
  return { raw, pid, display: p ? (isZh ? personDisplayName(pid!) : p.nameEn || p.name || raw) : raw };
});

const summaryShort = isZh ? debate.summary || '' : pickLocalized<string>(debate, 'summary', lang) || '';
const keyPoints = isZh
  ? debate.keyPoints || []
  : (debate.keyPointsEn?.length ? debate.keyPointsEn : debate.keyPoints) || [];
const govStance = isZh
  ? debate.governmentStance
  : pickLocalized(debate, 'governmentStance', 'governmentStanceEn', lang);
const oppStance = isZh
  ? debate.oppositionStance
  : pickLocalized(debate, 'oppositionStance', 'oppositionStanceEn', lang);
const policySignal = isZh ? debate.policySignal : pickLocalized(debate, 'policySignal', 'policySignalEn', lang);
const notableQuote = isZh ? debate.notableQuote : pickLocalized(debate, 'notableQuote', 'notableQuoteEn', lang);

const debateTitle = isZh ? debate.title : debate.titleEn || debate.title;

const metadata = {
  title: `${debateTitle} · ${isZh ? '国会辩论' : 'Parliamentary Debate'}`,
  description: summaryShort,
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: debateTitle,
  ...(isZh ? { alternativeHeadline: debate.title } : {}),
  description: summaryShort,
  datePublished: debate.date,
  inLanguage: IN_LANGUAGES[lang],
  isPartOf: { '@type': 'CreativeWork', name: 'Singapore Hansard', url: 'https://sprs.parl.gov.sg/' },
};

const breadcrumbs = [
  { label: t(lang, 'navParliament'), href: localizedHref('/debates/', lang) },
  { label: debateTitle },
];
---

<Layout metadata={metadata} breadcrumbs={breadcrumbs} lang={lang}>
  <JsonLd schema={articleSchema} />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <p class="text-xs uppercase tracking-[0.18em] text-primary font-semibold mb-4">
      {typeMap[debate.type] || debate.type} · {debate.date} · {
        isZh ? `第 ${debate.parliament} 届国会` : `Parliament ${debate.parliament}`
      }
    </p>
    <h1 class="t-display text-gray-900 dark:text-white mb-3">
      {debateTitle}
    </h1>
    {
      isZh && (
        <p class="text-sm md:text-base text-gray-500 dark:text-gray-400 italic mb-6 leading-relaxed">{debate.title}</p>
      )
    }

    {
      debate.topics && debate.topics.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-8">
          {debate.topics.map((tp) => (
            <span class="text-xs bg-primary/10 text-primary px-3 py-1.5 rounded-full">{topicMap[tp] || tp}</span>
          ))}
          <span class="text-xs bg-gray-100 dark:bg-slate-800 text-gray-700 dark:text-gray-300 px-3 py-1.5 rounded-full ml-auto">
            {t(lang, 'controversyLevel')} {debate.controversyLevel} · {controversyLabels[debate.controversyLevel] || ''}
          </span>
        </div>
      )
    }

    {
      summaryShort && (
        <p class="font-serif text-lg leading-[1.85] text-gray-800 dark:text-gray-200 mb-8 border-l-4 border-primary pl-5 italic">
          {summaryShort}
        </p>
      )
    }

    {
      keyPoints.length > 0 && (
        <section class="mb-8">
          <h2 class="t-h3 text-gray-900 dark:text-white mb-4">{t(lang, 'keyPoints')}</h2>
          <ul class="space-y-2 text-gray-700 dark:text-gray-300 leading-[1.85]">
            {keyPoints.map((kp) => (
              <li class="flex gap-3">
                <span class="text-primary shrink-0 mt-1">&bull;</span>
                <span>{kp}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      (govStance || oppStance) && (
        <section class="mb-8 grid md:grid-cols-2 gap-4">
          {govStance && (
            <div class="border border-subtle rounded-lg p-4">
              <div class="text-xs font-semibold uppercase tracking-wider text-blue-600 dark:text-blue-400 mb-2">
                {t(lang, 'governmentStance')}
              </div>
              <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">{govStance}</p>
            </div>
          )}
          {oppStance && (
            <div class="border border-subtle rounded-lg p-4">
              <div class="text-xs font-semibold uppercase tracking-wider text-orange-600 dark:text-orange-400 mb-2">
                {t(lang, 'oppositionStance')}
              </div>
              <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">{oppStance}</p>
            </div>
          )}
        </section>
      )
    }

    {
      policySignal && (
        <section class="mb-8 bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800 rounded-lg p-4">
          <div class="text-xs font-semibold uppercase tracking-wider text-purple-600 dark:text-purple-400 mb-1">
            {t(lang, 'policySignal')}
          </div>
          <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">{policySignal}</p>
        </section>
      )
    }

    {
      notableQuote && (
        <blockquote class="border-l-4 border-gray-300 dark:border-gray-600 pl-5 my-8 text-lg font-serif italic text-gray-700 dark:text-gray-300 leading-[1.85]">
          &ldquo;{notableQuote}&rdquo;
        </blockquote>
      )
    }

    {
      speakers.length > 0 && (
        <section class="mb-8 mt-10 pt-6 border-t border-subtle">
          <h2 class="text-sm uppercase tracking-wider text-gray-500 dark:text-gray-400 font-semibold mb-3">
            {t(lang, 'participants')} ({speakers.length})
          </h2>
          <ul class="flex flex-wrap gap-x-4 gap-y-2">
            {speakers.map((s) => (
              <li>
                {s.pid ? (
                  <a
                    href={localizedHref(`/voices/${s.pid}/`, lang)}
                    class="text-primary hover:text-secondary text-sm font-medium"
                    title={s.raw}
                  >
                    {s.display}
                  </a>
                ) : (
                  <span class="text-sm text-gray-700 dark:text-gray-300">{s.raw}</span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      isZh && transcriptZh.length > 0 && (
        <section class="my-8 border border-primary/20 bg-primary/5 rounded-xl p-5">
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-4">
            <h2 class="t-h3 text-gray-900 dark:text-white">{'完整译文（中文）'}</h2>
            <p class="text-xs text-gray-500 dark:text-gray-400">
              {'Hansard 英文原文译文'}
              {transcript?.translatedAt && ` · 翻译日期：${transcript.translatedAt}`}
            </p>
          </div>
          <div class="space-y-4 text-base text-gray-700 dark:text-gray-300 leading-[1.9]">
            {transcriptZh.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </section>
      )
    }

    {
      originalParagraphs.length > 0 && (
        <section class="my-8 border border-subtle rounded-xl p-5" data-i18n-allow-cjk="hansard-original">
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-4">
            <h2 class="t-h3 text-gray-900 dark:text-white">{t(lang, 'fullTextEn')}</h2>
            <p class="text-xs text-gray-500 dark:text-gray-400">
              {isZh ? 'SPRS Hansard 原始记录' : 'SPRS Hansard'}
              {transcript?.fetchedAt && ` · ${isZh ? '抓取日期：' : 'Fetched: '}${transcript.fetchedAt}`}
            </p>
          </div>
          <div class="space-y-4 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
            {originalParagraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </section>
      )
    }

    <div class="mt-10 flex flex-wrap gap-3">
      {
        debate.sourceUrl && (
          <a
            href={debate.sourceUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-secondary border border-primary/30 hover:border-primary px-4 py-2 rounded-md transition-colors"
          >
            <Icon name="tabler:external-link" class="w-4 h-4" />
            {t(lang, 'hansardSource')}
          </a>
        )
      }
    </div>

    <RelatedRail entity={{ type: 'debate', id: debate.id }} variant="full" hideWhenEmpty={true} class="mt-12" />

    <nav class="mt-12 pt-6 border-t border-subtle">
      <a
        href={localizedHref('/debates/', lang)}
        class="text-sm text-primary hover:text-secondary font-medium inline-flex items-center gap-1"
      >
        <Icon name="tabler:arrow-left" class="w-4 h-4" />
        {t(lang, 'back')}
        {t(lang, 'navParliament')}
      </a>
    </nav>
  </article>
</Layout>
