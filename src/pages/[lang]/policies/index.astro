---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import PolicyCard from '~/components/data/PolicyCard.astro';
import { categories } from '~/data/policies';
import { NON_DEFAULT_ROUTE_LOCALES, t, pickLocalized, type Lang } from '~/i18n';

export function getStaticPaths() {
  return NON_DEFAULT_ROUTE_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const totalPolicies = categories.reduce((sum, cat) => sum + cat.policies.length, 0);
---

<Layout
  metadata={{
    title: t(lang, 'policiesPageTitle'),
    description: t(lang, 'policiesPageBlurb'),
  }}
  breadcrumbs={[{ label: t(lang, 'navPolicies') }]}
  lang={lang}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-6xl">
    <Headline title={`📋 ${t(lang, 'policiesPageTitle')}`} subtitle={t(lang, 'policiesPageBlurb')} />

    <div class="grid gap-3 sm:grid-cols-3 mb-12">
      <div class="bg-surface rounded-lg border border-subtle p-4">
        <p class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1">
          {t(lang, 'policiesStatProfiles')}
        </p>
        <p class="t-stat text-primary">{totalPolicies}</p>
      </div>
      <div class="bg-surface rounded-lg border border-subtle p-4">
        <p class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1">
          {t(lang, 'policiesStatCategories')}
        </p>
        <p class="t-stat text-primary">{categories.length}</p>
      </div>
      <div class="bg-surface rounded-lg border border-subtle p-4">
        <p class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1">
          {t(lang, 'policiesStatFormat')}
        </p>
        <p class="t-stat text-primary">{t(lang, 'policiesStatFormatValue')}</p>
      </div>
    </div>

    {
      categories.map((cat) => (
        <div class="mb-12">
          <h2 class="t-h2 mb-6 border-b-2 border-blue-600 dark:border-blue-400 pb-2">
            {cat.icon} {pickLocalized(cat, 'name', lang)}
            <span class="text-sm font-normal text-muted ml-2">
              ({cat.policies.length} {t(lang, 'policiesItemsSuffix')})
            </span>
          </h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {cat.policies.map((policy) => (
              <PolicyCard policy={policy} lang={lang} categoryIcon={cat.icon} />
            ))}
          </div>
        </div>
      ))
    }
  </section>
</Layout>
