---
import Layout from '~/layouts/PageLayout.astro';
import UpdatesPage from '~/components/home/UpdatesPage.astro';
import { NON_DEFAULT_ROUTE_LOCALES, t, type Lang } from '~/i18n';

export function getStaticPaths() {
  return NON_DEFAULT_ROUTE_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
---

<Layout
  metadata={{
    title: t(lang, 'updatesPageTitle'),
    description: t(lang, 'updatesPageBlurb'),
  }}
  breadcrumbs={[{ label: t(lang, 'updatesNav') }]}
  lang={lang}
>
  <UpdatesPage lang={lang} />
</Layout>
