---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import {
  universityProjects,
  corporateLabProjects,
  startupProjects,
  summary,
  dataDisclaimer,
} from '~/data/community-opensource';
---

<Layout
  metadata={{
    title: '产学研开源生态',
    description: '新加坡产学研 AI 开源生态——大学、企业实验室、创业公司的开源贡献全景。',
  }}
  breadcrumbs={[{ label: '产学研开源生态' }]}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-6xl">
    <Headline title="🌐 产学研开源生态" subtitle="新加坡大学、国际企业实验室与创业公司的 AI 开源项目" />

    <!-- Summary -->
    <div
      class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4 mb-12 text-sm text-blue-800 dark:text-blue-200"
    >
      💡 {summary.note}
    </div>

    <!-- 大学与研究机构 -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold mb-6">🎓 大学与研究机构</h2>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          universityProjects.map((proj) => (
            <div class="bg-surface rounded-lg shadow-md border border-subtle p-5 hover:shadow-lg transition-shadow">
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-bold">{proj.name}</h3>
                {proj.stars && (
                  <span class="text-xs text-muted whitespace-nowrap">⭐ {proj.stars.toLocaleString()}</span>
                )}
              </div>
              <p class="text-xs text-blue-600 dark:text-blue-400 mb-2">{proj.org}</p>
              <p class="text-sm text-muted mb-3">{proj.description}</p>
              <div class="flex items-center gap-2 flex-wrap">
                {proj.papers &&
                  proj.papers.map((p) => (
                    <span class="text-xs bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 px-2 py-0.5 rounded">
                      {p}
                    </span>
                  ))}
                {proj.url ? (
                  <a
                    href={proj.url}
                    target="_blank"
                    rel="noopener"
                    class="text-sm text-blue-600 dark:text-blue-400 hover:underline ml-auto"
                  >
                    GitHub →
                  </a>
                ) : (
                  <span class="text-xs text-muted ml-auto">暂无公开仓库</span>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- 国际企业新加坡实验室 -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold mb-6">🏢 国际企业新加坡实验室</h2>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          corporateLabProjects.map((proj) => (
            <div class="bg-surface rounded-lg shadow-md border border-subtle p-5 hover:shadow-lg transition-shadow">
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-bold">{proj.name}</h3>
                {proj.stars && (
                  <span class="text-xs text-muted whitespace-nowrap">⭐ {proj.stars.toLocaleString()}</span>
                )}
              </div>
              <p class="text-xs text-blue-600 dark:text-blue-400 mb-2">{proj.org}</p>
              <p class="text-sm text-muted mb-3">{proj.description}</p>
              <div class="flex items-center gap-2 flex-wrap">
                {proj.papers &&
                  proj.papers.map((p) => (
                    <span class="text-xs bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 px-2 py-0.5 rounded">
                      {p}
                    </span>
                  ))}
                {proj.url && (
                  <a
                    href={proj.url}
                    target="_blank"
                    rel="noopener"
                    class="text-sm text-blue-600 dark:text-blue-400 hover:underline ml-auto"
                  >
                    GitHub →
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- 创业公司 -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold mb-6">🚀 创业公司</h2>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          startupProjects.map((proj) => (
            <div class="bg-surface rounded-lg shadow-md border border-subtle p-5 hover:shadow-lg transition-shadow">
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-bold">{proj.name}</h3>
                {proj.stars && (
                  <span class="text-xs text-muted whitespace-nowrap">⭐ {proj.stars.toLocaleString()}</span>
                )}
              </div>
              <p class="text-xs text-blue-600 dark:text-blue-400 mb-2">{proj.org}</p>
              <p class="text-sm text-muted mb-3">{proj.description}</p>
              {proj.url && (
                <a
                  href={proj.url}
                  target="_blank"
                  rel="noopener"
                  class="text-sm text-blue-600 dark:text-blue-400 hover:underline"
                >
                  GitHub →
                </a>
              )}
            </div>
          ))
        }
      </div>
    </div>

    <!-- 数据说明 -->
    <p class="mt-12 text-sm text-muted text-center">{dataDisclaimer}</p>
  </section>
</Layout>
