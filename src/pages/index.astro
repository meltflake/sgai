---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { stats, features } from '~/data/stats';

const metadata = {
  title: 'SG AI 观察',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: '阅读定调文章',
        href: '/aisg/singapore-ai-strategy-the-real-moat',
        icon: 'tabler:bulb',
      },
      { text: '浏览政策库', href: '/aisg/policies/' },
    ]}
  >
    <Fragment slot="title">
      🇸🇬 深度观察<br /><span class="text-accent dark:text-white">新加坡 AI 生态</span>与战略
    </Fragment>

    <Fragment slot="subtitle">
      不只是信息整理，更是独立视角的深度分析。追踪 20 份核心政策、42 项关键指标、132 场国会辩论、650+ AI
      创业公司，探究新加坡 AI 战略的真正护城河。
    </Fragment>
  </Hero>

  <Features
    id="features"
    tagline="核心内容"
    title="六大板块，深度解读新加坡 AI 生态"
    subtitle="政策文件、执行追踪、创业生态、国际对标、深度分析，持续更新。"
    items={features}
  />

  <Stats stats={stats} />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: '阅读定调文章',
        href: '/aisg/singapore-ai-strategy-the-real-moat',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">新加坡的 AI 马六甲海峡在哪里？</Fragment>
    <Fragment slot="subtitle">
      我们的核心观点：新加坡真正的 AI 护城河不在技术，在制度。阅读定调文章，了解我们的分析框架。
    </Fragment>
  </CallToAction>
</Layout>
