---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { stats, features } from '~/data/stats';
import { DEBATE_STATS, KEY_INSIGHTS } from '~/data/debates';

const metadata = {
  title: 'SG AI 观察',
  ignoreTitleTemplate: true,
  description: '深度观察新加坡 AI 生态与战略——追踪核心政策、国会辩论、创业生态与关键指标，独立视角的中文分析平台。',
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'SG AI 观察',
  url: 'https://meltflake.com/aisg/',
  logo: 'https://meltflake.com/aisg/favicon.svg',
  description: '深度观察新加坡 AI 生态与战略的中文分析平台',
  sameAs: ['https://github.com/meltflake/aisg'],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'SG AI 观察',
  url: 'https://meltflake.com/aisg/',
  inLanguage: 'zh-CN',
};
---

<Layout metadata={metadata}>
  <JsonLd schema={organizationSchema} />
  <JsonLd schema={websiteSchema} />
  <Hero
    actions={[
      {
        variant: 'primary',
        text: '阅读定调文章',
        href: '/aisg/singapore-ai-strategy-the-real-moat',
        icon: 'tabler:bulb',
      },
      { text: '浏览政策库', href: '/aisg/policies/' },
    ]}
  >
    <Fragment slot="title">
      🇸🇬 深度观察<br /><span class="text-accent dark:text-white">新加坡 AI 生态</span>与战略
    </Fragment>

    <Fragment slot="subtitle">
      不只是信息整理，更是独立视角的深度分析。追踪 20 份核心政策、42 项关键指标、150 场国会辩论、650+ AI
      创业公司，探究新加坡 AI 战略的真正护城河。
    </Fragment>
  </Hero>

  <Features
    id="features"
    tagline="核心内容"
    title="深度解读新加坡 AI 生态"
    subtitle="政策文件、执行追踪、创业生态、国会辩论、国际对标、深度分析，持续更新。"
    items={features}
  />

  <Stats stats={stats} />

  <!-- 国会辩论专区 -->
  <section class="py-12 md:py-16 bg-gray-50 dark:bg-slate-900">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-8">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-600 dark:text-blue-400 mb-2">国会 AI 焦点</p>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-3">
          {DEBATE_STATS.total} 场国会辩论，解码政策风向
        </h2>
        <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
          从 2015 年到 2026 年，新加坡议会围绕 AI 的每一次质询、答复与辩论，我们都做了中文摘要、立场分析和政策信号提炼。
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5 mb-8">
        {
          KEY_INSIGHTS.filter((ins) => ins.significance === 'high').map((ins) => (
            <div class="bg-white dark:bg-slate-800 rounded-xl p-5 shadow-sm border-l-4 border-l-red-500 border border-gray-100 dark:border-slate-700">
              <h3 class="font-semibold text-gray-800 dark:text-white text-sm mb-2">{ins.title}</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{ins.description}</p>
            </div>
          ))
        }
      </div>

      <div class="flex flex-wrap justify-center gap-6 text-center text-sm text-gray-500 dark:text-gray-400 mb-8">
        <div>
          <span class="block text-2xl font-bold text-gray-900 dark:text-white"
            >{Object.keys(DEBATE_STATS.byTopic).length}</span
          >
          议题领域
        </div>
        <div>
          <span class="block text-2xl font-bold text-gray-900 dark:text-white"
            >{Object.keys(DEBATE_STATS.topSpeakers).length}+</span
          >
          活跃议员
        </div>
        <div>
          <span class="block text-2xl font-bold text-gray-900 dark:text-white"
            >{DEBATE_STATS.yearRange.from}–{DEBATE_STATS.yearRange.to}</span
          >
          时间跨度
        </div>
      </div>

      <div class="text-center">
        <a
          href="/aisg/debates/"
          class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
        >
          浏览全部辩论记录
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
          >
        </a>
      </div>
    </div>
  </section>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: '阅读定调文章',
        href: '/aisg/singapore-ai-strategy-the-real-moat',
        icon: 'tabler:arrow-right',
      },
    ]}
  >
    <Fragment slot="title">新加坡的 AI 马六甲海峡在哪里？</Fragment>
    <Fragment slot="subtitle">
      我们的核心观点：新加坡真正的 AI 护城河不在技术，在制度。阅读定调文章，了解我们的分析框架。
    </Fragment>
  </CallToAction>
</Layout>
