---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import { sections } from '~/data/tracker';
---

<Layout
  metadata={{
    title: '落地执行追踪器',
    description: '新加坡 AI 发展关键指标追踪——投资规模、人才数量、算力基建等核心数据。',
  }}
  breadcrumbs={[{ label: '关键指标' }]}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-5xl">
    <Headline title="📊 落地执行追踪器" subtitle="追踪新加坡 AI 战略的关键执行指标，数据来源为官方公开信息。" />

    <div class="space-y-8">
      {
        sections.map((section) => (
          <div>
            <h2 class="text-xl font-bold mb-4">
              {section.icon} {section.title}
            </h2>
            <div class="overflow-x-auto">
              <table class="w-full text-sm border-collapse">
                <thead>
                  <tr class="bg-slate-100 dark:bg-slate-800">
                    <th class="text-left p-3 border border-subtle">指标</th>
                    <th class="text-left p-3 border border-subtle">数据</th>
                    <th class="text-left p-3 border border-subtle">来源/时间</th>
                  </tr>
                </thead>
                <tbody>
                  {section.rows.map((row) => (
                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
                      <td class="p-3 border border-subtle">{row.name}</td>
                      <td class="p-3 border border-subtle font-semibold">{row.value}</td>
                      <td class="p-3 border border-subtle text-muted">
                        {row.sourceUrl ? (
                          <a
                            href={row.sourceUrl}
                            target="_blank"
                            rel="noopener"
                            class="text-blue-600 dark:text-blue-400 hover:underline"
                          >
                            {row.source} ↗
                          </a>
                        ) : (
                          row.source
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))
      }
    </div>

    <p class="mt-8 text-sm text-muted">⚠️ 数据截至 2024 年底，部分为估算值。欢迎提供更新数据。</p>
  </section>
</Layout>
