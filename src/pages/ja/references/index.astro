---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import { sections } from '~/data/references';
---

<Layout
  metadata={{
    title: '参考資料ライブラリ',
    description: 'シンガポール AI 参考リソース——公式レポート、研究論文、データセット、ツール、推薦記事。',
  }}
  breadcrumbs={[{ label: '参考リソース' }]}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-4xl">
    <Headline
      title="📚 参考資料ライブラリ"
      subtitle="シンガポール AI 政策関連の公式文書、研究レポート、ニュース報道、分析記事。"
    />

    <div class="space-y-8">
      {
        sections.map((section) => (
          <div>
            <h2 class="t-h3 mb-3">
              {section.icon} {section.title}
            </h2>
            <ul class="space-y-2">
              {section.links.map((link) => (
                <li class="flex items-start gap-2">
                  <span class="text-blue-500 mt-1">•</span>
                  <div>
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener"
                      class="text-blue-600 dark:text-blue-400 hover:underline"
                    >
                      {link.text}
                    </a>
                    {link.translation && (
                      <a
                        href={link.translation}
                        class="text-sm text-green-600 dark:text-green-400 hover:underline ml-2"
                      >
                        [中国語翻訳]
                      </a>
                    )}
                    {link.note && <span class="text-sm text-muted ml-2">— {link.note}</span>}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <p class="mt-8 text-sm text-muted">
      30以上の参考資料を収録し、継続的に更新しています。新しいリソースの提出を歓迎します。
    </p>
  </section>
</Layout>
