---
import Layout from '~/layouts/Layout.astro';
import { localizedHref } from '~/i18n';

const title = 'ページが見つかりません';
---

<Layout
  metadata={{
    title,
    description: 'お探しのページは存在しません。',
    robots: { index: false, follow: false },
  }}
  lang="ja"
>
  <section class="flex items-center h-full p-16">
    <div class="container flex flex-col items-center justify-center px-5 mx-auto my-8">
      <div class="max-w-md text-center">
        <h2 class="mb-8 font-bold text-9xl">
          <span class="sr-only">エラー</span>
          <span class="text-primary">404</span>
        </h2>
        <p class="text-3xl font-semibold md:text-3xl">ページが見つかりません</p>
        <p class="mt-4 mb-8 text-lg text-muted dark:text-slate-400">
          お探しのページは存在しません。トップページからご覧ください。
        </p>
        <a rel="noopener noreferrer" href={localizedHref('/', 'ja')} class="btn ml-4">トップページへ</a>
      </div>
    </div>
  </section>
</Layout>
