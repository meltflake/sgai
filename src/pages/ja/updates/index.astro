---
import Layout from '~/layouts/PageLayout.astro';
import UpdatesPage from '~/components/home/UpdatesPage.astro';
import { t } from '~/i18n';

const lang = 'ja' as const;
---

<Layout
  metadata={{
    title: t(lang, 'updatesPageTitle'),
    description: t(lang, 'updatesPageBlurb'),
  }}
  breadcrumbs={[{ label: t(lang, 'updatesNav') }]}
  lang={lang}
>
  <UpdatesPage lang={lang} />
</Layout>
