---
import Layout from '~/layouts/PageLayout.astro';
import { people, institutions, mddiSpeeches } from '~/data/voices';
import { speechId } from '~/data/speech-transcripts';

const meta = {
  title: 'AI インフルエンスマップ — シンガポール AI キーパーソンと機関',
  description:
    'シンガポール AI 分野のキーパーソンと中核機関の公式情報チャネル、および MDDI AI 関連スピーチ全文リンク。',
};

// Category label mapping
const categoryLabels: Record<string, string> = {
  government: '政府高官',
  academic: '学者',
  industry: '業界リーダー',
};

// Category badge color classes
const categoryColors: Record<string, string> = {
  government: 'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300',
  academic: 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300',
  industry: 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300',
};

// Platform display labels
const platformLabels: Record<string, string> = {
  twitter: 'X (Twitter)',
  linkedin: 'LinkedIn',
  facebook: 'Facebook',
  website: '公式サイト',
  newsletter: 'Newsletter',
  github: 'GitHub',
  youtube: 'YouTube',
};

// Extract years from speeches for filter
const speechYears = [...new Set(mddiSpeeches.map((s) => s.date.slice(0, 4)))].sort().reverse();

// Extract unique speakers from speeches
const speechSpeakers = [...new Set(mddiSpeeches.map((s) => s.speaker).filter((s) => s !== ''))].sort();
---

<Layout metadata={meta} breadcrumbs={[{ label: 'AI インフルエンスマップ' }]}>
  <div class="max-w-7xl mx-auto px-4 py-10">
    <!-- Header -->
    <div class="mb-10">
      <h1 class="t-h1 text-gray-900 dark:text-white mb-3">AI インフルエンスマップ</h1>
      <p class="text-gray-600 dark:text-gray-400 text-lg">
        シンガポール AI 分野のキーパーソンと機関、およびその公式情報チャネル。
      </p>
      <p class="text-gray-400 dark:text-gray-500 text-sm mt-1">
        彼らの動向を追い、AI 政策・戦略の一次情報を入手できます
      </p>
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-3 gap-4 mb-10">
      <div class="bg-surface rounded-xl p-5 shadow-sm border border-subtle text-center">
        <div class="t-stat text-blue-600">{people.length}</div>
        <div class="text-sm text-gray-500 mt-1">キーパーソン</div>
      </div>
      <div class="bg-surface rounded-xl p-5 shadow-sm border border-subtle text-center">
        <div class="t-stat text-purple-600">{institutions.length}</div>
        <div class="text-sm text-gray-500 mt-1">中核機関</div>
      </div>
      <div class="bg-surface rounded-xl p-5 shadow-sm border border-subtle text-center">
        <div class="t-stat text-green-600">{mddiSpeeches.length}</div>
        <div class="text-sm text-gray-500 mt-1">MDDI スピーチ</div>
      </div>
    </div>

    <!-- People Section -->
    <section class="mb-14">
      <h2 class="t-h2 text-gray-800 dark:text-white mb-6">キーパーソン</h2>
      <div class="grid gap-5 md:grid-cols-2">
        {
          people.map((person) => (
            <div class="bg-surface rounded-xl p-6 shadow-sm border border-subtle">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <h3 class="font-bold text-gray-900 dark:text-white text-lg leading-snug">
                    <a href={`/voices/${person.id}/`} class="hover:text-blue-600 dark:hover:text-blue-400">
                      {person.name || person.nameEn}
                    </a>
                  </h3>
                  <p class="text-gray-500 dark:text-gray-400 text-sm">{person.nameEn}</p>
                </div>
                <span
                  class={`shrink-0 ml-3 text-xs font-semibold px-2.5 py-1 rounded-full ${categoryColors[person.category]}`}
                >
                  {categoryLabels[person.category]}
                </span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300 font-medium mb-1">{person.title}</p>
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 leading-relaxed">{person.summary}</p>
              <div class="flex flex-wrap gap-2">
                {person.channels.map((ch) => (
                  <a
                    href={ch.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-full border transition-all hover:shadow-sm ${
                      ch.primary
                        ? 'bg-blue-50 border-blue-300 text-blue-700 font-semibold dark:bg-blue-900/30 dark:border-blue-600 dark:text-blue-300'
                        : 'bg-gray-50 border-gray-200 text-gray-600 hover:border-gray-300 dark:bg-slate-700 dark:border-slate-600 dark:text-gray-300'
                    }`}
                  >
                    {ch.primary && <span class="inline-block w-1.5 h-1.5 rounded-full bg-blue-500 dark:bg-blue-400" />}
                    {ch.label || platformLabels[ch.platform] || ch.platform}
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Institutions Section -->
    <section class="mb-14">
      <h2 class="t-h2 text-gray-800 dark:text-white mb-6">中核機関</h2>
      <div class="grid gap-5 md:grid-cols-3">
        {
          institutions.map((inst) => (
            <div class="bg-surface rounded-xl p-6 shadow-sm border border-subtle">
              <h3 class="font-bold text-gray-900 dark:text-white text-lg mb-0.5">{inst.name}</h3>
              <p class="text-gray-500 dark:text-gray-400 text-sm mb-3">{inst.abbreviation}</p>
              <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed mb-4">{inst.role}</p>
              <div class="flex flex-wrap gap-2">
                {inst.channels.map((ch) => (
                  <a
                    href={ch.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-full border transition-all hover:shadow-sm ${
                      ch.primary
                        ? 'bg-blue-50 border-blue-300 text-blue-700 font-semibold dark:bg-blue-900/30 dark:border-blue-600 dark:text-blue-300'
                        : 'bg-gray-50 border-gray-200 text-gray-600 hover:border-gray-300 dark:bg-slate-700 dark:border-slate-600 dark:text-gray-300'
                    }`}
                  >
                    {ch.primary && <span class="inline-block w-1.5 h-1.5 rounded-full bg-blue-500 dark:bg-blue-400" />}
                    {ch.label || platformLabels[ch.platform] || ch.platform}
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- MDDI Speeches Section -->
    <section>
      <div class="flex items-center gap-3 mb-6">
        <h2 class="t-h2 text-gray-800 dark:text-white">MDDI AI 関連スピーチ</h2>
        <span class="text-sm text-gray-400">({mddiSpeeches.length})</span>
      </div>

      <!-- Filters -->
      <div class="bg-surface rounded-xl p-4 shadow-sm border border-subtle mb-6">
        <div class="mb-3">
          <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">年度</div>
          <div class="flex flex-wrap gap-2">
            <button
              data-speech-filter="year"
              data-value=""
              class="speech-filter-btn speech-filter-active px-3 py-1.5 rounded-full text-sm border transition-all cursor-pointer"
            >
              すべて
            </button>
            {
              speechYears.map((year) => {
                const count = mddiSpeeches.filter((s) => s.date.startsWith(year)).length;
                return (
                  <button
                    data-speech-filter="year"
                    data-value={year}
                    class="speech-filter-btn px-3 py-1.5 rounded-full text-sm border transition-all cursor-pointer"
                  >
                    {year}
                    <span class="text-xs opacity-60 ml-1">({count})</span>
                  </button>
                );
              })
            }
          </div>
        </div>

        <div class="mb-2">
          <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">
            スピーカー
          </div>
          <div class="flex flex-wrap gap-2">
            <button
              data-speech-filter="speaker"
              data-value=""
              class="speech-filter-btn speech-filter-active px-3 py-1.5 rounded-full text-sm border transition-all cursor-pointer"
            >
              すべて
            </button>
            {
              speechSpeakers.map((speaker) => {
                const count = mddiSpeeches.filter((s) => s.speaker === speaker).length;
                return (
                  <button
                    data-speech-filter="speaker"
                    data-value={speaker}
                    class="speech-filter-btn px-3 py-1.5 rounded-full text-sm border transition-all cursor-pointer"
                  >
                    {speaker}
                    <span class="text-xs opacity-60 ml-1">({count})</span>
                  </button>
                );
              })
            }
          </div>
        </div>

        <div class="flex items-center justify-between mt-3 pt-3 border-t border-subtle">
          <div id="speech-result-count" class="text-sm text-gray-500"></div>
          <button
            id="speech-clear-btn"
            class="hidden text-sm text-red-500 hover:text-red-700 border border-red-200 hover:border-red-400 px-3 py-1.5 rounded-lg transition-all"
          >
            フィルタをクリア
          </button>
        </div>
      </div>

      <!-- Speech List -->
      <div
        id="speech-list"
        class="bg-surface rounded-xl shadow-sm border border-subtle divide-y divide-gray-100 dark:divide-slate-700"
      >
        {
          mddiSpeeches.map((speech) => (
            <div
              class="speech-row px-5 py-4 hover:bg-gray-50 dark:hover:bg-slate-700/50 transition-colors"
              data-year={speech.date.slice(0, 4)}
              data-speaker={speech.speaker}
            >
              <div class="flex items-start gap-4">
                <div class="shrink-0 text-xs text-gray-400 dark:text-gray-500 font-mono mt-0.5 w-24">{speech.date}</div>
                <div class="flex-1 min-w-0">
                  <a
                    href={`/speeches/${speechId(speech)}/`}
                    class="text-sm font-medium text-gray-800 dark:text-gray-200 hover:text-blue-600 dark:hover:text-blue-400 transition-colors leading-snug block mb-1"
                  >
                    {speech.title}
                  </a>
                  <div class="text-xs text-gray-400 dark:text-gray-500 mb-1.5 leading-snug">{speech.title}</div>
                  <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
                    {speech.speaker && (
                      <span class="font-medium text-gray-700 dark:text-gray-300">{speech.speaker}</span>
                    )}
                    {speech.speaker && speech.speakerTitle && <span>&middot;</span>}
                    {speech.speakerTitle && <span>{speech.speakerTitle}</span>}
                    {speech.event && (
                      <>
                        <span>&middot;</span>
                        <span class="italic truncate">{speech.event}</span>
                      </>
                    )}
                  </div>
                </div>
                <a
                  href={speech.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  title="MDDI 公式サイト原文"
                  class="shrink-0 text-gray-300 dark:text-gray-600 hover:text-blue-500 dark:hover:text-blue-400 transition-colors mt-0.5"
                >
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                    />
                  </svg>
                </a>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Empty state -->
      <div id="speech-empty" class="hidden text-center py-16">
        <p class="text-gray-400 text-lg">フィルタ条件に一致するスピーチはありません</p>
        <button id="speech-clear-all-btn" class="mt-3 text-blue-600 hover:text-blue-800 text-sm underline">
          すべてのフィルタをクリア
        </button>
      </div>
    </section>
  </div>
</Layout>

<style>
  .speech-filter-btn {
    background: transparent;
    border-color: #e5e7eb;
    color: #4b5563;
  }
  :global(.dark) .speech-filter-btn {
    border-color: #475569;
    color: #9ca3af;
  }
  .speech-filter-btn:hover {
    border-color: #60a5fa;
    color: #2563eb;
  }
  .speech-filter-active {
    background: #eff6ff;
    border-color: #60a5fa;
    color: #1d4ed8;
    font-weight: 600;
  }
  :global(.dark) .speech-filter-active {
    background: rgba(59, 130, 246, 0.15);
    border-color: #3b82f6;
    color: #93c5fd;
  }
</style>

<script>
  const speechFilters: Record<string, string> = { year: '', speaker: '' };

  function initSpeeches() {
    document.querySelectorAll('.speech-filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const dim = (btn as HTMLElement).dataset.speechFilter!;
        const val = (btn as HTMLElement).dataset.value!;
        speechFilters[dim] = val;
        updateSpeechFilterButtons();
        applySpeechFilters();
      });
    });

    const clearBtn = document.getElementById('speech-clear-btn');
    if (clearBtn) clearBtn.addEventListener('click', clearAllSpeechFilters);

    const clearAllBtn = document.getElementById('speech-clear-all-btn');
    if (clearAllBtn) clearAllBtn.addEventListener('click', clearAllSpeechFilters);
  }

  function updateSpeechFilterButtons() {
    document.querySelectorAll('.speech-filter-btn').forEach((btn) => {
      const dim = (btn as HTMLElement).dataset.speechFilter!;
      const val = (btn as HTMLElement).dataset.value!;
      btn.classList.toggle('speech-filter-active', speechFilters[dim] === val);
    });
  }

  function applySpeechFilters() {
    const hasFilter = Object.values(speechFilters).some((v) => v !== '');
    let visibleCount = 0;

    document.querySelectorAll('.speech-row').forEach((row) => {
      const el = row as HTMLElement;
      const matchYear = !speechFilters.year || el.dataset.year === speechFilters.year;
      const matchSpeaker = !speechFilters.speaker || el.dataset.speaker === speechFilters.speaker;
      const visible = matchYear && matchSpeaker;
      el.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    const countEl = document.getElementById('speech-result-count');
    const clearBtn = document.getElementById('speech-clear-btn');
    const emptyState = document.getElementById('speech-empty');
    const speechList = document.getElementById('speech-list');

    if (countEl) countEl.textContent = hasFilter ? `${visibleCount} 件表示中` : '';
    if (clearBtn) clearBtn.classList.toggle('hidden', !hasFilter);
    if (emptyState && speechList) {
      emptyState.classList.toggle('hidden', visibleCount > 0);
      speechList.classList.toggle('hidden', visibleCount === 0);
    }
  }

  function clearAllSpeechFilters() {
    Object.keys(speechFilters).forEach((k) => (speechFilters[k] = ''));
    updateSpeechFilterButtons();
    applySpeechFilters();
  }

  document.addEventListener('DOMContentLoaded', initSpeeches);
  document.addEventListener('astro:page-load', initSpeeches);
</script>
