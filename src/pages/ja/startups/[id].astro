---
import type { GetStaticPaths } from 'astro';
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import EcosystemProse from '~/components/data/EcosystemProse.astro';
import { ecosystemStats } from '~/data/startups';
import {
  getStartupAiRelation,
  getStartupEntitySiblings,
  startupEntityPages,
  type StartupEntityKind,
  type StartupEntityPage,
} from '~/utils/entity-pages';

export const prerender = true;

export const getStaticPaths = (() => {
  return startupEntityPages.map((page) => ({
    params: { id: page.slug },
    props: { page },
  }));
}) satisfies GetStaticPaths;

const { page } = Astro.props as { page: StartupEntityPage };
const { startup, unicorn, exit, investor } = page;

const kindLabels: Record<StartupEntityKind, string> = {
  company: '企業 / プロジェクト',
  exit: 'イグジット / 買収事例',
  investor: '投資機関',
};

const externalUrl = page.url || null;
const externalLabel = externalUrl?.replace(/^https?:\/\/(www\.)?/, '').replace(/\/$/, '');
const raised = unicorn?.raised || startup?.raised;
const description = startup?.profile || page.description;
const relatedPages = getStartupEntitySiblings(page);
const aiRelation = getStartupAiRelation(page);

function overviewText(entity: StartupEntityPage): string {
  if (entity.startup?.profile) return entity.startup.profile;
  if (entity.investor) {
    return `${entity.name} はシンガポール AI スタートアップエコシステムにおける${entity.investor.type}です。こうした機関は、初期段階の企業が忍耐資本、産業コネクション、越境展開リソースを獲得できるかを左右します。`;
  }
  if (entity.exit) {
    return `${entity.name} はシンガポール AI スタートアップエコシステムにおけるイグジット・M&A 事例です。その価値は取引そのものだけでなく、国内 AI プロジェクトがグローバルプラットフォーム、産業バイヤー、規制体系によって再評価され得るかを示す点にあります。`;
  }
  return `${entity.name} はシンガポール AI スタートアップエコシステムにおいて「${entity.category}」寄りの企業 / プロジェクトです。現在の公開ポジショニングは：${entity.description}。`;
}

function relevanceText(entity: StartupEntityPage): string {
  if (entity.investor) {
    return `${entity.name} は資本供給層に位置しています。その投資リズムを観察すれば、シンガポール AI エコシステムがインフラ・ディープテック寄りか、アプリケーション層・東南アジア市場展開寄りかが見えてきます。`;
  }
  if (entity.exit) {
    return `${entity.name} がシンガポールにとって重要なのは「イグジットパス」です。エコシステムが起業家を持続的に引き付けられるかは、企業数だけでなく、上場・M&A・越境統合といった実現可能な出口があるかにもかかっています。`;
  }
  return `${entity.name} が属する「${entity.category}」分野は、シンガポールの AI スタートアップが政策・人材・研究投入から実際の商業企業へ転換できるかを判断する具体的な観測ポイントです。`;
}

const signalItems = [
  unicorn &&
    `ユニコーン / 上場規模：資金調達 ${unicorn.raised}、評価額 ${unicorn.valuation}、ステータス「${unicorn.status}」。`,
  raised && `公開資金調達シグナル：${raised}。`,
  startup?.investors && `公開関連投資家：${startup.investors}。`,
  startup?.highlight && `現在のタグ：${startup.highlight}。`,
  exit && `イグジットイベント：買収者 / 取引相手 ${exit.acquirer}、金額 ${exit.amount}、年度 ${exit.year || '未定'}。`,
  investor && `投資実績：${investor.stats}；重点分野：${investor.focus}。`,
].filter((item): item is string => Boolean(item));

const trackingItems =
  page.kind === 'investor'
    ? [
        'AI 投資がインフラ、モデル、バーティカルアプリケーションに集中しているか、東南アジアプラットフォーム型企業寄りか。',
        '初期投資から M&A、IPO への連続的なイグジットパスが出現しているか。',
      ]
    : page.kind === 'exit'
      ? [
          '取引が実際に完了しているか、規制・データ・技術主権の要因が越境 M&A パスを変えているか。',
          '買収者が重視しているのはプロダクト、チーム、顧客か、それともシンガポールの地域本部としての構造的位置か。',
        ]
      : [
          'プロダクトが単一の AI 機能から反復可能なプラットフォームまたは業界ワークフローへ移行しているか。',
          '顧客が主にシンガポール国内、東南アジア地域、それともグローバル市場に分布しているか。',
          '資金調達、収益、オープンソース影響力、規制許可などのシグナルが引き続き強化されているか。',
        ];

const facts = [
  { label: 'タイプ', value: kindLabels[page.kind] },
  { label: '分野 / グループ', value: page.category },
  { label: 'AI 関連度', value: aiRelation.label },
  raised && { label: '公開資金調達', value: raised },
  unicorn?.valuation && { label: '評価額', value: unicorn.valuation },
  unicorn?.status && { label: 'ステータス', value: unicorn.status },
  startup?.investors && { label: '投資家', value: startup.investors },
  exit && { label: '買収者', value: exit.acquirer },
  exit && { label: '金額 / 年度', value: `${exit.amount} · ${exit.year || '未定'}` },
  investor && { label: '投資実績', value: investor.stats },
  investor && { label: '重点分野', value: investor.focus },
  externalUrl && { label: '公式サイト', value: externalLabel || externalUrl, href: externalUrl },
].filter((fact): fact is { label: string; value: string; href?: string } => Boolean(fact));

const metadata = {
  title: `${page.name} · AI スタートアップエコシステム`,
  description: `${page.name}：${page.description}`,
};

const canonicalUrl = `https://sgai.md/startups/${page.slug}/`;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: page.name,
  description: metadata.description,
  url: externalUrl || canonicalUrl,
  sameAs: externalUrl ? [externalUrl] : undefined,
  mainEntityOfPage: canonicalUrl,
  isPartOf: {
    '@type': 'WebSite',
    name: 'シンガポール AI 観測',
    url: 'https://sgai.md/',
  },
};
---

<Layout
  metadata={metadata}
  breadcrumbs={[{ label: 'AI スタートアップエコシステム', href: '/startups/' }, { label: page.name }]}
>
  <JsonLd schema={schema} />
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-10 md:py-12">
    <div class="mb-6 flex flex-wrap items-center gap-2 text-xs">
      <a
        href="/startups/"
        class="inline-flex items-center gap-1 bg-primary/10 text-primary px-3 py-1.5 rounded-full font-semibold hover:bg-primary/15 transition-colors"
      >
        <span>{page.icon}</span>
        <span>{page.category}</span>
      </a>
      <span class="bg-gray-100 dark:bg-slate-800 text-gray-700 dark:text-gray-300 px-3 py-1.5 rounded-full">
        {kindLabels[page.kind]}
      </span>
      <span class="bg-gray-100 dark:bg-slate-800 text-gray-700 dark:text-gray-300 px-3 py-1.5 rounded-full">
        {aiRelation.label}
      </span>
      {
        unicorn && (
          <span class="bg-gray-100 dark:bg-slate-800 text-gray-700 dark:text-gray-300 px-3 py-1.5 rounded-full">
            ユニコーン
          </span>
        )
      }
    </div>

    <h1 class="t-display text-gray-900 dark:text-white mb-3">{page.name}</h1>
    <p class="font-serif text-lg leading-[1.85] text-gray-800 dark:text-gray-200 mb-8 border-l-4 border-primary pl-5">
      {description}
    </p>

    <dl
      class="bg-surface rounded-lg border border-subtle p-5 mb-10 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4 text-sm"
    >
      {
        facts.map((fact) => (
          <div>
            <dt class="text-xs uppercase tracking-wider text-muted mb-1">{fact.label}</dt>
            <dd class="text-gray-900 dark:text-white">
              {fact.href ? (
                <a
                  href={fact.href}
                  target="_blank"
                  rel="noopener"
                  class="text-primary hover:underline inline-flex items-center gap-1"
                >
                  {fact.value}
                  <Icon name="tabler:external-link" class="w-3.5 h-3.5" />
                </a>
              ) : (
                fact.value
              )}
            </dd>
          </div>
        ))
      }
    </dl>

    <section class="mb-10">
      <h2 class="t-h3 text-gray-900 dark:text-white mb-4">ポジショニング</h2>
      <EcosystemProse content={overviewText(page)} />
    </section>

    <section class="mb-10">
      <h2 class="t-h3 text-gray-900 dark:text-white mb-4">資本・市場シグナル</h2>
      {
        signalItems.length > 0 ? (
          <ul class="list-disc list-outside pl-6 space-y-2 text-gray-800 dark:text-gray-200 leading-relaxed">
            {signalItems.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        ) : (
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">公開資本シグナルは未整備です。</p>
        )
      }
    </section>

    <section class="mb-10">
      <h2 class="t-h3 text-gray-900 dark:text-white mb-4">AI 関連度の判断</h2>
      <EcosystemProse content={aiRelation.description} />
    </section>

    <section class="mb-10">
      <h2 class="t-h3 text-gray-900 dark:text-white mb-4">なぜ注目に値するか</h2>
      <EcosystemProse content={relevanceText(page)} />
    </section>

    <section class="mb-10">
      <h2 class="t-h3 text-gray-900 dark:text-white mb-4">追跡ポイント</h2>
      <ul class="list-disc list-outside pl-6 space-y-2 text-gray-800 dark:text-gray-200 leading-relaxed">
        {trackingItems.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    {
      exit?.note && (
        <section class="mb-10 callout-note">
          <h2 class="font-semibold text-gray-900 dark:text-white mb-2">備考</h2>
          <p class="leading-relaxed text-gray-800 dark:text-gray-200">{exit.note}</p>
        </section>
      )
    }

    {
      relatedPages.length > 0 && (
        <section class="mb-10 pt-6 border-t border-subtle">
          <h2 class="text-sm uppercase tracking-wider text-muted font-semibold mb-3">関連エンティティ</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {relatedPages.map((related) => (
              <a
                href={`/startups/${related.slug}/`}
                class="group bg-surface rounded-lg p-4 border border-subtle hover:border-primary transition-colors"
              >
                <div class="text-xs text-muted mb-1">{related.category}</div>
                <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-primary transition-colors">
                  {related.name}
                </h3>
                <p class="text-xs text-gray-600 dark:text-gray-400 mt-1 line-clamp-2">{related.description}</p>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <section class="mb-10 pt-6 border-t border-subtle">
      <h2 class="text-sm uppercase tracking-wider text-muted font-semibold mb-3">データ説明</h2>
      <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">
        本ページはスタートアップエコシステムのエンティティ档案です。プロフィール整理と AI 関連度の基準は {
          ecosystemStats.profileUpdated
        } 時点で校正済み。基礎統計（650+、資金調達比率、総資金調達額等）は {ecosystemStats.dataDate} 時点の公開基準を使用しています。資金調達額、評価額、イグジット金額等はすべて公開報道または公開資料に基づいており、同一企業でもデータベースにより数値が異なる場合があります。
      </p>
    </section>

    <nav class="mt-12 pt-6 border-t border-subtle">
      <a href="/startups/" class="text-sm text-primary hover:text-secondary font-medium inline-flex items-center gap-1">
        <Icon name="tabler:arrow-left" class="w-4 h-4" />
        AI スタートアップエコシステムに戻る
      </a>
    </nav>
  </article>
</Layout>
