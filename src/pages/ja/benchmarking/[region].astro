---
import type { GetStaticPaths } from 'astro';

import CaseProfile from '~/components/benchmarking/CaseProfile.astro';
import DrilldownProfile from '~/components/benchmarking/DrilldownProfile.astro';
import RegionProfile from '~/components/benchmarking/RegionProfile.astro';
import { benchmarkPages, type BenchmarkPage } from '~/utils/entity-pages';

export const prerender = true;

export const getStaticPaths = (() =>
  benchmarkPages.map((page) => ({ params: { region: page.slug }, props: { page } }))) satisfies GetStaticPaths;

const { page } = Astro.props as { page: BenchmarkPage };
---

{page.kind === 'drilldown' && <DrilldownProfile page={page} lang="ja" />}
{page.kind === 'case' && <CaseProfile page={page} lang="ja" />}
{page.kind === 'region' && <RegionProfile page={page} lang="ja" />}
