---
// About page (en) — thin wrapper. Body lives in `src/components/about/AboutPage.astro`.

import Layout from '~/layouts/PageLayout.astro';
import AboutPage from '~/components/about/AboutPage.astro';
import { t } from '~/i18n';

const lang = 'en' as const;

const metadata = {
  title: t(lang, 'aboutPageTitle'),
  description: t(lang, 'aboutPageDesc'),
};
---

<Layout metadata={metadata} breadcrumbs={[{ label: t(lang, 'aboutPageTitle') }]} lang={lang}>
  <AboutPage lang={lang} />
</Layout>
