---
import Layout from '~/layouts/PageLayout.astro';
import {
  debates,
  DEBATE_STATS,
  POLICY_EVOLUTION,
  RECURRING_CONTROVERSIES,
  MP_PROFILES,
  KEY_INSIGHTS,
  POLICY_SIGNALS,
  TENSION_MAP,
} from '~/data/debates';
import { findPersonId, getPerson } from '~/utils/people';

const meta = {
  title: '国会 AI 焦点 — 新加坡议会辩论记录',
  description: '新加坡议会关于 AI 的第一手辩论记录，含 AI 提炼的中文摘要、议员立场分析、政策演变脉络与深度洞察。',
};

const typeMap: Record<string, string> = {
  'Oral Answers to Questions': '口头答复',
  'Written Answers to Questions': '书面答复',
  Budget: '预算辩论',
  Motion: '动议',
};

const controversyLabels: Record<number, string> = {
  1: '信息发布',
  2: '温和质询',
  3: '实质辩论',
  4: '激烈争议',
  5: '高度对立',
};

// Two-tone severity system: low = neutral, high (4+) = primary-tinted accent.
// Keeps vermillion as the single signature color and avoids pastel confetti.
const controversyColors: Record<number, string> = {
  1: 'bg-surface text-muted border border-subtle',
  2: 'bg-surface text-muted border border-subtle',
  3: 'bg-surface text-default border border-subtle',
  4: 'bg-primary/10 text-primary border border-primary/30',
  5: 'bg-primary/15 text-primary border border-primary/40 font-semibold',
};

const statusColors: Record<string, string> = {
  ongoing: 'bg-surface text-muted border border-subtle',
  escalating: 'bg-primary/10 text-primary border border-primary/30',
  resolved: 'bg-surface text-default border border-subtle',
};

const statusLabels: Record<string, string> = {
  ongoing: '持续讨论中',
  escalating: '争议升级',
  resolved: '已有定论',
};

const significanceColors: Record<string, string> = {
  high: 'border-l-primary',
  medium: 'border-l-subtle',
  low: 'border-l-subtle',
};

const topicZh: Record<string, string> = {
  'AI Economy & Industry': 'AI 经济与产业',
  'AI & Employment': 'AI 与就业',
  'AI Governance & Regulation': 'AI 治理与监管',
  'AI & National Security': 'AI 与国家安全',
  'AI in Public Sector': 'AI 与公共部门',
  'AI Infrastructure & Research': 'AI 基础设施与研究',
  'AI Safety & Ethics': 'AI 安全与伦理',
  'AI in Education': 'AI 与教育',
  'AI in Healthcare': 'AI 与医疗',
  'AI Strategy': 'AI 战略',
  'Deepfakes & Disinformation': '深度伪造与虚假信息',
  'Generative AI': '生成式 AI',
};

const maxCount = Math.max(...Object.values(DEBATE_STATS.byYear));

// Compute real debate counts per controversy topic (build-time)
const controversyDebateCounts = RECURRING_CONTROVERSIES.map((c) => {
  const relTopics = (c as { relatedTopics: string[] }).relatedTopics || [];
  return debates.filter((d) => relTopics.some((t) => d.topics.includes(t))).length;
});

// Build-time: compute speakers with 3+ appearances, sorted by frequency
const speakerCounts = new Map<string, number>();
for (const d of debates) {
  for (const s of d.speakers) {
    if (s && s.length > 1) {
      speakerCounts.set(s, (speakerCounts.get(s) || 0) + 1);
    }
  }
}
const frequentSpeakers = [...speakerCounts.entries()]
  .filter(([, count]) => count >= 3)
  .sort((a, b) => b[1] - a[1])
  .map(([name, count]) => ({ name, count }));

// Phase 0: debatesJson removed. Debate cards are now SSG-rendered to HTML
// with data-* attributes carrying filter metadata. The client script
// queries [data-debate-card] and toggles visibility — no JSON parse,
// no innerHTML rebuild on filter, no ~302 KB inline payload.

// Safely encode a string for use inside a single-quoted JS string literal
// in an inline onclick attribute. Escapes backslashes and single quotes.
const jsAttr = (s: string) => String(s).replace(/\\/g, '\\\\').replace(/'/g, "\\'");

// Build a lowercased search blob per debate (title, zhTitle, summary, speakers, key points).
const searchBlob = (d: (typeof debates)[number]) =>
  [d.title, d.zhTitle, d.zhSummary, ...(d.speakers || []), ...(d.keyPoints || [])].join(' ').toLowerCase();
---

<Layout metadata={meta} breadcrumbs={[{ label: '国会 AI 焦点' }]}>
  <div class="max-w-7xl mx-auto px-4 py-10">
    <!-- Update Banner -->
    <div
      class="mb-6 flex flex-wrap items-center justify-between gap-3 rounded-lg bg-blue-50 dark:bg-slate-800 border border-blue-200 dark:border-slate-600 px-5 py-3"
    >
      <div class="flex items-center gap-4 text-sm">
        <span class="font-semibold text-blue-800 dark:text-blue-300">数据更新：2026-03-24</span>
        <span class="text-gray-500 dark:text-gray-400">共 {DEBATE_STATS.total} 条辩论记录</span>
      </div>
      <div class="flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
        <span
          >来源：<a href="https://sprs.parl.gov.sg/search/" target="_blank" class="text-blue-600 hover:underline"
            >SPRS Hansard</a
          > · <a href="https://search.pair.gov.sg/" target="_blank" class="text-blue-600 hover:underline">PAIR Search</a
          ></span
        >
        <span class="text-gray-300 dark:text-gray-600">|</span>
        <span>中文摘要由 AI 辅助生成</span>
      </div>
    </div>

    <!-- Header -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-4xl">🏛️</span>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">国会 AI 焦点</h1>
      </div>
      <p class="text-gray-600 dark:text-gray-400 text-lg max-w-3xl">
        新加坡议会关于人工智能的第一手辩论记录，含 AI 提炼的中文摘要、议员立场分析与政策规律洞察。
        <strong class="text-blue-600 dark:text-blue-400"
          >点击任意议员、议题、年份或争议焦点，即可直接筛选相关辩论。</strong
        >
      </p>
    </div>

    <!-- Stats Row — clickable by type -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
      <div class="bg-surface rounded-xl p-5 shadow-sm border border-subtle text-center">
        <div class="text-3xl font-bold text-blue-600">{DEBATE_STATS.total}</div>
        <div class="text-sm text-gray-500 mt-1">辩论记录总数</div>
      </div>
      {
        Object.entries(DEBATE_STATS.byType).map(([type, count]) => (
          <button
            onclick={`filterBy('type','${type}')`}
            class="bg-surface rounded-xl p-5 shadow-sm border border-subtle text-center hover:border-blue-400 hover:shadow-md transition-all cursor-pointer group"
            title={`点击查看所有${typeMap[type] || type}`}
          >
            <div class="text-2xl font-bold text-purple-600 group-hover:text-blue-600 transition-colors">{count}</div>
            <div class="text-xs text-gray-500 mt-1">{typeMap[type] || type}</div>
            <div class="text-xs text-blue-400 opacity-0 group-hover:opacity-100 transition-opacity mt-0.5">
              点击筛选 →
            </div>
          </button>
        ))
      }
    </div>

    <!-- ===== YEAR TREND — clickable bars ===== -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-2 flex items-center gap-2">
        <span>📅</span> 历年辩论趋势
      </h2>
      <p class="text-sm text-gray-400 mb-5">点击任意年份柱状图，查看该年所有辩论</p>
      <div class="bg-surface rounded-xl p-6 shadow-sm border border-subtle">
        <div class="flex items-end gap-2 h-40">
          {
            Object.entries(DEBATE_STATS.byYear)
              .sort()
              .map(([year, count]) => (
                <button
                  onclick={`filterBy('year','${year}')`}
                  class="flex-1 flex flex-col items-center gap-1 group"
                  title={`${year}年：${count} 条辩论，点击查看`}
                >
                  <span class="text-xs text-gray-500 font-medium group-hover:text-blue-600 transition-colors">
                    {count}
                  </span>
                  <div
                    class="w-full bg-gradient-to-t from-blue-500 to-purple-400 rounded-t-sm transition-all group-hover:from-blue-600 group-hover:to-purple-500 group-hover:scale-105 origin-bottom"
                    style={`height: ${Math.round((count / maxCount) * 120)}px; min-height: 4px;`}
                  />
                  <span class="text-xs text-gray-400 group-hover:text-blue-600 transition-colors">{year.slice(2)}</span>
                </button>
              ))
          }
        </div>
        <p class="text-xs text-gray-400 mt-3 text-center">
          2023 年起 AI 相关辩论数量急剧增加，反映政策关注度的爆发式增长
        </p>
      </div>
    </section>

    <!-- ===== INSIGHTS SECTION ===== -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-5 flex items-center gap-2">
        <span>💡</span> 核心洞察
        <span class="text-sm font-normal text-gray-400 ml-2">从 {DEBATE_STATS.total} 条辩论中提炼</span>
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          KEY_INSIGHTS.map((ins) => (
            <div
              class={`bg-surface rounded-xl p-5 shadow-sm border-l-4 ${significanceColors[ins.significance]} border border-subtle`}
            >
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-semibold text-gray-800 dark:text-white text-sm">{ins.title}</h3>
                {ins.significance === 'high' && (
                  <span class="text-xs bg-red-100 text-red-600 px-2 py-0.5 rounded-full ml-2 shrink-0">重要</span>
                )}
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{ins.description}</p>
              <p class="text-xs text-gray-400 mt-2 italic">{ins.evidence}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ===== POLICY EVOLUTION — clickable periods ===== -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-2 flex items-center gap-2">
        <span>📈</span> 政策演变脉络
      </h2>
      <p class="text-sm text-gray-400 mb-5">点击任意时期，查看该阶段的所有辩论记录</p>
      <div class="relative">
        <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-gradient-to-b from-blue-300 to-purple-300 hidden md:block">
        </div>
        <div class="space-y-4">
          {
            POLICY_EVOLUTION.map((period, i) => (
              <div class="md:pl-16 relative">
                <div class="hidden md:flex absolute left-0 top-3 w-12 h-12 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 items-center justify-center text-white font-bold text-sm shadow-md">
                  {i + 1}
                </div>
                <button
                  onclick={`filterBy('yearRange','${period.years}')`}
                  class="w-full text-left bg-surface rounded-xl p-5 shadow-sm border border-subtle hover:border-blue-400 hover:shadow-md transition-all group"
                >
                  <div class="flex flex-wrap items-center gap-3 mb-2">
                    <span class="text-xs bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300 px-2 py-1 rounded-full font-mono">
                      {period.years}
                    </span>
                    <h3 class="font-bold text-gray-800 dark:text-white">{period.period}</h3>
                    <span class="text-xs text-blue-500 opacity-0 group-hover:opacity-100 transition-opacity ml-auto">
                      查看该时期辩论 →
                    </span>
                  </div>
                  <p class="text-sm font-medium text-blue-700 dark:text-blue-400 mb-2">{period.theme}</p>
                  <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{period.description}</p>
                  {period.keyDebates.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {period.keyDebates.map((kd) => (
                        <span class="text-xs bg-gray-100 dark:bg-slate-700 text-gray-600 dark:text-gray-400 px-2 py-1 rounded">
                          📌 {kd}
                        </span>
                      ))}
                    </div>
                  )}
                </button>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===== RECURRING CONTROVERSIES — clickable ===== -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-2 flex items-center gap-2">
        <span>⚡</span> 反复争议焦点
      </h2>
      <p class="text-sm text-gray-400 mb-5">这些问题在多届国会中持续被提出。点击任意焦点，查看相关辩论记录</p>
      <div class="grid md:grid-cols-2 gap-4">
        {
          RECURRING_CONTROVERSIES.map((c) => (
            <button
              onclick={`filterBy('topics','${(c as { relatedTopics: string[] }).relatedTopics.join(',')}')`}
              class="text-left bg-surface rounded-xl p-5 shadow-sm border border-subtle hover:border-orange-400 hover:shadow-md transition-all group"
            >
              <div class="flex items-start justify-between mb-3">
                <div>
                  <h3 class="font-bold text-gray-800 dark:text-white group-hover:text-orange-600 transition-colors">
                    {c.issue}
                  </h3>
                  <p class="text-sm text-gray-500 mt-1">{c.description}</p>
                </div>
                <div class="flex flex-col items-end gap-1 ml-3 shrink-0">
                  <span class="text-xs bg-gray-100 dark:bg-slate-700 text-gray-600 dark:text-gray-400 px-2 py-1 rounded-full">
                    相关 {controversyDebateCounts[RECURRING_CONTROVERSIES.indexOf(c)]} 条
                  </span>
                  <span
                    class={`text-xs px-2 py-1 rounded-full ${statusColors[c.resolutionStatus] || 'bg-gray-100 text-gray-600'}`}
                  >
                    {statusLabels[c.resolutionStatus] || c.resolutionStatus}
                  </span>
                </div>
              </div>
              <div class="grid grid-cols-2 gap-3 mt-3">
                <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-3">
                  <div class="text-xs font-semibold text-blue-600 dark:text-blue-400 mb-1">🏛️ 政府立场</div>
                  <div class="text-xs text-gray-700 dark:text-gray-300">{c.governmentPosition}</div>
                </div>
                <div class="bg-orange-50 dark:bg-orange-900/20 rounded-lg p-3">
                  <div class="text-xs font-semibold text-orange-600 dark:text-orange-400 mb-1">❓ 质询立场</div>
                  <div class="text-xs text-gray-700 dark:text-gray-300">{c.oppositionPosition}</div>
                </div>
              </div>
              <div class="mt-3 text-xs text-orange-500 opacity-0 group-hover:opacity-100 transition-opacity">
                点击查看 {controversyDebateCounts[RECURRING_CONTROVERSIES.indexOf(c)]} 条相关辩论 →
              </div>
            </button>
          ))
        }
      </div>
    </section>

    <!-- ===== TENSION MAP ===== -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-5 flex items-center gap-2">
        <span>⚖️</span> 核心政策张力
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          TENSION_MAP.map((t) => (
            <div class="bg-surface rounded-xl p-5 shadow-sm border border-subtle">
              <h3 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3">
                {t.dimension}
              </h3>
              <div class="flex items-center gap-2 mb-3">
                <div class="flex-1 bg-blue-50 dark:bg-blue-900/20 rounded-lg p-2 text-xs text-blue-700 dark:text-blue-300 text-center">
                  {t.sideA}
                </div>
                <div class="text-gray-400 font-bold text-sm">vs</div>
                <div class="flex-1 bg-orange-50 dark:bg-orange-900/20 rounded-lg p-2 text-xs text-orange-700 dark:text-orange-300 text-center">
                  {t.sideB}
                </div>
              </div>
              <div class="text-xs text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-slate-700 rounded p-2">
                <span class="font-medium">当前平衡：</span>
                {t.currentBalance}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ===== MP PROFILES — clickable ===== -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-2 flex items-center gap-2">
        <span>🎙️</span> 关键议员档案
      </h2>
      <p class="text-sm text-gray-400 mb-5">点击任意议员卡片，查看该议员参与的所有辩论</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        {
          MP_PROFILES.map((mp) => (
            <button
              onclick={`filterBy('speaker','${mp.name.replace(/'/g, "\\'")}')`}
              class="text-left bg-surface rounded-xl p-4 shadow-sm border border-subtle hover:border-purple-400 hover:shadow-md transition-all group cursor-pointer"
            >
              <div class="flex items-start justify-between mb-2">
                <div>
                  <div class="font-semibold text-gray-800 dark:text-white text-sm group-hover:text-purple-600 transition-colors">
                    {mp.name}
                  </div>
                  {mp.zhName && <div class="text-xs text-gray-500">{mp.zhName}</div>}
                </div>
                <span
                  class={`text-xs px-2 py-0.5 rounded-full shrink-0 ml-1 ${mp.role === '反对党' ? 'bg-orange-100 text-orange-700' : 'bg-blue-100 text-blue-700'}`}
                >
                  {mp.role}
                </span>
              </div>
              <div class="text-xs text-gray-500 mb-2">
                发言 <span class="font-bold text-gray-700 dark:text-gray-300">{mp.debateCount}</span> 次
              </div>
              <div class="flex flex-wrap gap-1 mb-2">
                {mp.focusAreas.slice(0, 3).map((area) => (
                  <span class="text-xs bg-gray-100 dark:bg-slate-700 text-gray-600 dark:text-gray-400 px-1.5 py-0.5 rounded">
                    {area}
                  </span>
                ))}
              </div>
              <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">{mp.notablePosition}</p>
              <div class="mt-2 text-xs text-purple-500 opacity-0 group-hover:opacity-100 transition-opacity">
                查看 {mp.debateCount} 条相关辩论 →
              </div>
            </button>
          ))
        }
      </div>
    </section>

    <!-- ===== POLICY SIGNALS — clickable ===== -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-2 flex items-center gap-2">
        <span>📡</span> 政策信号追踪
      </h2>
      <p class="text-sm text-gray-400 mb-5">点击任意信号，查看该政策信号首次出现的相关辩论</p>
      <div class="grid md:grid-cols-2 gap-3">
        {
          POLICY_SIGNALS.map((sig) => (
            <button
              onclick={`filterBy('year','${sig.year}')`}
              class="text-left bg-surface rounded-xl p-4 shadow-sm border border-subtle hover:border-green-400 hover:shadow-md transition-all group flex items-start gap-3"
            >
              <div class="shrink-0 mt-0.5">
                {sig.status === '已落实' && <span class="text-green-500 text-lg">✅</span>}
                {sig.status === '进行中' && <span class="text-blue-500 text-lg">🔄</span>}
                {sig.status === '仍在讨论' && <span class="text-amber-500 text-lg">💬</span>}
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="font-semibold text-sm text-gray-800 dark:text-white group-hover:text-green-600 transition-colors">
                    {sig.signal}
                  </span>
                  <span class="text-xs text-gray-400">首见 {sig.year}</span>
                  <span
                    class={`text-xs px-2 py-0.5 rounded-full ${sig.status === '已落实' ? 'bg-green-100 text-green-700' : sig.status === '进行中' ? 'bg-blue-100 text-blue-700' : 'bg-amber-100 text-amber-700'}`}
                  >
                    {sig.status}
                  </span>
                </div>
                <p class="text-xs text-gray-500 mt-1">{sig.context}</p>
                <div class="mt-1 text-xs text-green-500 opacity-0 group-hover:opacity-100 transition-opacity">
                  查看 {sig.year} 年辩论 →
                </div>
              </div>
            </button>
          ))
        }
      </div>
    </section>

    <!-- ===== TOPIC QUICK FILTER ===== -->
    <section class="mb-8">
      <h2 class="text-xl font-bold text-gray-800 dark:text-white mb-2 flex items-center gap-2">
        <span>🏷️</span> 按议题快速筛选
      </h2>
      <p class="text-sm text-gray-400 mb-4">点击议题标签，直接查看相关辩论</p>
      <div class="flex flex-wrap gap-2">
        {
          Object.entries(topicZh).map(([en, zh]) => {
            const count = debates.filter((d) => (d.topics || []).includes(en)).length;
            return (
              <button
                onclick={`filterBy('topic','${en}')`}
                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 border border-indigo-100 dark:border-indigo-800 hover:bg-indigo-100 dark:hover:bg-indigo-900/60 hover:border-indigo-400 transition-all cursor-pointer"
              >
                {zh}
                <span class="text-xs bg-indigo-200 dark:bg-indigo-800 text-indigo-700 dark:text-indigo-300 px-1.5 py-0.5 rounded-full">
                  {count}
                </span>
              </button>
            );
          })
        }
      </div>
    </section>

    <!-- ===== DEBATE LIST ===== -->
    <section id="debate-section">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-bold text-gray-800 dark:text-white flex items-center gap-2">
          <span>📜</span> 辩论记录全览
          <span class="text-sm font-normal text-gray-400 ml-2">含中文摘要与议员立场</span>
        </h2>
        <button
          id="clear-filters-btn"
          onclick="clearFilters()"
          class="hidden text-sm text-red-500 hover:text-red-700 border border-red-200 hover:border-red-400 px-3 py-1.5 rounded-lg transition-all"
        >
          ✕ 清除筛选
        </button>
      </div>

      <!-- Active filter indicator -->
      <div
        id="active-filter-bar"
        class="hidden mb-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl px-4 py-3 flex items-center gap-3"
      >
        <span class="text-sm text-blue-700 dark:text-blue-300 font-medium">🔍 当前筛选：</span>
        <span id="active-filter-label" class="text-sm text-blue-600 dark:text-blue-400"></span>
      </div>

      <!-- Filters: collapsible drawer on mobile, always-open on md+. -->
      <details
        class="md:open:opacity-100 md:[&>summary]:hidden bg-surface rounded-xl p-4 shadow-sm border border-subtle mb-5"
        open
      >
        <summary
          class="md:hidden cursor-pointer flex items-center gap-2 text-sm font-semibold text-gray-700 dark:text-gray-200 select-none"
        >
          <span>筛选条件</span>
          <span class="text-xs text-gray-400 font-normal">（点击展开）</span>
        </summary>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-3 mt-3 md:mt-0">
          <input
            id="search-input"
            type="text"
            placeholder="搜索标题、摘要、议员..."
            class="border border-gray-200 dark:border-slate-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-slate-700 text-gray-800 dark:text-gray-200 col-span-1 md:col-span-2"
          />
          <select
            id="type-filter"
            class="border border-gray-200 dark:border-slate-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-slate-700 text-gray-800 dark:text-gray-200"
          >
            <option value="">所有类型</option>
            <option value="Oral Answers to Questions">口头答复</option>
            <option value="Written Answers to Questions">书面答复</option>
            <option value="Budget">预算辩论</option>
            <option value="Motions">动议</option>
          </select>
          <select
            id="topic-filter"
            class="border border-gray-200 dark:border-slate-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-slate-700 text-gray-800 dark:text-gray-200"
          >
            <option value="">所有议题</option>
            {Object.entries(topicZh).map(([en, zh]) => <option value={en}>{zh}</option>)}
          </select>
        </div>
        <div class="flex gap-3 mt-3 flex-wrap">
          <select
            id="speaker-filter"
            class="border border-gray-200 dark:border-slate-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-slate-700 text-gray-800 dark:text-gray-200"
          >
            <option value="">所有议员</option>
            {
              frequentSpeakers.map((sp) => (
                <option value={sp.name}>
                  {sp.name}（{sp.count}）
                </option>
              ))
            }
          </select>
          <select
            id="year-filter"
            class="border border-gray-200 dark:border-slate-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-slate-700 text-gray-800 dark:text-gray-200"
          >
            <option value="">所有年份</option>
            {
              Object.keys(DEBATE_STATS.byYear)
                .sort()
                .reverse()
                .map((year) => <option value={year}>{year}</option>)
            }
          </select>
          <select
            id="controversy-filter"
            class="border border-gray-200 dark:border-slate-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-slate-700 text-gray-800 dark:text-gray-200"
          >
            <option value="">所有争议度</option>
            <option value="4">高争议（4-5级）</option>
            <option value="3">中等（3级）</option>
            <option value="1">低争议（1-2级）</option>
          </select>
          <div id="result-count" class="text-sm text-gray-500 self-center ml-auto"></div>
        </div>
      </details>

      <!-- Debate Cards (SSG-rendered) -->
      <div id="debate-list" class="space-y-4">
        {
          debates.map((d) => {
            const cLevel = d.controversyLevel || 1;
            const cLabel = controversyLabels[cLevel] || '未知';
            const cColor = controversyColors[cLevel] || 'bg-gray-100 text-gray-600';
            const yearStr = d.date.slice(0, 4);
            return (
              <article
                data-debate-card
                data-type={d.type}
                data-year={yearStr}
                data-controversy={cLevel}
                data-topics={(d.topics || []).join('|')}
                data-speakers={(d.speakers || []).join('|')}
                data-search={searchBlob(d)}
                class="bg-surface rounded-xl shadow-sm border border-subtle overflow-hidden"
              >
                <div class="p-5">
                  {/* Header row */}
                  <div class="flex flex-wrap items-start gap-2 mb-3">
                    <button
                      type="button"
                      onclick={`filterBy('type','${jsAttr(d.type)}')`}
                      class="text-xs bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-400 px-2 py-1 rounded hover:bg-slate-200 transition-colors"
                    >
                      {typeMap[d.type] || d.type}
                    </button>
                    <button
                      type="button"
                      onclick={`filterBy('year','${yearStr}')`}
                      class="text-xs text-gray-400 hover:text-blue-600 hover:underline transition-colors"
                    >
                      {d.date}
                    </button>
                    <span class="text-xs text-gray-400">第 {d.parliament} 届国会</span>
                    <span class={`text-xs ${cColor} px-2 py-0.5 rounded-full ml-auto`}>{cLabel}</span>
                  </div>

                  {/* Title (bilingual) */}
                  <h3 class="font-bold text-gray-800 dark:text-white text-base mb-1">
                    <a href={`/debates/${d.id}/`} class="hover:text-primary transition-colors">
                      {d.zhTitle}
                    </a>
                  </h3>
                  <p class="text-xs text-gray-400 mb-3 italic">
                    {d.title.length > 100 ? `${d.title.slice(0, 100)}...` : d.title}
                  </p>

                  {/* Topics */}
                  {d.topics && d.topics.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mb-3">
                      {d.topics.map((t) => (
                        <button
                          type="button"
                          onclick={`event.stopPropagation(); filterBy('topic','${jsAttr(t)}')`}
                          class="text-xs bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 px-2 py-0.5 rounded-full hover:bg-indigo-100 transition-colors"
                        >
                          {topicZh[t] || t}
                        </button>
                      ))}
                    </div>
                  )}

                  {/* Chinese Summary */}
                  <div class="bg-gray-50 dark:bg-slate-700/50 rounded-lg p-3 mb-3">
                    <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1">📝 摘要</div>
                    <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">{d.zhSummary}</p>
                  </div>

                  {/* Key Points */}
                  {d.keyPoints && d.keyPoints.length > 0 && (
                    <ul class="mb-3 space-y-0.5">
                      {d.keyPoints.slice(0, 3).map((kp) => (
                        <li class="text-xs text-gray-600 dark:text-gray-400">• {kp}</li>
                      ))}
                    </ul>
                  )}

                  {/* Stances */}
                  {(d.governmentStance || d.oppositionStance) && (
                    <div class="grid grid-cols-2 gap-2 mb-3">
                      {d.governmentStance && (
                        <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-2.5">
                          <div class="text-xs font-semibold text-blue-600 dark:text-blue-400 mb-1">🏛️ 政府立场</div>
                          <div class="text-xs text-gray-700 dark:text-gray-300">{d.governmentStance}</div>
                        </div>
                      )}
                      {d.oppositionStance && (
                        <div class="bg-orange-50 dark:bg-orange-900/20 rounded-lg p-2.5">
                          <div class="text-xs font-semibold text-orange-600 dark:text-orange-400 mb-1">❓ 质询立场</div>
                          <div class="text-xs text-gray-700 dark:text-gray-300">{d.oppositionStance}</div>
                        </div>
                      )}
                    </div>
                  )}

                  {/* Policy Signal */}
                  {d.policySignal && (
                    <div class="mt-2 text-xs text-purple-600 dark:text-purple-400 bg-purple-50 dark:bg-purple-900/20 px-2 py-1 rounded inline-block">
                      📡 {d.policySignal}
                    </div>
                  )}

                  {/* Notable Quote */}
                  {d.notableQuote && (
                    <blockquote class="border-l-2 border-gray-300 dark:border-gray-600 pl-3 mt-3 text-xs text-gray-500 dark:text-gray-400 italic">
                      "{d.notableQuote}"
                    </blockquote>
                  )}

                  {/* Footer */}
                  <div class="flex items-center justify-between mt-4 pt-3 border-t border-subtle">
                    <div class="flex flex-wrap gap-1 items-center text-xs">
                      <span class="text-gray-400 mr-1">🎙️</span>
                      {(d.speakers || []).slice(0, 5).map((s, i) => {
                        const pid = findPersonId(s);
                        const display = pid ? getPerson(pid)?.zhName || s : s;
                        return (
                          <>
                            {i > 0 && <span class="text-gray-300 mx-1">·</span>}
                            {pid ? (
                              <a
                                href={`/voices/${pid}/`}
                                class="text-xs text-gray-500 hover:text-purple-600 hover:underline transition-colors"
                                title={s}
                              >
                                {display}
                              </a>
                            ) : (
                              <span class="text-xs text-gray-500" title={s}>
                                {display}
                              </span>
                            )}
                          </>
                        );
                      })}
                    </div>
                    <div class="flex gap-2 shrink-0 ml-3">
                      <button
                        type="button"
                        data-toggle-fulltext
                        class="text-xs text-blue-600 hover:underline whitespace-nowrap"
                      >
                        展开原文 ▼
                      </button>
                      {d.sourceUrl && (
                        <a
                          href={d.sourceUrl}
                          target="_blank"
                          rel="noopener"
                          class="text-xs text-blue-600 hover:underline whitespace-nowrap"
                        >
                          🔗 Hansard ↗
                        </a>
                      )}
                    </div>
                  </div>

                  {/* Hidden full-text panel */}
                  <div class="full-text hidden mt-3 pt-3 border-t border-subtle">
                    <div class="text-xs font-semibold text-gray-500 mb-2">📄 原文节选（英文）</div>
                    <div class="text-xs text-gray-600 dark:text-gray-400 whitespace-pre-wrap leading-relaxed max-h-64 overflow-y-auto bg-gray-50 dark:bg-slate-700/50 rounded p-3">
                      {d.summary}
                    </div>
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>

      {/* Empty state (revealed when all cards are filtered out) */}
      <div id="debate-empty-state" class="hidden text-center py-16 text-gray-400">
        <div class="text-4xl mb-3">🔍</div>
        <div class="text-lg font-medium mb-2">没有找到匹配的辩论记录</div>
        <button onclick="clearFilters()" class="mt-3 text-sm text-blue-600 hover:underline">清除筛选条件</button>
      </div>
    </section>
  </div>
</Layout>

<script define:vars={{ typeMap, controversyLabels, topicZh }}>
  // Phase 0 rewrite: cards are SSG-rendered to HTML with data-* metadata.
  // This script only toggles visibility — no JSON parse, no innerHTML rebuild.
  // Public API (filterBy / clearFilters / toggleFullText) preserved for the
  // many onclick handlers in the SSG sections above.

  const cards = () => Array.from(document.querySelectorAll('[data-debate-card]'));

  // Filter state mirrors the previous implementation 1:1 so onclick handlers
  // throughout the page (year bars, MP profiles, controversy cards, etc.)
  // continue to work without modification.
  let activeFilters = {
    search: '',
    type: '',
    topic: '',
    topicsOr: [],
    year: '',
    controversy: '',
    speaker: '',
    _yearRange: null,
  };

  function setSelectValue(id, value) {
    const el = document.getElementById(id);
    if (el) el.value = value;
  }
  function setInputValue(id, value) {
    const el = document.getElementById(id);
    if (el) el.value = value;
  }
  function scrollToDebates() {
    document.getElementById('debate-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function resetActive() {
    activeFilters = {
      search: '',
      type: '',
      topic: '',
      topicsOr: [],
      year: '',
      controversy: '',
      speaker: '',
      _yearRange: null,
    };
    setInputValue('search-input', '');
    setSelectValue('type-filter', '');
    setSelectValue('topic-filter', '');
    setSelectValue('year-filter', '');
    setSelectValue('controversy-filter', '');
    setSelectValue('speaker-filter', '');
  }

  // ── Public API ───────────────────────────────────────────────────────────
  window.filterBy = function (dimension, value) {
    resetActive();

    if (dimension === 'type') {
      activeFilters.type = value;
      setSelectValue('type-filter', value);
    } else if (dimension === 'topic') {
      activeFilters.topic = value;
      setSelectValue('topic-filter', value);
    } else if (dimension === 'year') {
      activeFilters.year = value;
      setSelectValue('year-filter', value);
    } else if (dimension === 'speaker') {
      activeFilters.speaker = value;
      setSelectValue('speaker-filter', value);
    } else if (dimension === 'topics') {
      activeFilters.topicsOr = value
        .split(',')
        .map((t) => t.trim())
        .filter(Boolean);
      if (activeFilters.topicsOr.length === 1) {
        setSelectValue('topic-filter', activeFilters.topicsOr[0]);
        activeFilters.topic = activeFilters.topicsOr[0];
        activeFilters.topicsOr = [];
      }
    } else if (dimension === 'keyword') {
      activeFilters.search = value;
      setInputValue('search-input', value);
    } else if (dimension === 'yearRange') {
      const parts = value.split('-');
      activeFilters._yearRange = [parseInt(parts[0]), parseInt(parts[parts.length - 1])];
    }

    applyFilters();
    scrollToDebates();
  };

  window.clearFilters = function () {
    resetActive();
    applyFilters();
  };

  window.toggleFullText = function (btn) {
    const card = btn.closest('[data-debate-card]');
    const ft = card?.querySelector('.full-text');
    if (!ft) return;
    if (ft.classList.contains('hidden')) {
      ft.classList.remove('hidden');
      btn.textContent = '收起原文 ▲';
    } else {
      ft.classList.add('hidden');
      btn.textContent = '展开原文 ▼';
    }
  };

  // ── Filter bar / count ───────────────────────────────────────────────────
  function updateActiveFilterBar(visibleCount) {
    const bar = document.getElementById('active-filter-bar');
    const label = document.getElementById('active-filter-label');
    const clearBtn = document.getElementById('clear-filters-btn');
    const parts = [];

    if (activeFilters.search) parts.push(`关键词「${activeFilters.search}」`);
    if (activeFilters.type) parts.push(`类型：${typeMap[activeFilters.type] || activeFilters.type}`);
    if (activeFilters.topic) parts.push(`议题：${topicZh[activeFilters.topic] || activeFilters.topic}`);
    if (activeFilters.year) parts.push(`年份：${activeFilters.year}`);
    if (activeFilters.speaker) parts.push(`议员：${activeFilters.speaker}`);
    if (activeFilters.controversy) parts.push(`争议度筛选`);
    if (activeFilters._yearRange) parts.push(`时期：${activeFilters._yearRange[0]}–${activeFilters._yearRange[1]}`);
    if (activeFilters.topicsOr && activeFilters.topicsOr.length > 0)
      parts.push(`议题：${activeFilters.topicsOr.map((t) => topicZh[t] || t).join(' / ')}`);

    if (parts.length > 0) {
      label.textContent = parts.join('  ·  ') + `  （共 ${visibleCount} 条）`;
      bar.classList.remove('hidden');
      clearBtn.classList.remove('hidden');
    } else {
      bar.classList.add('hidden');
      clearBtn.classList.add('hidden');
    }
    // Use unused param to silence linters; cLabel/cColor only used in markup.
    void controversyLabels;
  }

  // ── Filter logic (DOM toggle, no JSON) ───────────────────────────────────
  function applyFilters() {
    activeFilters.search = (document.getElementById('search-input')?.value || '').toLowerCase();
    activeFilters.type = document.getElementById('type-filter')?.value || '';
    activeFilters.year = document.getElementById('year-filter')?.value || '';
    activeFilters.controversy = document.getElementById('controversy-filter')?.value || '';
    activeFilters.speaker = document.getElementById('speaker-filter')?.value || '';
    const topic = document.getElementById('topic-filter')?.value || '';
    if (topic !== activeFilters.topic) {
      activeFilters.topic = topic;
      activeFilters.topicsOr = [];
    }

    const all = cards();
    let visible = 0;

    for (const card of all) {
      const cType = card.dataset.type || '';
      const cTopics = (card.dataset.topics || '').split('|').filter(Boolean);
      const cYear = card.dataset.year || '';
      const cSpeakers = (card.dataset.speakers || '').split('|').filter(Boolean);
      const cControversy = parseInt(card.dataset.controversy || '1', 10);
      const cSearch = card.dataset.search || '';

      let match = true;
      if (activeFilters.search && !cSearch.includes(activeFilters.search)) match = false;
      if (match && activeFilters.type && cType !== activeFilters.type) match = false;
      if (match && activeFilters.topic && !cTopics.includes(activeFilters.topic)) match = false;
      if (match && activeFilters.topicsOr.length > 0 && !activeFilters.topicsOr.some((t) => cTopics.includes(t)))
        match = false;
      if (match && activeFilters.year && cYear !== activeFilters.year) match = false;
      if (match && activeFilters.speaker && !cSpeakers.includes(activeFilters.speaker)) match = false;
      if (match && activeFilters._yearRange) {
        const y = parseInt(cYear, 10);
        if (y < activeFilters._yearRange[0] || y > activeFilters._yearRange[1]) match = false;
      }
      if (match && activeFilters.controversy === '4' && cControversy < 4) match = false;
      else if (match && activeFilters.controversy === '3' && cControversy !== 3) match = false;
      else if (match && activeFilters.controversy === '1' && cControversy > 2) match = false;

      if (match) {
        card.removeAttribute('hidden');
        visible++;
      } else {
        card.setAttribute('hidden', '');
      }
    }

    const count = document.getElementById('result-count');
    if (count) count.textContent = `显示 ${visible} / ${all.length} 条`;

    const empty = document.getElementById('debate-empty-state');
    if (empty) empty.classList.toggle('hidden', visible !== 0);

    updateActiveFilterBar(visible);
  }

  // ── Init ─────────────────────────────────────────────────────────────────
  // Re-run on every navigation: ClientRouter swaps body without firing
  // DOMContentLoaded, so SPA-style entries to this page need astro:page-load.
  function initDebates() {
    applyFilters();

    document.querySelectorAll('[data-toggle-fulltext]').forEach((btn) => {
      btn.addEventListener('click', () => window.toggleFullText(btn));
    });

    document.getElementById('search-input')?.addEventListener('input', () => {
      activeFilters._yearRange = null;
      applyFilters();
    });

    ['type-filter', 'year-filter', 'controversy-filter', 'speaker-filter'].forEach((id) => {
      document.getElementById(id)?.addEventListener('change', () => {
        activeFilters._yearRange = null;
        applyFilters();
      });
    });

    document.getElementById('topic-filter')?.addEventListener('change', () => {
      activeFilters._yearRange = null;
      activeFilters.topicsOr = [];
      applyFilters();
    });
  }

  document.addEventListener('DOMContentLoaded', initDebates);
  document.addEventListener('astro:page-load', initDebates);
</script>
