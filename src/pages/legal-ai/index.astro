---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import { sections, dataDate, introBody, conclusion } from '~/data/legal-ai';

const scopeLabel: Record<string, { label: string; color: string }> = {
  training: { label: '训练侧', color: 'bg-emerald-100 dark:bg-emerald-900 text-emerald-800 dark:text-emerald-200' },
  output: { label: '输出侧', color: 'bg-rose-100 dark:bg-rose-900 text-rose-800 dark:text-rose-200' },
  liability: { label: '责任', color: 'bg-amber-100 dark:bg-amber-900 text-amber-800 dark:text-amber-200' },
  governance: { label: '治理', color: 'bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200' },
};
---

<Layout
  metadata={{
    title: '新加坡 AI 法律框架',
    description:
      '新加坡 AI 法律框架——"训练宽松 + 输出严管"双轨：Copyright §244 全球最宽松的 AI 训练例外，配合 OCHA + Elections Bill + Criminal Law Bill + Online Safety Bill 四件套输出严管。',
  }}
  breadcrumbs={[{ label: 'AI 法律框架' }]}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-5xl">
    <Headline
      title="⚖️ 新加坡 AI 法律框架"
      subtitle={`数据更新：${dataDate}。"训练宽松 + 输出严管"双轨——这让新加坡成为目前世界上对 AI 公司最清晰可预测的法域之一。`}
    />

    <div class="callout-note rounded-lg mb-12 leading-relaxed">
      <p class="font-bold text-base mb-3">核心立场</p>
      <pre class="text-sm whitespace-pre-wrap leading-relaxed bg-transparent p-0 border-0 m-0">{introBody}</pre>
    </div>

    {
      sections.map((section, sectionIdx) => (
        <div class="mb-16">
          <h2 class="text-2xl font-bold mb-3 border-b-2 border-blue-600 dark:border-blue-400 pb-2">
            {sectionIdx + 1}. {section.title}
          </h2>
          <p class="text-sm italic text-muted mb-6">{section.philosophy}</p>

          <div class="space-y-4">
            {section.items.map((item) => (
              <div class="border border-subtle rounded-lg p-6 bg-surface hover:shadow-md transition-shadow">
                <div class="flex items-start gap-2 flex-wrap mb-2">
                  <h3 class="text-lg font-bold m-0 flex-1 min-w-0">{item.title}</h3>
                  <span class={`text-xs font-bold px-2 py-1 rounded shrink-0 ${scopeLabel[item.scope].color}`}>
                    {scopeLabel[item.scope].label}
                  </span>
                  <span class="text-xs bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 px-2 py-1 rounded shrink-0">
                    {item.status}
                  </span>
                </div>
                <p class="text-sm text-muted mb-3">{item.titleEn}</p>
                <div class="flex gap-2 mb-3 flex-wrap text-xs">
                  {item.authorityUrl ? (
                    <a
                      href={item.authorityUrl}
                      target="_blank"
                      rel="noopener"
                      class="bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 px-2 py-1 rounded hover:underline"
                    >
                      {item.authority}
                    </a>
                  ) : (
                    <span class="bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 px-2 py-1 rounded">
                      {item.authority}
                    </span>
                  )}
                  <span class="bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 px-2 py-1 rounded">
                    {item.date}
                  </span>
                </div>
                <p class="text-sm font-medium mb-2">{item.summary}</p>
                <p class="text-sm text-muted mb-3">{item.body}</p>
                {item.sourceUrl && (
                  <a
                    href={item.sourceUrl}
                    target="_blank"
                    rel="noopener"
                    class="text-sm text-blue-600 dark:text-blue-400 hover:underline"
                  >
                    🔗 法律原文
                  </a>
                )}
              </div>
            ))}
          </div>
        </div>
      ))
    }

    <div class="mt-12 bg-surface rounded-xl p-8 border border-subtle">
      <h2 class="text-xl font-bold mb-4">为什么这套组合对 AI 公司有吸引力</h2>
      <pre class="text-sm whitespace-pre-wrap leading-relaxed bg-transparent p-0 border-0 m-0">{conclusion}</pre>
    </div>

    <div class="mt-12 text-sm text-muted text-center">
      延伸阅读：
      <a href="/singapore-ai-native-companies-vs-nations/" class="text-blue-600 dark:text-blue-400 hover:underline">
        从 50 人到 5,700,000 人——同一种 AI-native 架构
      </a>
      ·
      <a href="/levers/" class="text-blue-600 dark:text-blue-400 hover:underline">国家 AI 抓手图谱</a>
      ·
      <a href="/policies/" class="text-blue-600 dark:text-blue-400 hover:underline">完整政策库</a>
    </div>
  </section>
</Layout>
