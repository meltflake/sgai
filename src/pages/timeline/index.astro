---
// Timeline page (en) — thin wrapper.

import Layout from '~/layouts/PageLayout.astro';
import TimelinePage from '~/components/timeline/TimelinePage.astro';
import { t } from '~/i18n';

const lang = 'en' as const;
---

<Layout
  metadata={{
    title: t(lang, 'timelinePageTitle'),
    description: t(lang, 'timelinePageDesc'),
  }}
  breadcrumbs={[{ label: t(lang, 'timelinePageTitle') }]}
  lang={lang}
>
  <TimelinePage lang={lang} />
</Layout>
