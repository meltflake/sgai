---
// Person page (EN). Mirrors zh /people/[id]/.

import Layout from '~/layouts/PageLayout.astro';
import { allPeople, type Person } from '~/data/people';
import { getRelated, getPersonCounts } from '~/utils/graph';
import { t, pickLocalized, channelLabel } from '~/i18n';

const lang = 'en' as const;

export async function getStaticPaths() {
  return allPeople.map((p) => ({ params: { id: p.id }, props: { person: p } }));
}

interface Props {
  person: Person;
}

const { person } = Astro.props;
const related = getRelated({ type: 'person', id: person.id });
const counts = getPersonCounts(person.id);

const summary = pickLocalized(person, 'summary', 'summaryEn', lang) || '';
const isStub = !summary || summary === 'Profile pending.' || summary.startsWith('[需补充]');

const meta = {
  title: `${person.name} — Singapore AI Observatory`,
  description: summary || `${person.name}'s positions in Singapore's AI policy debates.`,
  canonical: `https://sgai.md/en/voices/${person.id}/`,
};

const categoryLabels: Record<Person['category'], string> = {
  government: 'Government',
  academic: 'Academia',
  industry: 'Industry',
};

const categoryColors: Record<Person['category'], string> = {
  government: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300',
  academic: 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300',
  industry: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300',
};
---

<Layout
  metadata={meta}
  breadcrumbs={[{ label: t(lang, 'navVoices'), href: '/en/voices/' }, { label: person.name }]}
  lang={lang}
>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-6">
      <div class="flex items-start justify-between flex-wrap gap-3">
        <div>
          <h1 class="t-display text-gray-900 dark:text-white">{person.name}</h1>
          {/* person.zhName intentionally hidden on EN page */}
        </div>
        <span class={`text-xs font-semibold px-2.5 py-1 rounded-full shrink-0 ${categoryColors[person.category]}`}>
          {categoryLabels[person.category]}
        </span>
      </div>
      {person.title && <p class="text-gray-700 dark:text-gray-300 mt-2 font-medium">{person.title}</p>}
      {/* zhTitle intentionally hidden on EN page */}
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
      <div class="bg-surface rounded-xl p-4 shadow-sm border border-subtle">
        <div class="t-stat text-blue-600">{counts.debateCount}</div>
        <div class="text-xs text-gray-500 mt-0.5">Parliamentary speeches</div>
      </div>
      <div class="bg-surface rounded-xl p-4 shadow-sm border border-subtle">
        <div class="t-stat text-purple-600">{counts.policyAuthorCount}</div>
        <div class="text-xs text-gray-500 mt-0.5">Policies championed</div>
      </div>
      <div class="bg-surface rounded-xl p-4 shadow-sm border border-subtle">
        <div class="t-stat text-amber-600">
          {(person.affiliations || []).slice(0, 2).join(' / ') || '—'}
        </div>
        <div class="text-xs text-gray-500 mt-0.5">Affiliations</div>
      </div>
    </div>

    {
      !isStub && summary && (
        <div class="callout-note p-5 rounded-lg mb-6">
          <p class="text-gray-800 dark:text-gray-200 leading-relaxed">{summary}</p>
        </div>
      )
    }
    {
      isStub && (
        <div class="callout-muted p-4 rounded-lg mb-6 text-sm">
          <p class="text-amber-900 dark:text-amber-200">
            Profile pending. The list below is auto-generated from this person's parliamentary appearances.
          </p>
        </div>
      )
    }

    {
      person.channels && person.channels.length > 0 && (
        <div class="mb-8">
          <h2 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3">
            Official channels
          </h2>
          <div class="flex flex-wrap gap-2">
            {person.channels.map((ch) => (
              <a
                href={ch.url}
                target="_blank"
                rel="noopener noreferrer"
                class={`inline-flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-full border transition-all hover:shadow-sm ${
                  ch.primary
                    ? 'bg-blue-50 border-blue-300 text-blue-700 font-semibold dark:bg-blue-900/30 dark:border-blue-600 dark:text-blue-300'
                    : 'bg-gray-50 border-gray-200 text-gray-600 hover:border-gray-300 dark:bg-slate-700 dark:border-slate-600 dark:text-gray-300'
                }`}
              >
                {channelLabel(ch, lang)}
              </a>
            ))}
          </div>
        </div>
      )
    }

    <section class="mb-10">
      <h2 class="t-h3 text-gray-800 dark:text-white mb-4 flex items-center gap-2">
        Parliamentary speeches ({related.debates.length})
      </h2>
      {
        related.debates.length === 0 ? (
          <p class="text-sm text-gray-400 italic">No related debate records.</p>
        ) : (
          <div class="space-y-3">
            {related.debates.slice(0, 30).map((d) => (
              <a
                href={`/en/debates/${d.id}/`}
                class="block bg-surface rounded-lg p-4 border border-subtle hover:border-blue-300 hover:shadow-sm transition-all"
              >
                <div class="flex items-start justify-between gap-3 flex-wrap">
                  <div class="flex-1 min-w-0">
                    <h3 class="font-semibold text-gray-800 dark:text-white text-sm leading-snug">{d.title}</h3>
                    {/* d.zhTitle intentionally hidden on EN page */}
                  </div>
                  <div class="text-xs text-gray-500 shrink-0 text-right">
                    <div>{d.date}</div>
                    <div class="text-gray-400">Parliament {d.parliament}</div>
                  </div>
                </div>
                {d.summaryShortEn && (
                  <p class="text-xs text-gray-600 dark:text-gray-400 mt-2 leading-relaxed line-clamp-3">
                    {d.summaryShortEn}
                  </p>
                )}
              </a>
            ))}
            {related.debates.length > 30 && (
              <p class="text-xs text-gray-400 italic text-center pt-2">
                Showing 30 most recent. Visit /en/debates/ for the full archive.
              </p>
            )}
          </div>
        )
      }
    </section>

    {
      related.policies.length > 0 && (
        <section class="mb-10">
          <h2 class="t-h3 text-gray-800 dark:text-white mb-4 flex items-center gap-2">
            Policies championed ({related.policies.length})
          </h2>
          <div class="grid gap-3">
            {related.policies.map((p) => (
              <a
                href={`/en/policies/${p.id}/`}
                class="block bg-surface rounded-lg p-4 border border-subtle hover:border-purple-300 hover:shadow-sm transition-all"
              >
                <h3 class="font-semibold text-gray-800 dark:text-white text-sm">{p.titleEn || p.title}</h3>
                <p class="text-xs text-gray-500 mt-0.5">{p.date}</p>
                <p class="text-xs text-gray-600 dark:text-gray-400 mt-2">{p.summaryEn || p.summary}</p>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </section>
</Layout>
