---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import { ecosystemStats, unicorns, verticals, exits, investors } from '~/data/startups';

const lang = 'en' as const;
---

<Layout
  metadata={{
    title: 'AI Startup Ecosystem',
    description: "Singapore's AI startup ecosystem — 650+ companies, funding data, unicorns, verticals, and investors.",
  }}
  breadcrumbs={[{ label: 'AI Startups' }]}
  lang={lang}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-6xl">
    <Headline title="🚀 AI Startup Ecosystem" subtitle="650+ AI startups in Singapore — the world's #3 AI hub." />

    {/* Overview Stats */}
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-12">
      <div class="bg-surface rounded-lg shadow border border-subtle p-4 text-center">
        <div class="t-stat text-blue-600 dark:text-blue-400">{ecosystemStats.totalStartups}</div>
        <div class="text-xs text-muted mt-1">AI startups</div>
      </div>
      <div class="bg-surface rounded-lg shadow border border-subtle p-4 text-center">
        <div class="t-stat text-blue-600 dark:text-blue-400">#{ecosystemStats.globalRank}</div>
        <div class="text-xs text-muted mt-1">Global AI hub rank</div>
      </div>
      <div class="bg-surface rounded-lg shadow border border-subtle p-4 text-center">
        <div class="t-stat text-blue-600 dark:text-blue-400">{ecosystemStats.seaFundingShare}</div>
        <div class="text-xs text-muted mt-1">SEA AI funding share</div>
      </div>
      <div class="bg-surface rounded-lg shadow border border-subtle p-4 text-center">
        <div class="t-stat text-blue-600 dark:text-blue-400">{ecosystemStats.totalVCRaised}</div>
        <div class="text-xs text-muted mt-1">Total VC raised</div>
      </div>
      <div class="bg-surface rounded-lg shadow border border-subtle p-4 text-center">
        <div class="t-stat text-blue-600 dark:text-blue-400">{ecosystemStats.unicorns}</div>
        <div class="text-xs text-muted mt-1">Unicorns</div>
      </div>
      <div class="bg-surface rounded-lg shadow border border-subtle p-4 text-center">
        <div class="t-stat text-blue-600 dark:text-blue-400">{ecosystemStats.govCommitment}</div>
        <div class="text-xs text-muted mt-1">Government AI commitment</div>
      </div>
    </div>

    {/* Unicorns */}
    <div class="mb-12">
      <h2 class="t-h3 mb-4">🦄 Unicorns</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-slate-100 dark:bg-slate-800">
              <th class="text-left p-3 border border-subtle">Company</th>
              <th class="text-left p-3 border border-subtle">Sector</th>
              <th class="text-left p-3 border border-subtle">Raised</th>
              <th class="text-left p-3 border border-subtle">Valuation</th>
              <th class="text-left p-3 border border-subtle">Status</th>
            </tr>
          </thead>
          <tbody>
            {
              unicorns.map((u) => (
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
                  <td class="p-3 border border-subtle font-semibold">
                    <a
                      href={u.url}
                      target="_blank"
                      rel="noopener"
                      class="text-blue-600 dark:text-blue-400 hover:underline"
                    >
                      {u.name} ↗
                    </a>
                  </td>
                  <td class="p-3 border border-subtle">{u.sectorEn || u.sector}</td>
                  <td class="p-3 border border-subtle font-semibold">{u.raised}</td>
                  <td class="p-3 border border-subtle font-semibold text-green-600 dark:text-green-400">
                    {u.valuation}
                  </td>
                  <td class="p-3 border border-subtle">
                    {u.status === '已上市 (NASDAQ)' ? (
                      <span class="text-xs font-medium bg-purple-100 dark:bg-purple-900 text-purple-800 dark:text-purple-200 px-2 py-1 rounded">
                        Listed (NASDAQ)
                      </span>
                    ) : (
                      <span class="text-xs font-medium bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 px-2 py-1 rounded">
                        {u.statusEn || u.status}
                      </span>
                    )}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>

    {/* By Vertical */}
    <div class="mb-12">
      <h2 class="t-h3 mb-6">📂 By Vertical</h2>
      <div class="space-y-8">
        {
          verticals.map((v) => (
            <div>
              <h3 class="text-lg font-bold mb-3">
                {v.icon} {v.nameEn || v.name}
              </h3>
              <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                {v.startups.map((s) => (
                  <div class="bg-surface rounded-lg shadow-sm border border-subtle p-4">
                    <div class="flex items-start justify-between mb-2">
                      <h4 class="font-semibold">
                        {s.url ? (
                          <a
                            href={s.url}
                            target="_blank"
                            rel="noopener"
                            class="text-blue-600 dark:text-blue-400 hover:underline"
                          >
                            {s.name} ↗
                          </a>
                        ) : (
                          s.name
                        )}
                      </h4>
                      {(s.highlightEn || s.highlight) && (
                        <span class="text-xs font-medium bg-amber-100 dark:bg-amber-900 text-amber-800 dark:text-amber-200 px-2 py-0.5 rounded whitespace-nowrap ml-2">
                          {s.highlightEn || s.highlight}
                        </span>
                      )}
                    </div>
                    <p class="text-sm text-muted mb-2">{s.descriptionEn || s.description}</p>
                    <div class="flex gap-3 text-xs text-muted">
                      {s.raised && <span class="font-semibold text-green-600 dark:text-green-400">💰 {s.raised}</span>}
                      {s.investors && <span>🏛️ {s.investors}</span>}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    {/* Exits */}
    <div class="mb-12">
      <h2 class="t-h3 mb-4">🏆 Notable Exits &amp; Acquisitions</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-slate-100 dark:bg-slate-800">
              <th class="text-left p-3 border border-subtle">Company</th>
              <th class="text-left p-3 border border-subtle">Description</th>
              <th class="text-left p-3 border border-subtle">Acquirer</th>
              <th class="text-left p-3 border border-subtle">Amount</th>
              <th class="text-left p-3 border border-subtle">Year</th>
              <th class="text-left p-3 border border-subtle">Note</th>
            </tr>
          </thead>
          <tbody>
            {
              exits.map((e) => (
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
                  <td class="p-3 border border-subtle font-semibold">{e.name}</td>
                  <td class="p-3 border border-subtle">{e.descriptionEn || e.description}</td>
                  <td class="p-3 border border-subtle">{e.acquirerEn || e.acquirer}</td>
                  <td class="p-3 border border-subtle font-semibold text-green-600 dark:text-green-400">{e.amount}</td>
                  <td class="p-3 border border-subtle">{e.year || '—'}</td>
                  <td class="p-3 border border-subtle text-muted">{e.noteEn || e.note}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>

    {/* Investors */}
    <div class="mb-12">
      <h2 class="t-h3 mb-4">💰 Investor Ecosystem</h2>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          investors.map((inv) => (
            <div class="bg-surface rounded-lg shadow-sm border border-subtle p-4">
              <h4 class="font-bold text-lg mb-1">{inv.name}</h4>
              <span class="text-xs font-medium bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 px-2 py-0.5 rounded">
                {inv.typeEn || inv.type}
              </span>
              <p class="text-sm mt-2">
                <span class="text-muted">Track record: </span>
                {inv.statsEn || inv.stats}
              </p>
              <p class="text-sm">
                <span class="text-muted">Focus: </span>
                {inv.focusEn || inv.focus}
              </p>
            </div>
          ))
        }
      </div>
    </div>

    {/* Footer */}
    <p class="mt-8 text-sm text-muted text-center">
      ⚠️ Data current to {ecosystemStats.dataDate}; some figures are estimates. Funding amounts are drawn from public
      reporting and actual numbers may differ. Updates and corrections welcome.
    </p>
  </section>
</Layout>
