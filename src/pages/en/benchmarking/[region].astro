---
import type { GetStaticPaths } from 'astro';
import { Icon } from 'astro-icon/components';

import JsonLd from '~/components/common/JsonLd.astro';
import Layout from '~/layouts/PageLayout.astro';
import { benchmarkCaseProfileUpdated, dataDate, dataDisclaimerEn } from '~/data/benchmarking';
import {
  benchmarkCasePages,
  benchmarkPages,
  getBenchmarkDrilldownsForRegion,
  regionPages,
  type BenchmarkPage,
} from '~/utils/entity-pages';

export const prerender = true;

const lang = 'en' as const;

export const getStaticPaths = (() =>
  benchmarkPages.map((page) => ({ params: { region: page.slug }, props: { page } }))) satisfies GetStaticPaths;

const { page } = Astro.props as { page: BenchmarkPage };
const casePage = page.kind === 'case' ? page : null;
const regionPage = page.kind === 'region' ? page : null;
const drilldownPage = page.kind === 'drilldown' ? page : null;
const caseItem = casePage?.caseItem;
const caseName = caseItem ? caseItem.nameEn || caseItem.name : '';
const regionDrilldowns = regionPage ? getBenchmarkDrilldownsForRegion(regionPage.slug) : [];
const regionDrilldownByLocalId = new Map(regionDrilldowns.map((item) => [item.localId, item]));
const relatedDrilldowns = drilldownPage
  ? getBenchmarkDrilldownsForRegion(drilldownPage.region.slug)
      .filter((candidate) => candidate.slug !== drilldownPage.slug)
      .slice(0, 6)
  : [];
const relatedCases = caseItem
  ? benchmarkCasePages.filter((candidate) => candidate.slug !== casePage.slug).slice(0, 4)
  : [];
const caseRegionPage = caseItem
  ? regionPages.find(
      (candidate) =>
        candidate.summary.name === caseItem.region ||
        candidate.summary.nameEn === caseItem.regionEn ||
        candidate.summary.nameEn === caseItem.region ||
        candidate.summary.name === caseItem.regionEn
    )
  : null;
const relatedRegions = regionPage
  ? regionPages.filter((candidate) => candidate.slug !== regionPage.slug).slice(0, 6)
  : [];
const regionName = regionPage ? regionPage.summary.nameEn || regionPage.summary.name : '';

function drilldownHref(localId: string): string {
  const target = regionDrilldownByLocalId.get(localId);
  return target ? `/en/benchmarking/${target.slug}/` : '/en/benchmarking/';
}

const metadata = drilldownPage
  ? {
      title: `${drilldownPage.titleEn || drilldownPage.title} · ${drilldownPage.region.summary.nameEn || drilldownPage.region.summary.name} Benchmark`,
      description: drilldownPage.descriptionEn || drilldownPage.description,
    }
  : caseItem
    ? {
        title: `${caseName} · International Benchmark Case`,
        description: caseItem.summaryEn || caseItem.summary,
      }
    : {
        title: `${regionName} AI Strategy Benchmark · International Benchmarks`,
        description:
          regionPage?.detail?.overviewEn ||
          regionPage?.detail?.overview ||
          `${regionName}'s AI strategy, investment, governance model, and comparative strengths.`,
      };

const articleSchema = drilldownPage
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: drilldownPage.titleEn || drilldownPage.title,
      description: drilldownPage.descriptionEn || drilldownPage.description,
      dateModified: benchmarkCaseProfileUpdated,
      inLanguage: 'en',
      mainEntityOfPage: new URL(Astro.url).href,
      about: [
        { '@type': 'Thing', name: drilldownPage.titleEn || drilldownPage.title },
        { '@type': 'Place', name: drilldownPage.region.summary.nameEn || drilldownPage.region.summary.name },
      ],
      isPartOf: {
        '@type': 'WebSite',
        name: 'Singapore AI Observatory',
        url: 'https://sgai.md/en/',
      },
    }
  : caseItem
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: `${caseName} · International Benchmark Case`,
        description: caseItem.summaryEn || caseItem.summary,
        dateModified: benchmarkCaseProfileUpdated,
        inLanguage: 'en',
        mainEntityOfPage: new URL(Astro.url).href,
        about: [
          { '@type': 'Thing', name: caseName },
          { '@type': 'Place', name: caseItem.regionEn || caseItem.region },
        ],
        isPartOf: {
          '@type': 'WebSite',
          name: 'Singapore AI Observatory',
          url: 'https://sgai.md/en/',
        },
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: `${regionName} AI Strategy Benchmark`,
        description: metadata.description,
        dateModified: dataDate,
        inLanguage: 'en',
        about: [
          { '@type': 'Place', name: regionName },
          { '@type': 'Thing', name: 'AI strategy' },
        ],
      };
---

{
  drilldownPage ? (
    <Layout
      metadata={metadata}
      breadcrumbs={[
        { label: 'International Benchmarks', href: '/en/benchmarking/' },
        {
          label: drilldownPage.region.summary.nameEn || drilldownPage.region.summary.name,
          href: `/en/benchmarking/${drilldownPage.region.slug}/`,
        },
        { label: drilldownPage.titleEn || drilldownPage.title },
      ]}
      lang={lang}
    >
      <JsonLd schema={articleSchema} />

      <article class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-16">
        <header class="mb-8">
          <div class="mb-5 flex flex-wrap items-center gap-2 text-xs">
            <a
              href={`/en/benchmarking/${drilldownPage.region.slug}/`}
              class="inline-flex items-center gap-1 bg-primary/10 text-primary px-3 py-1.5 rounded font-semibold hover:bg-primary/15 transition-colors"
            >
              <Icon name="tabler:arrow-left" class="w-3.5 h-3.5" />
              {drilldownPage.region.summary.nameEn || drilldownPage.region.summary.name}
            </a>
            <span class="bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-3 py-1.5 rounded">
              {drilldownPage.categoryEn || drilldownPage.category}
            </span>
          </div>

          <p class="text-xs uppercase tracking-[0.18em] text-primary font-semibold mb-4">
            Benchmark Drilldown · Updated {benchmarkCaseProfileUpdated}
          </p>
          <h1 class="t-display text-gray-900 dark:text-white mb-3">{drilldownPage.titleEn || drilldownPage.title}</h1>
          <p class="t-lead text-gray-700 dark:text-gray-300 mt-6">
            {drilldownPage.descriptionEn || drilldownPage.description}
          </p>
        </header>

        <dl class="bg-surface rounded-lg border border-subtle p-5 mb-10 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4 text-sm">
          {drilldownPage.facts.map((fact) => (
            <div>
              <dt class="text-xs uppercase tracking-wider text-muted mb-1">{fact.labelEn || fact.label}</dt>
              <dd class="text-gray-900 dark:text-white">{fact.valueEn || fact.value}</dd>
            </div>
          ))}
        </dl>

        <section class="mb-10">
          <h2 class="t-h3 text-gray-900 dark:text-white mb-4">Expanded Note</h2>
          <p class="text-base leading-[1.85] text-gray-800 dark:text-gray-200">
            {drilldownPage.bodyEn || drilldownPage.body}
          </p>
        </section>

        {(drilldownPage.sourcesEn || drilldownPage.sources).length > 0 && (
          <section class="mb-10">
            <h2 class="t-h3 text-gray-900 dark:text-white mb-4">Sources</h2>
            <ul class="space-y-1 text-sm text-gray-500 dark:text-gray-400">
              {(drilldownPage.sourcesEn || drilldownPage.sources).map((source) => (
                <li>• {source}</li>
              ))}
            </ul>
          </section>
        )}

        {relatedDrilldowns.length > 0 && (
          <section class="mb-10">
            <h2 class="t-h3 text-gray-900 dark:text-white mb-4">Continue Within This Region</h2>
            <div class="grid gap-3 md:grid-cols-2">
              {relatedDrilldowns.map((related) => (
                <a
                  href={`/en/benchmarking/${related.slug}/`}
                  class="group bg-surface rounded-lg p-4 border border-subtle hover:border-primary/50 hover:shadow-sm transition-all"
                >
                  <p class="text-xs text-muted">{related.categoryEn || related.category}</p>
                  <h3 class="mt-1 font-semibold text-gray-900 dark:text-white group-hover:text-primary">
                    {related.titleEn || related.title}
                  </h3>
                  <p class="mt-2 text-xs text-gray-600 dark:text-gray-400 line-clamp-2">
                    {related.descriptionEn || related.description}
                  </p>
                </a>
              ))}
            </div>
          </section>
        )}

        <section class="mb-10 pt-6 border-t border-subtle">
          <h2 class="text-sm uppercase tracking-wider text-muted font-semibold mb-3">Data Note</h2>
          <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">
            This page is generated from the regional benchmark data and curated on {benchmarkCaseProfileUpdated}; it is
            ready for future official links, metrics, timelines, and execution updates.
          </p>
        </section>

        <nav class="mt-12 pt-6 border-t border-subtle">
          <a
            href={`/en/benchmarking/${drilldownPage.region.slug}/`}
            class="text-sm text-primary hover:text-secondary font-medium inline-flex items-center gap-1"
          >
            <Icon name="tabler:arrow-left" class="w-4 h-4" />
            Back to {drilldownPage.region.summary.nameEn || drilldownPage.region.summary.name}
          </a>
        </nav>
      </article>
    </Layout>
  ) : caseItem ? (
    <Layout
      metadata={metadata}
      breadcrumbs={[{ label: 'International Benchmarks', href: '/en/benchmarking/' }, { label: caseName }]}
      lang={lang}
    >
      <JsonLd schema={articleSchema} />

      <article class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-16">
        <header class="mb-8">
          <div class="mb-5 flex flex-wrap items-center gap-2 text-xs">
            <a
              href="/en/benchmarking/"
              class="inline-flex items-center gap-1 bg-primary/10 text-primary px-3 py-1.5 rounded font-semibold hover:bg-primary/15 transition-colors"
            >
              <Icon name="tabler:arrow-left" class="w-3.5 h-3.5" />
              International Benchmarks
            </a>
            <span class="bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-3 py-1.5 rounded">
              {caseItem.flag} {caseItem.regionEn || caseItem.region}
            </span>
            <span class="bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-3 py-1.5 rounded">
              {caseItem.typeEn || caseItem.type}
            </span>
            <span class="bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-3 py-1.5 rounded">
              {caseItem.statusEn || caseItem.status}
            </span>
          </div>

          <p class="text-xs uppercase tracking-[0.18em] text-primary font-semibold mb-4">
            Benchmark Case · Updated {benchmarkCaseProfileUpdated}
          </p>
          <h1 class="t-display text-gray-900 dark:text-white mb-3">{caseName}</h1>
          <p class="t-lead text-gray-700 dark:text-gray-300 mt-6">{caseItem.summaryEn || caseItem.summary}</p>
        </header>

        <section class="callout-note rounded-lg p-5 mb-8">
          <p class="font-serif text-lg leading-[1.85] text-gray-900 dark:text-white m-0">
            {caseItem.headlineEn || caseItem.headline}
          </p>
        </section>

        <dl class="bg-surface rounded-lg border border-subtle p-5 mb-10 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4 text-sm">
          <div>
            <dt class="text-xs uppercase tracking-wider text-muted mb-1">Owner</dt>
            <dd class="text-gray-900 dark:text-white">{caseItem.ownerEn || caseItem.owner}</dd>
          </div>
          {caseItem.facts.map((fact) => (
            <div>
              <dt class="text-xs uppercase tracking-wider text-muted mb-1">{fact.labelEn || fact.label}</dt>
              <dd class="text-gray-900 dark:text-white">{fact.valueEn || fact.value}</dd>
              {fact.noteEn && <dd class="mt-1 text-xs text-muted">{fact.noteEn}</dd>}
            </div>
          ))}
        </dl>

        <section class="mb-10 grid md:grid-cols-2 gap-5">
          <div>
            <h2 class="t-h3 text-gray-900 dark:text-white mb-4">Why It Matters</h2>
            <p class="text-gray-800 dark:text-gray-200 leading-[1.85]">
              {caseItem.whyItMattersEn || caseItem.whyItMatters}
            </p>
          </div>
          <div>
            <h2 class="t-h3 text-gray-900 dark:text-white mb-4">Singapore Takeaway</h2>
            <p class="text-gray-800 dark:text-gray-200 leading-[1.85]">
              {caseItem.singaporeTakeawayEn || caseItem.singaporeTakeaway}
            </p>
          </div>
        </section>

        {caseItem.sections.map((section) => (
          <section class="mb-10">
            <h2 class="t-h3 text-gray-900 dark:text-white mb-4">{section.titleEn || section.title}</h2>
            <p class="text-base leading-[1.85] text-gray-800 dark:text-gray-200">{section.bodyEn || section.body}</p>
            {section.bulletsEn && section.bulletsEn.length > 0 && (
              <ul class="mt-4 grid gap-2 text-sm">
                {section.bulletsEn.map((item) => (
                  <li class="flex items-start gap-2 text-gray-700 dark:text-gray-300">
                    <Icon name="tabler:check" class="w-4 h-4 mt-1 text-primary shrink-0" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </section>
        ))}

        <section class="mb-10">
          <h2 class="t-h3 text-gray-900 dark:text-white mb-4">Sources</h2>
          <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
            {caseItem.sources.map((source) => (
              <li>
                {source.url ? (
                  <a
                    href={source.url}
                    target="_blank"
                    rel="noopener"
                    class="inline-flex items-center gap-1 text-primary hover:text-secondary"
                  >
                    {source.labelEn || source.label}
                    <Icon name="tabler:external-link" class="w-3.5 h-3.5" />
                  </a>
                ) : (
                  <span>• {source.labelEn || source.label}</span>
                )}
              </li>
            ))}
          </ul>
        </section>

        <section class="mb-10 grid gap-4 md:grid-cols-2">
          {caseRegionPage && (
            <a
              href={`/en/benchmarking/${caseRegionPage.slug}/`}
              class="group rounded-lg border border-subtle bg-surface p-5 hover:border-primary/50 hover:shadow-sm transition-all"
            >
              <p class="text-xs text-muted">Region background</p>
              <h2 class="mt-2 font-bold text-gray-900 dark:text-white group-hover:text-primary">
                {caseRegionPage.summary.flag} {caseRegionPage.summary.nameEn || caseRegionPage.summary.name}
              </h2>
              <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">
                {caseRegionPage.summary.strengthEn || caseRegionPage.summary.strength}
              </p>
            </a>
          )}
          {relatedCases.slice(0, 1).map((related) => (
            <a
              href={`/en/benchmarking/${related.slug}/`}
              class="group rounded-lg border border-subtle bg-surface p-5 hover:border-primary/50 hover:shadow-sm transition-all"
            >
              <p class="text-xs text-muted">Another case</p>
              <h2 class="mt-2 font-bold text-gray-900 dark:text-white group-hover:text-primary">
                {related.caseItem.flag} {related.caseItem.nameEn || related.caseItem.name}
              </h2>
              <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">
                {related.caseItem.headlineEn || related.caseItem.headline}
              </p>
            </a>
          ))}
        </section>

        {relatedCases.length > 1 && (
          <section class="mb-10">
            <h2 class="t-h3 text-gray-900 dark:text-white mb-4">Continue With Cases</h2>
            <div class="grid gap-3 sm:grid-cols-2">
              {relatedCases.slice(1).map((related) => (
                <a
                  href={`/en/benchmarking/${related.slug}/`}
                  class="group bg-surface rounded-lg p-4 border border-subtle hover:border-primary transition-colors"
                >
                  <p class="text-xs text-muted">
                    {related.caseItem.flag} {related.caseItem.regionEn || related.caseItem.region} ·{' '}
                    {related.caseItem.typeEn || related.caseItem.type}
                  </p>
                  <h3 class="mt-1 font-semibold text-gray-900 dark:text-white group-hover:text-primary">
                    {related.caseItem.nameEn || related.caseItem.name}
                  </h3>
                </a>
              ))}
            </div>
          </section>
        )}

        <section class="mb-10 pt-6 border-t border-subtle">
          <h2 class="text-sm uppercase tracking-wider text-muted font-semibold mb-3">Data Note</h2>
          <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">
            This is an international benchmark case profile curated on {benchmarkCaseProfileUpdated}; base regional data
            follows the public-source cut-off of {dataDate}. Future updates can add official links, timelines, metrics,
            citations, and cross-page relationships.
          </p>
        </section>

        <nav class="mt-12 pt-6 border-t border-subtle">
          <a
            href="/en/benchmarking/"
            class="text-sm text-primary hover:text-secondary font-medium inline-flex items-center gap-1"
          >
            <Icon name="tabler:arrow-left" class="w-4 h-4" />
            Back to International Benchmarks
          </a>
        </nav>
      </article>
    </Layout>
  ) : (
    regionPage && (
      <Layout
        metadata={metadata}
        breadcrumbs={[{ label: 'International Benchmarks', href: '/en/benchmarking/' }, { label: regionName }]}
        lang={lang}
      >
        <JsonLd schema={articleSchema} />

        <article class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-16">
          <header class="mb-8">
            <p class="text-xs uppercase tracking-[0.18em] text-primary font-semibold mb-4">
              International Benchmark · Updated {dataDate}
            </p>
            <h1 class="t-display text-gray-900 dark:text-white mb-3">
              {regionPage.summary.flag}
              {regionName} AI Strategy Benchmark
            </h1>
            {regionPage.detail?.fullNameEn && (
              <p class="text-base md:text-lg text-gray-500 dark:text-gray-400">{regionPage.detail.fullNameEn}</p>
            )}
          </header>

          <section class="grid md:grid-cols-2 gap-3 mb-8">
            <a
              href={drilldownHref('core-strategy')}
              class="group bg-surface border border-subtle rounded-lg p-4 hover:border-primary/50 hover:shadow-sm transition-all"
            >
              <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">Core strategy</div>
              <div class="font-semibold group-hover:text-primary">
                {regionPage.summary.strategyEn || regionPage.summary.strategy}
              </div>
              <div class="text-xs text-gray-500 mt-1">{regionPage.summary.strategyYear}</div>
            </a>
            <a
              href={drilldownHref('investment-overview')}
              class="group bg-surface border border-subtle rounded-lg p-4 hover:border-primary/50 hover:shadow-sm transition-all"
            >
              <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">Investment</div>
              <div class="font-semibold group-hover:text-primary">
                {regionPage.summary.investmentEn || regionPage.summary.investment}
              </div>
            </a>
            <a
              href={drilldownHref('governance-model')}
              class="group bg-surface border border-subtle rounded-lg p-4 hover:border-primary/50 hover:shadow-sm transition-all"
            >
              <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">Governance</div>
              <div class="font-semibold group-hover:text-primary">
                {regionPage.summary.governanceEn || regionPage.summary.governance}
              </div>
            </a>
            <a
              href={drilldownHref('comparative-strength')}
              class="group bg-surface border border-subtle rounded-lg p-4 hover:border-primary/50 hover:shadow-sm transition-all"
            >
              <div class="text-xs uppercase tracking-wider text-gray-500 mb-1">Core strength</div>
              <div class="font-semibold group-hover:text-primary">
                {regionPage.summary.strengthEn || regionPage.summary.strength}
              </div>
            </a>
          </section>

          <section class="callout-note rounded-lg p-5 mb-10">
            <h2 class="t-h3 text-gray-900 dark:text-white mb-3">One-line Read</h2>
            <p class="text-gray-800 dark:text-gray-200 leading-[1.85]">
              {regionPage.detail?.overviewEn ||
                `${regionName}'s AI strategy centres on ${
                  regionPage.summary.strategyEn || regionPage.summary.strategy
                }; its governance model is ${
                  regionPage.summary.governanceEn || regionPage.summary.governance
                }; its comparative strength is ${regionPage.summary.strengthEn || regionPage.summary.strength}.`}
            </p>
          </section>

          {regionPage.detail ? (
            <>
              <section class="mb-10">
                <h2 class="t-h3 text-gray-900 dark:text-white mb-4">Core Strategies</h2>
                <div class="space-y-3">
                  {regionPage.detail.strategies.map((strategy, index) => (
                    <a
                      href={drilldownHref(`strategy-${index + 1}`)}
                      class="group block bg-surface border border-subtle rounded-lg p-4 hover:border-primary/50 hover:shadow-sm transition-all"
                    >
                      <div class="text-xs font-mono text-blue-600 dark:text-blue-400 mb-1">{strategy.year}</div>
                      <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-primary">
                        {strategy.nameEn || strategy.name}
                      </h3>
                      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
                        {strategy.descriptionEn || strategy.description}
                      </p>
                    </a>
                  ))}
                </div>
              </section>

              <section class="mb-10">
                <h2 class="t-h3 text-gray-900 dark:text-white mb-4">Investment and Resources</h2>
                <div class="grid gap-3">
                  {regionPage.detail.investment.map((item, index) => (
                    <a
                      href={drilldownHref(`investment-${index + 1}`)}
                      class="group grid gap-3 rounded-lg border border-subtle bg-surface p-4 hover:border-primary/50 hover:shadow-sm transition-all sm:grid-cols-[1.2fr_0.8fr_1.2fr]"
                    >
                      <div>
                        <div class="text-xs uppercase tracking-wider text-muted mb-1">Item</div>
                        <div class="font-semibold text-gray-900 dark:text-white group-hover:text-primary">
                          {item.itemEn || item.item}
                        </div>
                      </div>
                      <div>
                        <div class="text-xs uppercase tracking-wider text-muted mb-1">Amount</div>
                        <div class="font-semibold text-gray-900 dark:text-white">{item.amountEn || item.amount}</div>
                      </div>
                      <div>
                        <div class="text-xs uppercase tracking-wider text-muted mb-1">Note</div>
                        <div class="text-sm text-gray-600 dark:text-gray-400">{item.noteEn || item.note}</div>
                      </div>
                    </a>
                  ))}
                </div>
              </section>

              <section class="mb-10">
                <h2 class="t-h3 text-gray-900 dark:text-white mb-3">Governance Model</h2>
                <p class="text-gray-700 dark:text-gray-300 leading-[1.85]">
                  {regionPage.detail.governanceEn || regionPage.detail.governance}
                </p>
              </section>

              <section class="mb-10 grid md:grid-cols-2 gap-5">
                <div>
                  <h2 class="font-serif text-xl font-semibold text-green-700 dark:text-green-300 mb-3">
                    Strengths vs Singapore
                  </h2>
                  <ul class="space-y-2 text-sm text-gray-700 dark:text-gray-300">
                    {(regionPage.detail.strengthsEn || regionPage.detail.strengths).map((item) => (
                      <li>• {item}</li>
                    ))}
                  </ul>
                </div>
                <div>
                  <h2 class="font-serif text-xl font-semibold text-red-700 dark:text-red-300 mb-3">
                    Weaknesses vs Singapore
                  </h2>
                  <ul class="space-y-2 text-sm text-gray-700 dark:text-gray-300">
                    {(regionPage.detail.weaknessesEn || regionPage.detail.weaknesses).map((item) => (
                      <li>• {item}</li>
                    ))}
                  </ul>
                </div>
              </section>

              <section class="mb-10">
                <h2 class="t-h3 text-gray-900 dark:text-white mb-4">Key Initiatives and Bodies</h2>
                <div class="grid md:grid-cols-2 gap-5">
                  <div class="bg-surface border border-subtle rounded-lg p-4">
                    <h3 class="font-semibold mb-3">Key Initiatives</h3>
                    <div class="space-y-2 text-sm">
                      {(regionPage.detail.keyInitiativesEn || regionPage.detail.keyInitiatives).map((item, index) => (
                        <a
                          href={drilldownHref(`initiative-${index + 1}`)}
                          class="group flex items-start justify-between gap-3 rounded-md border border-subtle p-3 hover:border-primary/50 hover:bg-slate-50 dark:hover:bg-slate-800/60 transition-colors"
                        >
                          <span class="text-gray-700 dark:text-gray-300 group-hover:text-primary">{item}</span>
                          <Icon
                            name="tabler:arrow-up-right"
                            class="w-4 h-4 text-muted group-hover:text-primary shrink-0"
                          />
                        </a>
                      ))}
                    </div>
                  </div>
                  <div class="bg-surface border border-subtle rounded-lg p-4">
                    <h3 class="font-semibold mb-3">Key Bodies</h3>
                    <div class="space-y-2 text-sm">
                      {regionPage.detail.keyBodies.map((body, index) => (
                        <a
                          href={drilldownHref(`body-${index + 1}`)}
                          class="group block rounded-md border border-subtle p-3 hover:border-primary/50 hover:bg-slate-50 dark:hover:bg-slate-800/60 transition-colors"
                        >
                          <div class="font-semibold text-gray-900 dark:text-white group-hover:text-primary">
                            {body.nameEn || body.name}
                          </div>
                          <div class="mt-1 text-gray-700 dark:text-gray-300">{body.roleEn || body.role}</div>
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              </section>

              <section class="mb-10">
                <h2 class="t-h3 text-gray-900 dark:text-white mb-3">Sources</h2>
                <ul class="space-y-1 text-sm text-gray-500 dark:text-gray-400">
                  {(regionPage.detail.sourcesEn || regionPage.detail.sources).map((source) => (
                    <li>• {source}</li>
                  ))}
                </ul>
              </section>
            </>
          ) : (
            <section class="callout-muted rounded-lg p-5 mb-10">
              <h2 class="font-semibold mb-2">Detail profile pending</h2>
              <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
                This page is currently generated from the overview table. Add a full <code>RegionDetail</code> record in{' '}
                <code>src/data/benchmarking.ts</code> and this route will automatically expand with strategy,
                investment, governance, strengths/weaknesses, and sources.
              </p>
            </section>
          )}

          <section class="mb-10">
            <h2 class="t-h3 text-gray-900 dark:text-white mb-4">Related Reading</h2>
            <div class="flex flex-wrap gap-3">
              <a
                href="/en/benchmarking/"
                class="text-sm text-primary hover:text-secondary border border-primary/30 px-4 py-2 rounded-md"
              >
                Benchmark Overview
              </a>
              <a
                href="/en/levers/"
                class="text-sm text-primary hover:text-secondary border border-primary/30 px-4 py-2 rounded-md"
              >
                Singapore National AI Levers
              </a>
              <a
                href="/en/legal-ai/"
                class="text-sm text-primary hover:text-secondary border border-primary/30 px-4 py-2 rounded-md"
              >
                Singapore AI Legal Framework
              </a>
            </div>
          </section>

          <section class="mb-10">
            <h2 class="t-h3 text-gray-900 dark:text-white mb-4">Continue Comparing</h2>
            <div class="grid gap-3 md:grid-cols-2">
              {relatedRegions.map((item) => (
                <a
                  href={`/en/benchmarking/${item.slug}/`}
                  class="block bg-surface rounded-lg p-4 border border-subtle hover:border-blue-300 hover:shadow-sm transition-all"
                >
                  <h3 class="font-semibold text-gray-800 dark:text-white text-sm">
                    {item.summary.flag} {item.summary.nameEn || item.summary.name}
                  </h3>
                  <p class="text-xs text-gray-600 dark:text-gray-400 mt-2">
                    {item.summary.strengthEn || item.summary.strength}
                  </p>
                </a>
              ))}
            </div>
          </section>

          <p class="text-xs text-gray-500 dark:text-gray-400 border-t border-subtle pt-5">{dataDisclaimerEn}</p>

          <nav class="mt-8">
            <a
              href="/en/benchmarking/"
              class="text-sm text-primary hover:text-secondary font-medium inline-flex items-center gap-1"
            >
              <Icon name="tabler:arrow-left" class="w-4 h-4" />
              Back to International Benchmarks
            </a>
          </nav>
        </article>
      </Layout>
    )
  )
}
