---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import { regions, regionDetails, insights, dataDate, dataDisclaimerEn, dataDisclaimer } from '~/data/benchmarking';
import { pickLocalized } from '~/i18n';
import { regionSlug } from '~/utils/entity-pages';

const lang = 'en' as const;
const disclaimer = dataDisclaimerEn || dataDisclaimer;
---

<Layout
  metadata={{
    title: 'International Benchmarks',
    description:
      "International benchmarks for Singapore's AI strategy — comparison with the United States, the United Kingdom, China, the EU and other major economies.",
  }}
  breadcrumbs={[{ label: 'International Benchmarks' }]}
  lang={lang}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-6xl">
    <Headline title="🌏 International Benchmarks" subtitle="Singapore's AI strategy compared to leading economies." />

    <!-- Overview comparison table -->
    <div class="mb-12">
      <h2 class="t-h3 mb-4">📊 Overview Comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse min-w-[900px]">
          <thead>
            <tr class="bg-slate-100 dark:bg-slate-800">
              <th class="text-left p-3 border border-subtle">Region</th>
              <th class="text-left p-3 border border-subtle">Core strategy</th>
              <th class="text-left p-3 border border-subtle">Year</th>
              <th class="text-left p-3 border border-subtle">Investment</th>
              <th class="text-left p-3 border border-subtle">Governance</th>
              <th class="text-left p-3 border border-subtle">Strength</th>
              <th class="text-left p-3 border border-subtle">AI ranking</th>
            </tr>
          </thead>
          <tbody>
            {
              regions.map((r, i) => (
                <tr
                  class={
                    i === 0
                      ? 'bg-blue-50 dark:bg-blue-900/20 font-semibold'
                      : 'hover:bg-slate-50 dark:hover:bg-slate-800/50'
                  }
                >
                  <td class="p-3 border border-subtle whitespace-nowrap">
                    <a href={`/en/benchmarking/${regionSlug(r)}/`} class="text-primary hover:text-secondary">
                      {r.flag} {r.nameEn || r.name}
                    </a>
                  </td>
                  <td class="p-3 border border-subtle">{r.strategyEn || r.strategy}</td>
                  <td class="p-3 border border-subtle">{r.strategyYear}</td>
                  <td class="p-3 border border-subtle">{r.investmentEn || r.investment}</td>
                  <td class="p-3 border border-subtle">{r.governanceEn || r.governance}</td>
                  <td class="p-3 border border-subtle">{r.strengthEn || r.strength}</td>
                  <td class="p-3 border border-subtle text-muted">{r.aiRanking || '—'}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>

    <!-- Key insights -->
    <div class="mb-12">
      <h2 class="t-h3 mb-4">💡 Key Insights</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {
          insights.map((insight) => (
            <div class="p-5 rounded-lg border border-subtle bg-surface">
              <h3 class="font-bold text-lg mb-2">{pickLocalized(insight, 'title', 'titleEn', lang)}</h3>
              <p class="text-muted text-sm">{pickLocalized(insight, 'text', 'textEn', lang)}</p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Region details -->
    <div class="mb-12">
      <h2 class="t-h3 mb-6">🔍 Region Profiles</h2>
      <div class="space-y-8">
        {
          regionDetails.map((region) => (
            <details class="border border-subtle rounded-lg overflow-hidden">
              <summary class="p-4 bg-slate-50 dark:bg-slate-800 cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-700 font-bold text-lg">
                {region.flag} {region.nameEn || region.name} — {region.fullNameEn || region.fullName}
              </summary>
              <div class="p-5 space-y-5">
                <a
                  href={`/en/benchmarking/${regionSlug(region)}/`}
                  class="inline-flex text-sm text-blue-600 dark:text-blue-400 hover:underline"
                >
                  Open detail page →
                </a>
                {/* Overview */}
                <p class="text-muted">{region.overviewEn || region.overview}</p>

                {/* Core strategies */}
                <div>
                  <h4 class="font-semibold mb-2">📋 Core Strategies</h4>
                  <div class="space-y-1">
                    {region.strategies.map((s) => (
                      <div class="flex gap-2 text-sm">
                        <span class="font-mono text-blue-600 dark:text-blue-400 whitespace-nowrap">{s.year}</span>
                        <span>
                          <strong>{s.nameEn || s.name}</strong> — {s.descriptionEn || s.description}
                        </span>
                      </div>
                    ))}
                  </div>
                </div>

                {/* Investment */}
                <div>
                  <h4 class="font-semibold mb-2">💰 Investment</h4>
                  <div class="overflow-x-auto">
                    <table class="w-full text-sm border-collapse">
                      <thead>
                        <tr class="bg-slate-100 dark:bg-slate-800">
                          <th class="text-left p-2 border border-subtle">Item</th>
                          <th class="text-left p-2 border border-subtle">Amount</th>
                          <th class="text-left p-2 border border-subtle">Note</th>
                        </tr>
                      </thead>
                      <tbody>
                        {region.investment.map((inv) => (
                          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">
                            <td class="p-2 border border-subtle">{inv.itemEn || inv.item}</td>
                            <td class="p-2 border border-subtle font-semibold">{inv.amountEn || inv.amount}</td>
                            <td class="p-2 border border-subtle text-muted">{inv.noteEn || inv.note}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>

                {/* Governance */}
                <div>
                  <h4 class="font-semibold mb-2">⚖️ Governance Model</h4>
                  <p class="text-sm text-muted">{region.governanceEn || region.governance}</p>
                </div>

                {/* Key initiatives */}
                <div>
                  <h4 class="font-semibold mb-2">🎯 Key Initiatives</h4>
                  <ul class="list-disc list-inside text-sm space-y-1">
                    {(region.keyInitiativesEn && region.keyInitiativesEn.length
                      ? region.keyInitiativesEn
                      : region.keyInitiatives
                    ).map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>

                {/* Strengths and weaknesses */}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <h4 class="font-semibold mb-2 text-green-600 dark:text-green-400">✅ Strengths vs Singapore</h4>
                    <ul class="text-sm space-y-1">
                      {(region.strengthsEn && region.strengthsEn.length ? region.strengthsEn : region.strengths).map(
                        (s) => (
                          <li class="text-green-700 dark:text-green-300">• {s}</li>
                        )
                      )}
                    </ul>
                  </div>
                  <div>
                    <h4 class="font-semibold mb-2 text-red-600 dark:text-red-400">❌ Weaknesses vs Singapore</h4>
                    <ul class="text-sm space-y-1">
                      {(region.weaknessesEn && region.weaknessesEn.length
                        ? region.weaknessesEn
                        : region.weaknesses
                      ).map((w) => (
                        <li class="text-red-700 dark:text-red-300">• {w}</li>
                      ))}
                    </ul>
                  </div>
                </div>

                {/* Key bodies */}
                <div>
                  <h4 class="font-semibold mb-2">🏛️ Key Bodies</h4>
                  <div class="space-y-1 text-sm">
                    {region.keyBodies.map((body) => (
                      <div>
                        <strong>{body.nameEn || body.name}</strong> — {body.roleEn || body.role}
                      </div>
                    ))}
                  </div>
                </div>

                {/* Sources */}
                <div>
                  <h4 class="font-semibold mb-2 text-muted">📚 Sources</h4>
                  <ul class="text-xs text-muted space-y-0.5">
                    {(region.sourcesEn && region.sourcesEn.length ? region.sourcesEn : region.sources).map((src) => (
                      <li>• {src}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </details>
          ))
        }
      </div>
    </div>

    <!-- Data note -->
    <div class="p-4 rounded-lg bg-slate-50 dark:bg-slate-800 border border-subtle">
      <p class="text-sm text-muted">⚠️ {disclaimer}</p>
      <p class="text-xs text-muted mt-1">Last updated: {dataDate}</p>
    </div>
  </section>
</Layout>
