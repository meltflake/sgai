---
import type { GetStaticPaths } from 'astro';
import { Icon } from 'astro-icon/components';

import JsonLd from '~/components/common/JsonLd.astro';
import Layout from '~/layouts/PageLayout.astro';
import { dataDate } from '~/data/legal-ai';
import { legalItemPages, legalItemSlug } from '~/utils/entity-pages';

export const prerender = true;

const lang = 'en' as const;

export const getStaticPaths = (() =>
  legalItemPages.map((page) => ({ params: { id: page.slug }, props: { page } }))) satisfies GetStaticPaths;

const { page } = Astro.props;
const { item, section } = page;
const relatedItems = section.items.filter((candidate) => candidate.title !== item.title).slice(0, 4);

const scopeLabel: Record<string, { label: string; color: string }> = {
  training: { label: 'Training', color: 'bg-emerald-100 dark:bg-emerald-900 text-emerald-800 dark:text-emerald-200' },
  output: { label: 'Output', color: 'bg-rose-100 dark:bg-rose-900 text-rose-800 dark:text-rose-200' },
  liability: { label: 'Liability', color: 'bg-amber-100 dark:bg-amber-900 text-amber-800 dark:text-amber-200' },
  governance: { label: 'Governance', color: 'bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200' },
};

const title = item.titleEn || item.title;
const summary = item.summaryEn || item.summary;
const body = item.bodyEn || item.body;

const metadata = {
  title: `${title} · AI Legal Framework`,
  description: summary,
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Legislation',
  name: title,
  description: summary,
  datePublished: item.dateEn || item.date,
  inLanguage: 'en',
  legislationJurisdiction: 'Singapore',
  ...(item.sourceUrl ? { url: item.sourceUrl } : {}),
};
---

<Layout
  metadata={metadata}
  breadcrumbs={[{ label: 'AI Legal Framework', href: '/en/legal-ai/' }, { label: title }]}
  lang={lang}
>
  <JsonLd schema={schema} />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <header class="mb-8">
      <p class="text-xs uppercase tracking-[0.18em] text-primary font-semibold mb-4">
        {section.titleEn || section.title} · Updated {dataDate}
      </p>
      <h1 class="font-serif text-3xl md:text-5xl leading-tight font-semibold text-gray-900 dark:text-white mb-3">
        {title}
      </h1>
    </header>

    <section class="flex flex-wrap gap-2 mb-8">
      <span class={`text-xs font-bold px-2 py-1 rounded ${scopeLabel[item.scope].color}`}>
        {scopeLabel[item.scope].label}
      </span>
      <span class="text-xs bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 px-2 py-1 rounded">
        {item.statusEn || item.status}
      </span>
      <span class="text-xs bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 px-2 py-1 rounded">
        {item.dateEn || item.date}
      </span>
      {
        item.authorityUrl ? (
          <a
            href={item.authorityUrl}
            target="_blank"
            rel="noopener"
            class="text-xs bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 px-2 py-1 rounded hover:underline"
          >
            {item.authorityEn || item.authority}
          </a>
        ) : (
          <span class="text-xs bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 px-2 py-1 rounded">
            {item.authorityEn || item.authority}
          </span>
        )
      }
    </section>

    <section class="callout-note rounded-lg p-5 mb-8">
      <h2 class="font-serif text-xl font-semibold text-gray-900 dark:text-white mb-3">Core Point</h2>
      <p class="text-gray-800 dark:text-gray-200 leading-[1.85]">{summary}</p>
    </section>

    <section class="prose prose-lg dark:prose-invert max-w-none font-serif mb-10">
      <h2>Detailed Note</h2>
      <p>{body}</p>
    </section>

    <section class="bg-surface border border-subtle rounded-lg p-5 mb-10">
      <h2 class="font-serif text-xl font-semibold text-gray-900 dark:text-white mb-3">
        Position in the Legal Framework
      </h2>
      <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
        {section.philosophyEn || section.philosophy}
      </p>
    </section>

    <div class="flex flex-wrap gap-3 mb-10">
      {
        item.sourceUrl && (
          <a
            href={item.sourceUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-secondary border border-primary/30 hover:border-primary px-4 py-2 rounded-md transition-colors"
          >
            <Icon name="tabler:external-link" class="w-4 h-4" />
            Statute text / source
          </a>
        )
      }
      <a
        href="/en/levers/"
        class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-secondary border border-primary/30 hover:border-primary px-4 py-2 rounded-md transition-colors"
      >
        <Icon name="tabler:target" class="w-4 h-4" />
        View National AI Levers
      </a>
    </div>

    {
      relatedItems.length > 0 && (
        <section class="mb-10">
          <h2 class="font-serif text-xl font-semibold text-gray-900 dark:text-white mb-4">Related Legal Cards</h2>
          <div class="grid gap-3">
            {relatedItems.map((related) => (
              <a
                href={`/en/legal-ai/${legalItemSlug(related)}/`}
                class="block bg-surface rounded-lg p-4 border border-subtle hover:border-blue-300 hover:shadow-sm transition-all"
              >
                <h3 class="font-semibold text-gray-800 dark:text-white text-sm">{related.titleEn || related.title}</h3>
                <p class="text-xs text-gray-600 dark:text-gray-400 mt-2">{related.summaryEn || related.summary}</p>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <nav class="mt-12 pt-6 border-t border-subtle">
      <a
        href="/en/legal-ai/"
        class="text-sm text-primary hover:text-secondary font-medium inline-flex items-center gap-1"
      >
        <Icon name="tabler:arrow-left" class="w-4 h-4" />
        Back to AI Legal Framework
      </a>
    </nav>
  </article>
</Layout>
