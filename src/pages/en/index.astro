---
// Homepage (EN) — editorial layout mirroring zh /, all chrome strings
// from the dictionary. Latest analyses are filtered to lang='en'.

import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { Icon } from 'astro-icon/components';
import { fetchPosts } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';
import { debates, DEBATE_STATS } from '~/data/debates';
import { levers } from '~/data/levers';
import { leverSlug } from '~/utils/entity-pages';
import { categories as policyCategories } from '~/data/policies';
import { SITE_UPDATED } from '~/version';
import { t, pickLocalized, localizedHref } from '~/i18n';
import { dimensions, dataDate as trackerDataDate } from '~/data/tracker';

const lang = 'en' as const;

const metadata = {
  title: t(lang, 'siteName'),
  ignoreTitleTemplate: true,
  description: t(lang, 'siteDescription'),
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: t(lang, 'siteName'),
  url: 'https://sgai.md/en/',
  logo: 'https://sgai.md/favicon.svg',
  description: t(lang, 'siteDescription'),
  sameAs: ['https://github.com/meltflake/sgai'],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: t(lang, 'siteName'),
  url: 'https://sgai.md/en/',
  inLanguage: 'en',
};

const allPosts = await fetchPosts();
const latestPosts = allPosts.filter((p) => p.lang === 'en').slice(0, 3);
const [featuredPost, ...secondaryPosts] = latestPosts;

const leverProjectCount = (lv: (typeof levers)[number]) => lv.groups.flatMap((g) => g.items).length;
const passThroughLevers = levers.filter((lv) => lv.transmissionMode === 'transmitted');
const directLevers = levers.filter((lv) => lv.transmissionMode === 'direct');

const latestDebates = [...debates].sort((a, b) => (a.date < b.date ? 1 : -1)).slice(0, 5);

const totalPolicies = policyCategories.flatMap((c) => c.policies).length;
const totalDebates = DEBATE_STATS.total;
const totalLeverItems = levers.reduce((sum, lv) => sum + lv.groups.flatMap((g) => g.items).length, 0);
---

<Layout metadata={metadata} lang={lang}>
  <JsonLd schema={organizationSchema} />
  <JsonLd schema={websiteSchema} />

  {
    /* Hero — thesis + lever map in one fold. The structure (4 pass-through
      vs 2 direct) is the argument; copy is intentionally compact. */
  }
  <section class="relative pt-12 md:pt-16 pb-8 md:pb-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <p class="text-xs uppercase tracking-[0.18em] text-primary font-semibold mb-4">{t(lang, 'heroEyebrow')}</p>
      <h1
        class="font-serif text-3xl md:text-5xl leading-[1.15] font-semibold text-gray-900 dark:text-white mb-6 tracking-tight max-w-3xl"
      >
        {t(lang, 'heroHeadline')}<br class="hidden md:inline" />{` ${t(lang, 'heroHeadline2')}`}
      </h1>
      <p class="text-base md:text-lg leading-[1.85] text-gray-700 dark:text-gray-300 mb-8 max-w-prose">
        {t(lang, 'heroSubtitle')}
      </p>
      <div class="flex flex-wrap gap-4 items-center">
        <a
          href="/en/singapore-ai-strategy-the-real-moat/"
          class="inline-flex items-center gap-2 bg-primary hover:bg-secondary text-white font-semibold px-5 py-3 rounded-md transition-colors text-sm"
        >
          {t(lang, 'ctaReadCore')}
          <Icon name="tabler:arrow-right" class="w-4 h-4" />
        </a>
        <a
          href="/en/blog/"
          class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-primary transition-colors underline-offset-4 hover:underline"
        >
          {t(lang, 'ctaBrowseAll')}
        </a>
      </div>
    </div>
  </section>

  {/* Tracker dashboard summary — links to the 6-dimension dashboard. */}
  <section class="px-4 py-10 sm:px-6 mx-auto lg:px-8 max-w-6xl">
    <div class="callout-note rounded-lg p-6">
      <h2 class="text-xl font-bold mb-3 m-0">{t(lang, 'trackerHomeSummaryTitle')}</h2>
      <p class="text-sm text-muted mb-3">
        {t(lang, 'trackerLastUpdated')}: {trackerDataDate}
      </p>
      <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm font-mono mb-4">
        {
          dimensions.map((dim) => {
            const tt = dim.titleEn ?? dim.title;
            const arrow = dim.trend === 'up' ? '↗' : dim.trend === 'down' ? '↘' : '→';
            return (
              <span>
                <span class="text-slate-500">{dim.icon}</span> {tt} <span class="text-slate-400">{arrow}</span>
              </span>
            );
          })
        }
      </div>
      <a
        href={localizedHref('/tracker/', lang)}
        class="text-sm font-semibold text-blue-600 dark:text-blue-400 hover:underline"
      >
        {t(lang, 'trackerHomeSummaryCta')} →
      </a>
    </div>
  </section>

  {
    /* Lever map — visual evidence for the hero thesis. Two columns by
      transmissionMode: pass-through (4) wide-left, direct (2) narrow-right. */
  }
  <section class="pb-12 md:pb-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex items-baseline justify-between mb-2 gap-4 flex-wrap">
        <h2 class="font-serif text-xl md:text-2xl font-semibold text-gray-900 dark:text-white">
          {t(lang, 'leversSection')}
        </h2>
        <a href="/en/levers/" class="text-sm text-gray-500 hover:text-primary dark:text-gray-400 transition-colors">
          {t(lang, 'viewAllLeversCta')}
        </a>
      </div>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-6 max-w-prose leading-relaxed">
        {t(lang, 'leversBlurb').replace('{count}', String(totalLeverItems))}
      </p>

      <div class="grid gap-6 md:grid-cols-[2fr_1fr] md:gap-8">
        {/* Pass-through column (4 levers) */}
        <div>
          <div class="flex items-center gap-2 mb-4">
            <span class="text-xs uppercase tracking-[0.18em] text-primary font-semibold">
              {t(lang, 'leverMapColPassThrough')}
            </span>
            <span class="text-xs text-gray-400 dark:text-gray-500 tabular-nums">
              {passThroughLevers.length}
            </span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-4 leading-relaxed">
            {t(lang, 'leverMapColPassThroughHint')}
          </p>
          <div class="grid sm:grid-cols-2 gap-x-6 gap-y-5">
            {
              passThroughLevers.map((lv) => (
                <a
                  href={`/en/levers/${leverSlug(lv)}/`}
                  class="group block border-l-2 border-subtle hover:border-primary pl-4 py-1 transition-colors"
                >
                  <div class="flex items-baseline justify-between gap-2 mb-1">
                    <div class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 tabular-nums">
                      {t(lang, 'leverWord')} {String(lv.number).padStart(2, '0')}
                    </div>
                    <div class="text-xs text-gray-400 dark:text-gray-500 tabular-nums">
                      {leverProjectCount(lv)} {t(lang, 'leverProjectsSuffix')}
                    </div>
                  </div>
                  <div class="font-serif text-base md:text-lg font-semibold text-gray-900 dark:text-white group-hover:text-primary transition-colors mb-1">
                    {lv.icon} {pickLocalized(lv, 'name', 'nameEn', lang)}
                  </div>
                  <div class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">
                    {pickLocalized(lv, 'subtitle', 'subtitleEn', lang)}
                  </div>
                </a>
              ))
            }
          </div>
        </div>

        {/* Direct column (2 levers) */}
        <div class="md:border-l md:border-subtle md:pl-8">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-xs uppercase tracking-[0.18em] text-amber-700 dark:text-amber-400 font-semibold">
              {t(lang, 'leverMapColDirect')}
            </span>
            <span class="text-xs text-gray-400 dark:text-gray-500 tabular-nums">{directLevers.length}</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-4 leading-relaxed">
            {t(lang, 'leverMapColDirectHint')}
          </p>
          <div class="grid gap-y-5">
            {
              directLevers.map((lv) => (
                <a
                  href={`/en/levers/${leverSlug(lv)}/`}
                  class="group block border-l-2 border-amber-200 dark:border-amber-900/60 hover:border-amber-600 pl-4 py-1 transition-colors"
                >
                  <div class="flex items-baseline justify-between gap-2 mb-1">
                    <div class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 tabular-nums">
                      {t(lang, 'leverWord')} {String(lv.number).padStart(2, '0')}
                    </div>
                    <div class="text-xs text-gray-400 dark:text-gray-500 tabular-nums">
                      {leverProjectCount(lv)} {t(lang, 'leverProjectsSuffix')}
                    </div>
                  </div>
                  <div class="font-serif text-base md:text-lg font-semibold text-gray-900 dark:text-white group-hover:text-primary transition-colors mb-1">
                    {lv.icon} {pickLocalized(lv, 'name', 'nameEn', lang)}
                  </div>
                  <div class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">
                    {pickLocalized(lv, 'subtitle', 'subtitleEn', lang)}
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </div>

      <div class="mt-6 pt-6 border-t border-subtle text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
        {t(lang, 'transmissionFootnote')}{' '}
        <a href="/en/levers/" class="text-primary hover:text-secondary underline underline-offset-4">
          {t(lang, 'transmissionFootnoteCta')}
        </a>
      </div>
    </div>
  </section>

  {/* Freshness strip — pushed below the map; data breadth signal. */}
  <section class="border-y border-subtle">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-5">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-sm">
        <div>
          <div class="text-2xl font-serif font-semibold text-gray-900 dark:text-white tabular-nums">
            {totalPolicies}
          </div>
          <div class="text-gray-500 dark:text-gray-400 text-xs uppercase tracking-wider mt-1">
            {t(lang, 'freshnessPolicies')}
          </div>
        </div>
        <div>
          <div class="text-2xl font-serif font-semibold text-gray-900 dark:text-white tabular-nums">{totalDebates}</div>
          <div class="text-gray-500 dark:text-gray-400 text-xs uppercase tracking-wider mt-1">
            {t(lang, 'freshnessDebates')}
          </div>
        </div>
        <div>
          <div class="text-2xl font-serif font-semibold text-gray-900 dark:text-white tabular-nums">
            {totalLeverItems}
          </div>
          <div class="text-gray-500 dark:text-gray-400 text-xs uppercase tracking-wider mt-1">
            {t(lang, 'freshnessLevers')}
          </div>
        </div>
        <div>
          <div class="text-2xl font-serif font-semibold text-gray-900 dark:text-white tabular-nums">
            {SITE_UPDATED}
          </div>
          <div class="text-gray-500 dark:text-gray-400 text-xs uppercase tracking-wider mt-1">
            {t(lang, 'freshnessUpdated')}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex items-baseline justify-between mb-8">
        <h2 class="font-serif text-2xl md:text-3xl font-semibold text-gray-900 dark:text-white">
          {t(lang, 'latestAnalyses')}
        </h2>
        <a
          href="/en/blog/"
          class="text-sm text-gray-500 hover:text-primary dark:text-gray-400 transition-colors hidden sm:inline"
        >
          {t(lang, 'viewAll')}
        </a>
      </div>
      {
        latestPosts.length > 0 ? (
          <div class="grid gap-8 lg:grid-cols-[minmax(0,1.45fr)_minmax(280px,0.85fr)] lg:items-start">
            {featuredPost && (
              <article class="border-y border-subtle py-6 lg:py-8">
                <a href={getPermalink(featuredPost.permalink, 'post')} class="group block">
                  <div class="flex items-baseline gap-4 mb-3">
                    <span class="font-serif text-sm text-primary tabular-nums">01</span>
                    <span class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400">
                      {featuredPost.category?.title ?? 'Analysis'} ·{' '}
                      {new Date(featuredPost.publishDate).toLocaleDateString('en-SG', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      })}
                    </span>
                  </div>
                  <h3 class="font-serif text-2xl md:text-3xl font-semibold text-gray-900 dark:text-white mb-4 leading-snug group-hover:text-primary transition-colors">
                    {featuredPost.title}
                  </h3>
                  {featuredPost.excerpt && (
                    <p class="text-gray-600 dark:text-gray-400 leading-[1.9] max-w-2xl">{featuredPost.excerpt}</p>
                  )}
                </a>
              </article>
            )}
            {secondaryPosts.length > 0 && (
              <aside class="lg:border-l lg:border-subtle lg:pl-7">
                <div class="mb-3 text-xs uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">
                  Continue Reading
                </div>
                <ol class="divide-y divide-subtle">
                  {secondaryPosts.map((post, idx) => (
                    <li class="py-5 first:pt-0 last:pb-0">
                      <a href={getPermalink(post.permalink, 'post')} class="group block">
                        <div class="flex items-baseline gap-3 mb-2">
                          <span class="font-serif text-sm text-primary tabular-nums">
                            {String(idx + 2).padStart(2, '0')}
                          </span>
                          <span class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400">
                            {new Date(post.publishDate).toLocaleDateString('en-SG', {
                              month: 'short',
                              day: 'numeric',
                            })}
                          </span>
                        </div>
                        <h3 class="font-serif text-lg font-semibold text-gray-900 dark:text-white leading-snug group-hover:text-primary transition-colors">
                          {post.title}
                        </h3>
                        {post.excerpt && (
                          <p class="mt-3 text-sm text-gray-600 dark:text-gray-400 leading-[1.75] line-clamp-4">
                            {post.excerpt}
                          </p>
                        )}
                      </a>
                    </li>
                  ))}
                </ol>
              </aside>
            )}
          </div>
        ) : (
          <p class="text-gray-500 dark:text-gray-400 italic">
            English translations of the analysis archive are being added.
          </p>
        )
      }
      <div class="mt-8 sm:hidden">
        <a href="/en/blog/" class="text-sm text-primary hover:text-secondary font-medium">
          {t(lang, 'ctaBrowseAll')}
        </a>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 border-t border-subtle">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex items-baseline justify-between mb-2">
        <h2 class="font-serif text-2xl md:text-3xl font-semibold text-gray-900 dark:text-white">
          {t(lang, 'recentDebatesSection')}
        </h2>
        <a
          href="/en/debates/"
          class="text-sm text-gray-500 hover:text-primary dark:text-gray-400 transition-colors hidden sm:inline"
        >
          {t(lang, 'viewAllDebatesCta').replace('{count}', String(totalDebates))}
        </a>
      </div>
      <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-prose leading-relaxed">
        {
          t(lang, 'recentDebatesBlurb')
            .replace('{from}', String(DEBATE_STATS.yearRange.from))
            .replace('{to}', String(DEBATE_STATS.yearRange.to))
        }
      </p>
      <ul class="divide-y divide-gray-200 dark:divide-slate-800">
        {
          latestDebates.map((d) => (
            <li class="py-4">
              <a href={`/en/debates/${d.id}/`} class="group block">
                <div class="flex items-baseline gap-4">
                  <span class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 tabular-nums w-24 shrink-0">
                    {d.date}
                  </span>
                  <div class="flex-1 min-w-0">
                    <div class="font-medium text-gray-900 dark:text-white group-hover:text-primary transition-colors leading-snug">
                      {d.title}
                    </div>
                    <div class="text-xs text-gray-500 dark:text-gray-400 mt-1 truncate">
                      {d.type} · {d.topics.slice(0, 2).join(' · ')}
                    </div>
                  </div>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="py-12 md:py-20 border-t border-subtle">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="font-serif text-xl md:text-2xl text-gray-700 dark:text-gray-300 leading-[1.7] mb-6 italic">
        "{t(lang, 'closingThesis')}"
      </p>
      <a
        href="/en/singapore-ai-strategy-the-real-moat/"
        class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-secondary transition-colors underline underline-offset-4"
      >
        {t(lang, 'closingCta')}
        <Icon name="tabler:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </section>
</Layout>
