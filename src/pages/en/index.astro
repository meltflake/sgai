---
// Editorial homepage (en) — thin wrapper. All structure and copy live in
// `src/components/home/HomePage.astro`; this file supplies metadata + JSON-LD.
// To change the page layout, edit the shared component, not this file.

import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import HomePage from '~/components/home/HomePage.astro';
import { t } from '~/i18n';

const lang = 'en' as const;

const metadata = {
  title: t(lang, 'siteName'),
  ignoreTitleTemplate: true,
  description: t(lang, 'siteDescription'),
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: t(lang, 'siteName'),
  url: 'https://sgai.md/en/',
  logo: 'https://sgai.md/favicon.svg',
  description: t(lang, 'siteDescription'),
  sameAs: ['https://github.com/meltflake/sgai'],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: t(lang, 'siteName'),
  url: 'https://sgai.md/en/',
  inLanguage: 'en',
};
---

<Layout metadata={metadata} lang={lang}>
  <JsonLd schema={organizationSchema} />
  <JsonLd schema={websiteSchema} />
  <HomePage lang={lang} />
</Layout>
