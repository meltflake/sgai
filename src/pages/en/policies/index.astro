---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import RelatedRail from '~/components/data/RelatedRail.astro';
import { Icon } from 'astro-icon/components';
import { categories } from '~/data/policies';
import { t, pickLocalized, localizedHref } from '~/i18n';

const lang = 'en' as const;
---

<Layout
  metadata={{
    title: t(lang, 'policiesPageTitle'),
    description: t(lang, 'policiesPageBlurb'),
  }}
  breadcrumbs={[{ label: t(lang, 'navPolicies') }]}
  lang={lang}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-6xl">
    <Headline title={`📋 ${t(lang, 'policiesPageTitle')}`} subtitle={t(lang, 'policiesPageBlurb')} />

    {
      categories.map((cat) => (
        <div class="mb-12">
          <h2 class="t-h2 mb-6 border-b-2 border-blue-600 dark:border-blue-400 pb-2">
            {cat.icon} {pickLocalized(cat, 'name', lang)}
            <span class="text-sm font-normal text-muted ml-2">
              ({cat.policies.length} {t(lang, 'policiesItemsSuffix')})
            </span>
          </h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {cat.policies.map((policy) => {
              const title = pickLocalized(policy, 'title', lang) || policy.title;
              const showEnSubtitle = policy.titleEn && policy.titleEn !== title;
              return (
                <div class="bg-surface rounded-lg shadow-md p-6 border border-subtle hover:shadow-lg transition-shadow">
                  <h3 class="text-lg font-bold mb-1">
                    {policy.id ? (
                      <a
                        href={localizedHref(`/policies/${policy.id}/`, lang)}
                        class="hover:text-primary transition-colors"
                      >
                        {title}
                      </a>
                    ) : (
                      title
                    )}
                  </h3>
                  {showEnSubtitle && <p class="text-sm text-muted mb-2 italic">{policy.titleEn}</p>}
                  <div class="flex gap-2 mb-3 flex-wrap">
                    {policy.sourceOrgUrl ? (
                      <a
                        href={policy.sourceOrgUrl}
                        target="_blank"
                        rel="noopener"
                        class="text-xs bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 px-2 py-1 rounded hover:underline"
                      >
                        {pickLocalized(policy, 'source', lang)}
                      </a>
                    ) : (
                      <span class="text-xs bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 px-2 py-1 rounded">
                        {pickLocalized(policy, 'source', lang)}
                      </span>
                    )}
                    <span class="text-xs bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 px-2 py-1 rounded">
                      {policy.date}
                    </span>
                  </div>
                  <p class="text-sm font-medium mb-2">{pickLocalized(policy, 'summary', lang)}</p>
                  <p class="text-sm text-muted mb-3">{pickLocalized(policy, 'content', lang)}</p>
                  <div class="flex gap-2 flex-wrap">
                    {policy.sourceUrl && (
                      <a
                        href={policy.sourceUrl}
                        target="_blank"
                        rel="noopener"
                        class="inline-flex items-center gap-1 text-sm text-blue-600 dark:text-blue-400 hover:underline"
                      >
                        <Icon name="tabler:link" class="w-4 h-4" />
                        {t(lang, 'source')}
                      </a>
                    )}
                    {policy.pdfUrl && (
                      <a
                        href={policy.pdfUrl}
                        target="_blank"
                        rel="noopener"
                        class="inline-flex items-center gap-1 text-sm text-blue-600 dark:text-blue-400 hover:underline"
                      >
                        <Icon name="tabler:file-text" class="w-4 h-4" />
                        {t(lang, 'sourcePdf')}
                      </a>
                    )}
                    {policy.translatedPdfUrl && (
                      <a
                        href={policy.translatedPdfUrl}
                        target="_blank"
                        rel="noopener"
                        class="inline-flex items-center gap-1 text-sm text-green-600 dark:text-green-400 hover:underline"
                      >
                        <Icon name="tabler:language" class="w-4 h-4" />
                        {t(lang, 'translation')}
                      </a>
                    )}
                  </div>
                  {policy.id && <RelatedRail entity={{ type: 'policy', id: policy.id }} variant="compact" />}
                </div>
              );
            })}
          </div>
        </div>
      ))
    }
  </section>
</Layout>
