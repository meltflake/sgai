---
import type { GetStaticPaths } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import OpenSourceProjectDetail from '~/components/data/OpenSourceProjectDetail.astro';
import { openSourceProjects } from '~/data/opensource';

export const prerender = true;

export const getStaticPaths = (() => {
  return openSourceProjects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}) satisfies GetStaticPaths;

const { project } = Astro.props;
const lang = 'en' as const;
const name = project.nameEn || project.name;
---

<Layout
  metadata={{
    title: `${name} · Official Open Source & Research`,
    description: project.summaryEn || project.descriptionEn || project.description,
  }}
  breadcrumbs={[{ label: 'Official Open Source', href: '/en/opensource/' }, { label: name }]}
  lang={lang}
>
  <OpenSourceProjectDetail project={project} lang={lang} />
</Layout>
