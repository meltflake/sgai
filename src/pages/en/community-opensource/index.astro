---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import {
  universityProjects,
  corporateLabProjects,
  startupProjects,
  summary,
  dataDisclaimer,
  dataDisclaimerEn,
} from '~/data/community-opensource';

const lang = 'en' as const;
const note = summary.noteEn || summary.note;
const disclaimer = dataDisclaimerEn || dataDisclaimer;
---

<Layout
  metadata={{
    title: 'Community Open Source',
    description:
      "Singapore's community AI open-source ecosystem — universities, international corporate labs, and startups contributing to open source.",
  }}
  breadcrumbs={[{ label: 'Community Open Source' }]}
  lang={lang}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-6xl">
    <Headline
      title="🌐 Community Open Source"
      subtitle="AI open-source projects from Singapore's universities, international corporate labs, and startups."
    />

    <!-- Summary -->
    <div
      class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-4 mb-12 text-sm text-blue-800 dark:text-blue-200"
    >
      💡 {note}
    </div>

    <!-- Universities and research institutions -->
    <div class="mb-16">
      <h2 class="t-h2 mb-6">🎓 Universities &amp; Research Institutions</h2>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          universityProjects.map((proj) => (
            <div class="bg-surface rounded-lg shadow-md border border-subtle p-5 hover:shadow-lg transition-shadow">
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-bold">{proj.name}</h3>
                {proj.stars && (
                  <span class="text-xs text-muted whitespace-nowrap">⭐ {proj.stars.toLocaleString()}</span>
                )}
              </div>
              <p class="text-xs text-blue-600 dark:text-blue-400 mb-2">{proj.org}</p>
              <p class="text-sm text-muted mb-3">{proj.descriptionEn || proj.description}</p>
              <div class="flex items-center gap-2 flex-wrap">
                {proj.papers &&
                  proj.papers.map((p) => (
                    <span class="text-xs bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 px-2 py-0.5 rounded">
                      {p}
                    </span>
                  ))}
                {proj.url ? (
                  <a
                    href={proj.url}
                    target="_blank"
                    rel="noopener"
                    class="text-sm text-blue-600 dark:text-blue-400 hover:underline ml-auto"
                  >
                    GitHub →
                  </a>
                ) : (
                  <span class="text-xs text-muted ml-auto">No public repository</span>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Corporate labs in Singapore -->
    <div class="mb-16">
      <h2 class="t-h2 mb-6">🏢 International Corporate Labs in Singapore</h2>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          corporateLabProjects.map((proj) => (
            <div class="bg-surface rounded-lg shadow-md border border-subtle p-5 hover:shadow-lg transition-shadow">
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-bold">{proj.name}</h3>
                {proj.stars && (
                  <span class="text-xs text-muted whitespace-nowrap">⭐ {proj.stars.toLocaleString()}</span>
                )}
              </div>
              <p class="text-xs text-blue-600 dark:text-blue-400 mb-2">{proj.org}</p>
              <p class="text-sm text-muted mb-3">{proj.descriptionEn || proj.description}</p>
              <div class="flex items-center gap-2 flex-wrap">
                {proj.papers &&
                  proj.papers.map((p) => (
                    <span class="text-xs bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 px-2 py-0.5 rounded">
                      {p}
                    </span>
                  ))}
                {proj.url && (
                  <a
                    href={proj.url}
                    target="_blank"
                    rel="noopener"
                    class="text-sm text-blue-600 dark:text-blue-400 hover:underline ml-auto"
                  >
                    GitHub →
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Startups -->
    <div class="mb-16">
      <h2 class="t-h2 mb-6">🚀 Startups</h2>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          startupProjects.map((proj) => (
            <div class="bg-surface rounded-lg shadow-md border border-subtle p-5 hover:shadow-lg transition-shadow">
              <div class="flex items-start justify-between mb-2">
                <h3 class="font-bold">{proj.name}</h3>
                {proj.stars && (
                  <span class="text-xs text-muted whitespace-nowrap">⭐ {proj.stars.toLocaleString()}</span>
                )}
              </div>
              <p class="text-xs text-blue-600 dark:text-blue-400 mb-2">{proj.org}</p>
              <p class="text-sm text-muted mb-3">{proj.descriptionEn || proj.description}</p>
              {proj.url && (
                <a
                  href={proj.url}
                  target="_blank"
                  rel="noopener"
                  class="text-sm text-blue-600 dark:text-blue-400 hover:underline"
                >
                  GitHub →
                </a>
              )}
            </div>
          ))
        }
      </div>
    </div>

    <!-- Data note -->
    <p class="mt-12 text-sm text-muted text-center">{disclaimer}</p>
  </section>
</Layout>
