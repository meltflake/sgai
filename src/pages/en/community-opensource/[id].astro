---
import type { GetStaticPaths } from 'astro';

import JsonLd from '~/components/common/JsonLd.astro';
import CommunityOpenSourceProjectDetail from '~/components/data/CommunityOpenSourceProjectDetail.astro';
import Layout from '~/layouts/PageLayout.astro';
import { allCommunityOpenSourceProjects, type OpenSourceProject } from '~/data/community-opensource';

export const prerender = true;

export const getStaticPaths = (() =>
  allCommunityOpenSourceProjects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }))) satisfies GetStaticPaths;

interface Props {
  project: OpenSourceProject;
}

const lang = 'en' as const;
const { project } = Astro.props as Props;
const name = project.nameEn || project.name;
const description = project.summaryEn || project.descriptionEn || project.description;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `${name} · ${project.orgEn || project.org}`,
  description,
  inLanguage: 'en',
  mainEntityOfPage: new URL(Astro.url).href,
  about: name,
  isBasedOn: project.resources.map((resource) => resource.url),
  publisher: {
    '@type': 'Organization',
    name: 'Singapore AI Observatory',
    url: 'https://sgai.md/en/',
  },
};
---

<Layout
  metadata={{
    title: `${name} · Community Open Source`,
    description,
  }}
  breadcrumbs={[{ label: 'Community Open Source', href: '/en/community-opensource/' }, { label: name }]}
  lang={lang}
>
  <JsonLd schema={schema} />
  <CommunityOpenSourceProjectDetail project={project} lang={lang} />
</Layout>
