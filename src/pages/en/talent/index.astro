---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import { programmes } from '~/data/talent';

const lang = 'en' as const;
---

<Layout
  metadata={{
    title: 'Talent Pipeline',
    description:
      "Singapore's AI talent pipeline — university programmes, government-led training schemes, and talent attraction policies in one view.",
  }}
  breadcrumbs={[{ label: 'Talent Pipeline' }]}
  lang={lang}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-6xl">
    <Headline
      title="🎓 AI Talent Pipeline"
      subtitle="Singapore's full-spectrum AI talent system — from students to PhDs, beginners to experts, covering every stage of the AI career path."
    />

    <div class="grid gap-8 md:grid-cols-2">
      {
        programmes.map((prog) => (
          <div class="bg-surface rounded-lg shadow-md border border-subtle hover:shadow-lg transition-shadow overflow-hidden">
            <div class="p-6">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <h3 class="t-h3">
                    {prog.icon} {prog.nameEn}
                  </h3>
                </div>
                {(prog.statusEn || prog.status) && (
                  <span class="text-xs font-medium bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 px-2 py-1 rounded whitespace-nowrap">
                    {prog.statusEn || prog.status}
                  </span>
                )}
              </div>
              <p class="text-sm mb-4">{prog.descriptionEn || prog.description}</p>

              {/* Key stats */}
              <div class="grid grid-cols-2 gap-2 mb-4">
                {prog.stats.map((stat) => (
                  <div class="bg-slate-50 dark:bg-slate-800 rounded p-2 text-center">
                    <div class="text-lg font-bold text-blue-600 dark:text-blue-400">{stat.valueEn || stat.value}</div>
                    <div class="text-xs text-muted">{stat.labelEn || stat.label}</div>
                  </div>
                ))}
              </div>

              {/* Highlights */}
              <ul class="text-sm space-y-1">
                {(prog.highlightsEn && prog.highlightsEn.length ? prog.highlightsEn : prog.highlights).map((h) => (
                  <li class="flex items-start gap-2">
                    <span class="text-blue-600 dark:text-blue-400 mt-0.5">•</span>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>

              {prog.url && (
                <a
                  href={prog.url}
                  target="_blank"
                  rel="noopener"
                  class="inline-block mt-4 text-sm text-blue-600 dark:text-blue-400 hover:underline"
                >
                  Learn more →
                </a>
              )}
            </div>
          </div>
        ))
      }
    </div>

    <p class="mt-12 text-sm text-muted text-center">
      Source: AI Singapore. Programme details and intake status are best confirmed on the official website.
    </p>
  </section>
</Layout>
