---
import { Icon } from 'astro-icon/components';

import Headline from '~/components/ui/Headline.astro';
import Layout from '~/layouts/PageLayout.astro';
import { programmes, talentDataDate, type TalentStatusTone } from '~/data/talent';

const lang = 'en' as const;

const statusClasses: Record<TalentStatusTone, string> = {
  active: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-200',
  scheduled: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-200',
  closed: 'bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300',
  evergreen: 'bg-teal-100 text-teal-800 dark:bg-teal-900/30 dark:text-teal-200',
};
---

<Layout
  metadata={{
    title: 'Talent Pipeline',
    description:
      "Singapore's AI talent pipeline — university programmes, government-led training schemes, and talent attraction policies in one view.",
  }}
  breadcrumbs={[{ label: 'Talent Pipeline' }]}
  lang={lang}
>
  <section class="px-4 py-14 sm:px-6 mx-auto lg:px-8 max-w-6xl">
    <Headline
      title="AI Talent Pipeline"
      subtitle="Singapore's AI talent system is not a single path. It is a set of trackable project entry points: students, educators, career switchers, enterprise teams, and research talent from undergraduate to PhD."
    />

    <div class="grid gap-5 md:grid-cols-2">
      {
        programmes.map((prog) => (
          <a
            href={`/en/talent/${prog.id}/`}
            class="group flex h-full flex-col bg-surface rounded-lg border border-subtle shadow-sm hover:shadow-md hover:border-primary/40 transition-all overflow-hidden focus-visible:outline-primary"
          >
            <div class="p-5 sm:p-6 flex-1 flex flex-col">
              <div class="flex items-start justify-between gap-4 mb-4">
                <div class="flex gap-3 min-w-0">
                  <div class="w-11 h-11 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0">
                    <Icon name={prog.icon} class="w-6 h-6" />
                  </div>
                  <div class="min-w-0">
                    <p class="text-xs uppercase tracking-[0.14em] text-muted font-semibold mb-1">{prog.categoryEn}</p>
                    <h3 class="font-serif text-xl font-semibold leading-snug text-gray-900 dark:text-white">
                      {prog.nameEn}
                    </h3>
                    {prog.shortName && <p class="text-sm text-muted mt-1">{prog.shortName}</p>}
                  </div>
                </div>
                <span
                  class={`text-xs font-medium px-2.5 py-1 rounded whitespace-nowrap ${statusClasses[prog.statusTone]}`}
                >
                  {prog.statusEn}
                </span>
              </div>

              <p class="text-sm leading-relaxed text-gray-700 dark:text-gray-300 mb-5">{prog.descriptionEn}</p>

              <div class="grid grid-cols-2 gap-2 mb-5">
                {prog.stats.slice(0, 4).map((stat) => (
                  <div class="rounded-md bg-slate-50 dark:bg-slate-800/70 p-3">
                    <div class="text-base font-semibold text-gray-900 dark:text-white">
                      {stat.valueEn || stat.value}
                    </div>
                    <div class="text-xs text-muted mt-1">{stat.labelEn || stat.label}</div>
                  </div>
                ))}
              </div>

              <ul class="text-sm space-y-2 mb-5">
                {prog.highlightsEn.slice(0, 3).map((h) => (
                  <li class="flex items-start gap-2 text-gray-700 dark:text-gray-300">
                    <Icon name="tabler:check" class="w-4 h-4 mt-0.5 text-primary shrink-0" />
                    <span>{h}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-auto pt-4 border-t border-subtle flex items-center justify-between gap-3">
                <span class="text-xs text-muted">{prog.ownerEn}</span>
                <span class="inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:text-secondary">
                  Open profile
                  <Icon name="tabler:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-0.5" />
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <p class="mt-10 text-sm text-muted text-center">
      Sources: official AI Singapore, LearnAI, AIAP, NAISC and IOAI pages. Checked by this site on {talentDataDate}.
    </p>
  </section>
</Layout>
