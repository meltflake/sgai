---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import { sections } from '~/data/references';

const lang = 'en' as const;
---

<Layout
  metadata={{
    title: 'References',
    description:
      "Singapore AI references — official documents, research reports, news coverage, and analytical reading on Singapore's AI policy.",
  }}
  breadcrumbs={[{ label: 'References' }]}
  lang={lang}
>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 max-w-4xl">
    <Headline
      title="📚 Reference Library"
      subtitle="Official documents, research reports, news coverage, and analytical reading on Singapore's AI policy."
    />

    <div class="space-y-8">
      {
        sections.map((section) => (
          <div>
            <h2 class="t-h3 mb-3">
              {section.icon} {section.titleEn || section.title}
            </h2>
            <ul class="space-y-2">
              {section.links.map((link) => (
                <li class="flex items-start gap-2">
                  <span class="text-blue-500 mt-1">•</span>
                  <div>
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener"
                      class="text-blue-600 dark:text-blue-400 hover:underline"
                    >
                      {link.textEn || link.text}
                    </a>
                    {link.translation && (
                      <a
                        href={link.translation}
                        class="text-sm text-green-600 dark:text-green-400 hover:underline ml-2"
                      >
                        [Chinese translation]
                      </a>
                    )}
                    {(link.noteEn || link.note) && (
                      <span class="text-sm text-muted ml-2">— {link.noteEn || link.note}</span>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <p class="mt-8 text-sm text-muted">30+ references; the list grows over time. Submit additions on GitHub.</p>
  </section>
</Layout>
