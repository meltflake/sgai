---
import type { GetStaticPaths } from 'astro';
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import JsonLd from '~/components/common/JsonLd.astro';
import { mddiSpeeches, type MddiSpeech } from '~/data/voices';
import {
  speechId,
  getSpeechTranscript,
  getSpeechTranscriptParagraphs,
  getSpeechTranscriptTldr,
} from '~/data/speech-transcripts';
import { findPersonId } from '~/utils/people';
import { pickLocalized } from '~/i18n';

export const prerender = true;

const lang = 'en' as const;

export const getStaticPaths = (() =>
  mddiSpeeches.map((speech) => ({
    params: { id: speechId(speech) },
    props: { speech },
  }))) satisfies GetStaticPaths;

interface Props {
  speech: MddiSpeech;
}

const { speech } = Astro.props;
const id = speechId(speech);
const transcript = getSpeechTranscript(id);
const paragraphsEn = getSpeechTranscriptParagraphs(id, 'en');
const tldrEn = getSpeechTranscriptTldr(id, 'en');

const speakerPid = findPersonId(speech.speaker);
const speakerTitle = pickLocalized(speech, 'speakerTitle', 'speakerTitleEn', lang);

const metadata = {
  title: `${speech.title} · MDDI Speech`,
  description: speech.title,
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: speech.title,
  datePublished: speech.date,
  inLanguage: 'en',
  author: { '@type': 'Person', name: speech.speaker },
  publisher: {
    '@type': 'GovernmentOrganization',
    name: 'Ministry of Digital Development and Information',
    url: 'https://www.mddi.gov.sg/',
  },
};

const breadcrumbs = [{ label: 'AI Influence Map', href: '/en/voices/' }, { label: speech.title }];
---

<Layout metadata={metadata} breadcrumbs={breadcrumbs}>
  <JsonLd schema={articleSchema} />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <p class="text-xs uppercase tracking-[0.18em] text-primary font-semibold mb-4">
      MDDI Speech · {speech.date}
    </p>
    <h1 class="font-serif text-2xl md:text-4xl leading-tight font-semibold text-gray-900 dark:text-white mb-6">
      {speech.title}
    </h1>

    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-600 dark:text-gray-400 mb-8">
      {
        speakerPid ? (
          <a href={`/en/voices/${speakerPid}/`} class="font-medium text-primary hover:text-secondary">
            {speech.speaker}
          </a>
        ) : (
          <span class="font-medium text-gray-700 dark:text-gray-300">{speech.speaker}</span>
        )
      }
      <span class="text-gray-300 dark:text-gray-600">·</span>
      <span>{speakerTitle}</span>
      {
        speech.event && (
          <>
            <span class="text-gray-300 dark:text-gray-600">·</span>
            <span class="italic">{speech.event}</span>
          </>
        )
      }
    </div>

    {
      tldrEn && tldrEn.length > 0 && (
        <section class="mb-8 border-l-4 border-primary pl-5" data-i18n-allow-cjk="speech-verbatim-source">
          <h2 class="text-xs uppercase tracking-wider text-primary font-semibold mb-2">Key takeaways</h2>
          <ul class="space-y-2 text-base text-gray-700 dark:text-gray-300 leading-[1.85]">
            {tldrEn.map((point) => (
              <li class="flex gap-3">
                <span class="text-primary shrink-0 mt-1">•</span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      paragraphsEn.length > 0 ? (
        <section
          class="my-8 border border-primary/20 bg-primary/5 rounded-xl p-5"
          data-i18n-allow-cjk="speech-verbatim-source"
        >
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-4">
            <h2 class="font-serif text-xl font-semibold text-gray-900 dark:text-white">Full speech</h2>
            <p class="text-xs text-gray-500 dark:text-gray-400">
              Archived from mddi.gov.sg
              {transcript?.fetchedAt && ` · Fetched ${transcript.fetchedAt}`}
            </p>
          </div>
          <div class="space-y-4 text-base text-gray-700 dark:text-gray-300 leading-[1.9]">
            {paragraphsEn.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </section>
      ) : (
        <section class="my-8 callout-muted rounded-xl p-5 text-sm text-amber-900 dark:text-amber-200">
          Local archive not yet available. Please read the original on the
          <a href={speech.url} target="_blank" rel="noopener" class="underline mx-1">
            MDDI website
          </a>
          . We are progressively archiving full text and translations for all AI-related MDDI speeches.
        </section>
      )
    }

    <div class="mt-10 flex flex-wrap gap-3">
      <a
        href={speech.url}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-secondary border border-primary/30 hover:border-primary px-4 py-2 rounded-md transition-colors"
      >
        <Icon name="tabler:external-link" class="w-4 h-4" />
        Source on mddi.gov.sg
      </a>
    </div>

    <nav class="mt-12 pt-6 border-t border-subtle">
      <a
        href="/en/voices/"
        class="text-sm text-primary hover:text-secondary font-medium inline-flex items-center gap-1"
      >
        <Icon name="tabler:arrow-left" class="w-4 h-4" />
        Back to AI Influence Map
      </a>
    </nav>
  </article>
</Layout>
