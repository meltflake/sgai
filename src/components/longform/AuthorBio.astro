---
// Phase 2.3 — Author bio block at the end of long-form posts.
//
// Resolution order (frontmatter `author` is authoritative; never infer
// authorship from `relatedPersonIds`, which exists for cross-reference,
// not attribution — politicians cited in a post are not its authors):
//   1. If `author` matches a Person by name (via findPersonId),
//      render full Person card.
//   2. Else if `author` exists, render minimal byline with the string.
//   3. Else render nothing.
//
// SAFE: emits empty fragment when nothing to render.

import { getPerson, findPersonId } from '~/utils/people';
import type { Person } from '~/data/people';
import { getLangFromPath, localizedHref, channelLabel, pickLocalized } from '~/i18n';

interface Props {
  author?: string;
  /** Accepted for API compatibility but intentionally unused for attribution. */
  relatedPersonIds?: string[];
  class?: string;
}

const { author, class: extraClass = '' } = Astro.props;
const lang = getLangFromPath(new URL(Astro.url).pathname);

let person: Person | undefined;
if (author) {
  const id = findPersonId(author);
  if (id) person = getPerson(id);
}

const hasContent = !!person || !!author;
const isStub = person && (!person.summary || person.summary.startsWith('[需补充]'));

const personName = person ? (lang === 'en' ? person.name : person.name || person.name) : '';
const personTitle = person ? pickLocalized(person, 'title', 'title', lang) : '';
const personSummary = person ? pickLocalized(person, 'summary', 'summaryEn', lang) : '';
const initialsSeed = person ? personName : author || '';
const authorLabel = lang === 'en' ? 'Author' : '作者';

const initials =
  initialsSeed.replace(/[A-Za-z]+\s*/g, '').slice(0, 2) || initialsSeed.replace(/\s+/g, '').slice(0, 2) || '·';
---

{
  hasContent && (
    <aside class={`mt-12 mb-4 max-w-3xl mx-auto px-4 sm:px-6 ${extraClass}`} aria-label="Author">
      <div class="flex items-start gap-4 p-5 rounded-xl border border-subtle bg-gray-50 dark:bg-slate-800/40">
        <div
          aria-hidden="true"
          class="shrink-0 w-12 h-12 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 text-white flex items-center justify-center font-semibold text-sm select-none"
        >
          {initials}
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 mb-1">{authorLabel}</p>
          {person ? (
            <a
              href={localizedHref(`/voices/${person.id}/`, lang)}
              class="text-base font-bold text-gray-800 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
            >
              {personName}
            </a>
          ) : (
            <p class="text-base font-bold text-gray-800 dark:text-white">{author}</p>
          )}
          {person && personTitle && <p class="text-sm text-gray-600 dark:text-gray-300 mt-0.5">{personTitle}</p>}
          {person && !isStub && personSummary && (
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-2 leading-relaxed">{personSummary}</p>
          )}
          {person && person.channels && person.channels.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-3">
              {person.channels.slice(0, 4).map((ch) => (
                <a
                  href={ch.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs text-blue-600 dark:text-blue-400 hover:underline"
                >
                  {channelLabel(ch, lang)}
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </aside>
  )
}
