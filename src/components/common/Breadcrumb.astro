---
import { SITE } from 'astrowind:config';
import { getLangFromPath, localizedHref, t } from '~/i18n';

export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const lang = getLangFromPath(new URL(Astro.url).pathname);
const homeLabel = t(lang, 'navHome');
const homeHref = localizedHref('/', lang);
const homeItem = { label: homeLabel, href: homeHref };
const allItems = [homeItem, ...items];

const siteUrl = SITE?.site || 'https://sgai.md';
const currentUrl = `${siteUrl}${Astro.url.pathname}`;

const jsonLdItems = allItems
  .map((item) => ({ item, name: typeof item.label === 'string' ? item.label.trim() : '' }))
  .filter(({ name }) => name.length > 0)
  .map(({ item, name }, position) => ({
    '@type': 'ListItem',
    position: position + 1,
    name,
    item: item.href ? `${siteUrl}${item.href}` : currentUrl,
  }));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: jsonLdItems,
};
---

<nav aria-label="Breadcrumb" class="max-w-6xl mx-auto px-4 sm:px-6 pt-4 pb-2">
  <ol class="flex flex-wrap items-center gap-1 text-sm text-gray-500 dark:text-gray-400">
    {
      allItems.map((crumb, index) => (
        <li class="flex items-center">
          {index > 0 && <span class="mx-1">/</span>}
          {crumb.href && index < allItems.length - 1 ? (
            <a href={crumb.href} class="hover:text-primary dark:hover:text-blue-400 transition-colors">
              {crumb.label}
            </a>
          ) : (
            <span class="text-gray-700 dark:text-gray-300">{crumb.label}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
