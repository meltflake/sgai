---
// i18n — non-intrusive language hint banner.
//
// Behaviour:
//  - SSR-renders hidden. Client-side reveals it only when the visitor's
//    browser language disagrees with the current page AND no `sgai_lang`
//    localStorage choice is set.
//  - NEVER auto-redirects. URL paths are the source of truth.
//  - Supports all 3 locales (en/zh/ja). Suggests the best matching locale
//    from the browser's language preferences.

import { type Lang, LOCALES, t } from '~/i18n';

interface Props {
  currentLang: Lang;
}

const { currentLang } = Astro.props;

const BANNER_MESSAGES: Record<Lang, string> = {
  en: t('en', 'langBannerEn') || 'English version available',
  zh: '中文版可用',
  ja: '日本語版があります',
};
const SWITCH_LABELS: Record<Lang, string> = {
  en: t('en', 'langBannerSwitch') || 'Read in English →',
  zh: '阅读中文版 →',
  ja: '日本語で読む →',
};
const dismissLabel = t(currentLang, 'langBannerDismiss') || '关闭';
const localesJson = JSON.stringify(LOCALES.filter((l) => l !== currentLang));
---

<div
  id="lang-banner"
  data-current-lang={currentLang}
  data-suggest-locales={localesJson}
  class="hidden bg-primary/5 dark:bg-primary/10 border-b border-primary/20"
  aria-live="polite"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-2 flex items-center justify-between gap-4 text-sm">
    <span class="text-gray-700 dark:text-gray-300">
      <span class="font-medium" id="lang-banner-msg"></span>
    </span>
    <div class="flex items-center gap-3 shrink-0">
      <a
        id="lang-banner-switch"
        href="#"
        class="text-primary hover:text-secondary font-semibold underline-offset-4 hover:underline"></a>
      <button
        type="button"
        id="lang-banner-dismiss"
        class="text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-200"
        aria-label={dismissLabel}
      >
        {dismissLabel}
      </button>
    </div>
  </div>
</div>

<script define:vars={{ BANNER_MESSAGES, SWITCH_LABELS }}>
  (() => {
    const banner = document.getElementById('lang-banner');
    if (!banner) return;
    const currentLang = banner.dataset.currentLang;
    const candidates = JSON.parse(banner.dataset.suggestLocales || '[]');

    function localeUrl(targetLang) {
      const path = location.pathname;
      let bare = path;
      if (path === '/zh' || path === '/zh/') bare = '/';
      else if (path.startsWith('/zh/')) bare = path.slice(3);
      else if (path === '/ja' || path === '/ja/') bare = '/';
      else if (path.startsWith('/ja/')) bare = path.slice(3);
      if (targetLang === 'en') return bare;
      if (bare === '/' || bare === '') return '/' + targetLang + '/';
      return '/' + targetLang + bare;
    }

    const stored = localStorage.getItem('sgai_lang');
    if (stored) return;

    const prefs = (navigator.languages?.length ? navigator.languages : [navigator.language]).map((l) =>
      l.toLowerCase()
    );
    const prefersCurrent = prefs.some((p) => p.startsWith(currentLang));
    if (prefersCurrent) return;

    const suggestLang = candidates.find((lang) => prefs.some((p) => p.startsWith(lang)));
    if (!suggestLang) return;

    document.getElementById('lang-banner-msg').textContent = BANNER_MESSAGES[suggestLang] || '';
    const switchEl = document.getElementById('lang-banner-switch');
    switchEl.textContent = SWITCH_LABELS[suggestLang] || '';
    banner.classList.remove('hidden');

    switchEl?.addEventListener('click', (e) => {
      e.preventDefault();
      localStorage.setItem('sgai_lang', suggestLang);
      location.assign(localeUrl(suggestLang));
    });
    document.getElementById('lang-banner-dismiss')?.addEventListener('click', () => {
      localStorage.setItem('sgai_lang', currentLang);
      banner.classList.add('hidden');
    });
  })();
</script>
