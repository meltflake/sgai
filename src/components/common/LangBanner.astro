---
// i18n (v0.4.0) — non-intrusive language hint banner.
//
// Behaviour:
//  - SSR-renders hidden. Client-side reveals it only when the visitor's
//    browser language disagrees with the current page AND no `sgai_lang`
//    localStorage choice is set.
//  - NEVER auto-redirects. The Phase-2 routing migration (en root + /zh/)
//    relies on URL paths as the source of truth — we don't override the
//    user's chosen URL silently. The banner offers a manual switch and
//    persists the dismissal.
//
// Sibling-URL math is centralised here so the routing convention
// (/zh/<path> vs /<path>) lives in one place.

import { type Lang, t } from '~/i18n';

interface Props {
  currentLang: Lang;
}

const { currentLang } = Astro.props;
const otherLang: Lang = currentLang === 'en' ? 'zh' : 'en';

const message = otherLang === 'en' ? t(otherLang, 'langBannerEn') : '中文版可用';
const switchLabel = otherLang === 'en' ? t(otherLang, 'langBannerSwitch') : '阅读中文版 →';
const dismissLabel = currentLang === 'en' ? t(currentLang, 'langBannerDismiss') : '关闭';
---

<div
  id="lang-banner"
  data-current-lang={currentLang}
  data-other-lang={otherLang}
  class="hidden bg-primary/5 dark:bg-primary/10 border-b border-primary/20"
  aria-live="polite"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-2 flex items-center justify-between gap-4 text-sm">
    <span class="text-gray-700 dark:text-gray-300">
      <span class="font-medium">{message}</span>
    </span>
    <div class="flex items-center gap-3 shrink-0">
      <a
        id="lang-banner-switch"
        href="#"
        class="text-primary hover:text-secondary font-semibold underline-offset-4 hover:underline"
      >
        {switchLabel}
      </a>
      <button
        type="button"
        id="lang-banner-dismiss"
        class="text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-200"
        aria-label={dismissLabel}
      >
        {dismissLabel}
      </button>
    </div>
  </div>
</div>

<script>
  (() => {
    const banner = document.getElementById('lang-banner') as HTMLElement | null;
    if (!banner) return;
    const currentLang = banner.dataset.currentLang as 'zh' | 'en';
    const otherLang = banner.dataset.otherLang as 'zh' | 'en';

    // Routing convention (post-Phase-2): EN is route default at '/<path>',
    // ZH is at '/zh/<path>'. Compute the sibling URL accordingly.
    function siblingUrl(): string {
      const path = location.pathname;
      if (otherLang === 'zh') {
        // Currently on EN — switch to ZH variant by prefixing /zh.
        if (path === '/' || path === '') return '/zh/';
        return '/zh' + path;
      }
      // Currently on ZH — switch to EN by stripping /zh.
      if (path === '/zh' || path === '/zh/') return '/';
      if (path.startsWith('/zh/')) return path.slice(3);
      return path;
    }

    // Show only when the visitor's browser language clearly prefers the
    // other locale AND they haven't pinned a preference yet. No silent
    // redirect — the user's URL choice always wins.
    const stored = localStorage.getItem('sgai_lang');
    const shouldSuggest = (() => {
      if (stored) return false;
      const prefs = (navigator.languages?.length ? navigator.languages : [navigator.language]).map((l) =>
        l.toLowerCase()
      );
      const prefersOther = prefs.some((p) => p.startsWith(otherLang));
      const prefersCurrent = prefs.some((p) => p.startsWith(currentLang));
      return prefersOther && !prefersCurrent;
    })();
    if (shouldSuggest) banner.classList.remove('hidden');

    document.getElementById('lang-banner-switch')?.addEventListener('click', (e) => {
      e.preventDefault();
      localStorage.setItem('sgai_lang', otherLang);
      location.assign(siblingUrl());
    });
    document.getElementById('lang-banner-dismiss')?.addEventListener('click', () => {
      localStorage.setItem('sgai_lang', currentLang);
      banner.classList.add('hidden');
    });
  })();
</script>
