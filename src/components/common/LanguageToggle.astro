---
// i18n — header language toggle.
//
// Renders a small ZH ↔ EN switch. Clicking it navigates to the equivalent
// URL in the other locale and persists the choice in localStorage.
//
// IMPORTANT: uses document-level event delegation because Astro's
// <ClientRouter> swaps the DOM during view transitions; per-element
// listeners would be lost after the first navigation.

import { type Lang, t } from '~/i18n';

interface Props {
  currentLang: Lang;
  /** Optional class on the wrapper. */
  class?: string;
}

const { currentLang, class: extraClass = '' } = Astro.props;
const otherLang: Lang = currentLang === 'en' ? 'zh' : 'en';
const otherLabel = otherLang === 'en' ? 'EN' : '中';
const ariaLabel = currentLang === 'en' ? t(currentLang, 'langToggleLabel') : '切换语言';
---

<button
  type="button"
  data-lang-toggle
  data-other-lang={otherLang}
  aria-label={ariaLabel}
  title={ariaLabel}
  class={`inline-flex items-center text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 hover:text-primary border border-subtle hover:border-primary rounded-md px-2 py-1.5 min-w-[2rem] justify-center transition-colors ${extraClass}`}
>
  <span aria-hidden="true">{otherLabel}</span>
  <span class="sr-only">{ariaLabel}</span>
</button>

<script is:inline>
  // Document-level delegation: bound once, survives ClientRouter swaps.
  if (!window.__sgaiLangToggleBound) {
    window.__sgaiLangToggleBound = true;
    document.addEventListener('click', function (e) {
      const target = e.target;
      if (!(target instanceof Element)) return;
      const btn = target.closest('[data-lang-toggle]');
      if (!btn) return;
      const otherLang = btn.getAttribute('data-other-lang');
      if (otherLang !== 'zh' && otherLang !== 'en') return;
      try {
        localStorage.setItem('sgai_lang', otherLang);
      } catch {
        /* private mode */
      }
      const path = location.pathname;
      let dest;
      if (otherLang === 'en') {
        dest = path === '/' || path === '' ? '/en/' : '/en' + path;
      } else {
        if (path === '/en' || path === '/en/') dest = '/';
        else if (path.indexOf('/en/') === 0) dest = path.slice(3);
        else dest = path;
      }
      location.assign(dest + location.search + location.hash);
    });
  }
</script>
