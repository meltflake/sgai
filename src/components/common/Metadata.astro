---
import merge from 'lodash.merge';
import { AstroSeo } from '@astrolib/seo';

import type { Props as AstroSeoProps } from '@astrolib/seo';

import { METADATA, I18N } from 'astrowind:config';
import type { MetaData } from '~/types';
import { getCanonical } from '~/utils/permalinks';
import { DEFAULT_LOCALE, getLangFromPath, t, type Lang } from '~/i18n';

import { adaptOpenGraphImages } from '~/utils/images';

export interface Props extends MetaData {
  dontUseTitleTemplate?: boolean;
  /** Override detected lang. Layout passes this so /* pages get the
   *  English siteName, og:locale, and title template. */
  lang?: Lang;
}

const {
  title,
  ignoreTitleTemplate = false,
  canonical = String(getCanonical(String(Astro.url.pathname))),
  robots = {},
  description,
  openGraph = {},
  twitter = {},
  lang: langOverride,
} = Astro.props;

const lang: Lang = langOverride ?? getLangFromPath(String(Astro.url.pathname));
const siteName = t(lang, 'siteName');
// og:locale uses BCP 47 with underscore (Facebook spec). Map per Lang.
const OG_LOCALES: Record<Lang, string> = { zh: 'zh_CN', en: 'en_US', ja: 'ja_JP' };
const ogLocale = OG_LOCALES[lang] ?? OG_LOCALES.en;
const hasDefaultOgImage = Boolean(METADATA?.openGraph?.images?.length);
const hasPageOgImage = Boolean(openGraph?.images?.length);
// Localized title template + default. The YAML METADATA config holds the
// zh (DEFAULT_LOCALE) defaults; non-default locales source title /
// description from the dictionary.
const isDefaultLocale = lang === DEFAULT_LOCALE;
const defaultTitle = isDefaultLocale ? (METADATA?.title?.default ?? siteName) : siteName;
const titleTemplate = isDefaultLocale ? (METADATA?.title?.template ?? `%s — ${siteName}`) : `%s — ${siteName}`;
const localizedDescription = isDefaultLocale ? (METADATA?.description ?? '') : t(lang, 'siteDescription');

const seoProps: AstroSeoProps = merge(
  {
    title: '',
    titleTemplate: '%s',
    canonical: canonical,
    noindex: true,
    nofollow: true,
    description: undefined,
    openGraph: {
      url: canonical,
      site_name: siteName,
      images: [],
      locale: ogLocale || I18N?.language || 'en',
      type: 'website',
    },
    twitter: {
      cardType: hasPageOgImage || hasDefaultOgImage ? 'summary_large_image' : 'summary',
    },
  },
  {
    title: defaultTitle,
    titleTemplate: titleTemplate,
    noindex: typeof METADATA?.robots?.index !== 'undefined' ? !METADATA.robots.index : undefined,
    nofollow: typeof METADATA?.robots?.follow !== 'undefined' ? !METADATA.robots.follow : undefined,
    description: localizedDescription,
    openGraph: METADATA?.openGraph ? { ...METADATA.openGraph, site_name: siteName, locale: ogLocale } : undefined,
    twitter: METADATA?.twitter,
  },
  {
    title: title,
    titleTemplate: ignoreTitleTemplate ? '%s' : undefined,
    canonical: canonical,
    noindex: typeof robots?.index !== 'undefined' ? !robots.index : undefined,
    nofollow: typeof robots?.follow !== 'undefined' ? !robots.follow : undefined,
    description: description,
    openGraph: { url: canonical, site_name: siteName, locale: ogLocale, ...openGraph },
    twitter: twitter,
  }
);
---

<AstroSeo {...{ ...seoProps, openGraph: await adaptOpenGraphImages(seoProps?.openGraph, Astro.site) }} />
