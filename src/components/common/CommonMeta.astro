---
import { getAsset, getCanonical } from '~/utils/permalinks';
import { localizedHref, unprefixed, ROUTE_DEFAULT_LOCALE } from '~/i18n';

// After Phase 2 routing migration, every content page has both an EN
// (route-default, unprefixed) and a /zh/<path>/ mirror. We always emit
// both hreflang alternates plus x-default → EN. The few non-content
// endpoints (sitemap.xml, llms.txt, RSS) are not HTML pages and don't
// hit this component.
const pathname = String(Astro.url.pathname);
const enPath = unprefixed(pathname);
const enCanonical = String(getCanonical(localizedHref(enPath, ROUTE_DEFAULT_LOCALE)));
const zhCanonical = String(getCanonical(localizedHref(enPath, 'zh')));
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="theme-color" content="#dc2626" />

<link rel="sitemap" href={getAsset('/sitemap-index.xml')} />
<link rel="manifest" href={getAsset('/manifest.json')} />
<link rel="alternate" hreflang="en" href={enCanonical} />
<link rel="alternate" hreflang="zh-CN" href={zhCanonical} />
<link rel="alternate" hreflang="x-default" href={enCanonical} />
