---
import { Icon } from 'astro-icon/components';

import JsonLd from '~/components/common/JsonLd.astro';
import Layout from '~/layouts/PageLayout.astro';
import { benchmarkCaseProfileUpdated } from '~/data/benchmarking';
import { getBenchmarkDrilldownsForRegion, type BenchmarkDrilldownPage } from '~/utils/entity-pages';
import { localizedHref, type Lang } from '~/i18n';

interface Props {
  page: BenchmarkDrilldownPage;
  lang: Lang;
}

const { page, lang } = Astro.props;
const isEn = lang === 'en';

const benchmarkRoot = isEn ? '/benchmarking/' : '/benchmarking/';

const title = isEn ? page.titleEn || page.title : page.title;
const description = isEn ? page.descriptionEn || page.description : page.description;
const body = isEn ? page.bodyEn || page.body : page.body;
const category = isEn ? page.categoryEn || page.category : page.category;
const regionName = isEn ? page.region.summary.nameEn || page.region.summary.name : page.region.summary.name;
const regionHref = `${benchmarkRoot}${page.region.slug}/`;
const inheritedSources = isEn && page.sourcesEn?.length ? page.sourcesEn : page.sources;
const analysisSources = page.analysisSources;

const relatedDrilldowns = getBenchmarkDrilldownsForRegion(page.region.slug)
  .filter((candidate) => candidate.slug !== page.slug)
  .slice(0, 6);

const labels = {
  benchmarkCrumb: isEn ? 'International Benchmarks' : '国际对标',
  drilldownEyebrow: 'Benchmark Drilldown · Updated',
  expandHeading: isEn ? 'Detail' : '展开说明',
  sourcesHeading: isEn ? 'References' : '参考来源',
  relatedHeading: isEn ? 'Continue exploring this region' : '同地区继续下钻',
  dataNoteHeading: isEn ? 'Data note' : '数据说明',
  dataNote: page.analysisPending
    ? isEn
      ? `This page is auto-generated from regional benchmark data and is awaiting deep analysis (curated on ${benchmarkCaseProfileUpdated}). It is excluded from search indexing until enrichment lands.`
      : `本页由地区对标数据自动生成，深度分析尚未补齐（整理于 ${benchmarkCaseProfileUpdated}）。在补深之前不进入搜索索引。`
    : isEn
      ? `Curated benchmark drilldown profile, last updated ${benchmarkCaseProfileUpdated}.`
      : `已补深的对标下钻档案，最近整理于 ${benchmarkCaseProfileUpdated}。`,
  backTo: isEn ? `Back to ${regionName}` : `返回 ${regionName}`,
};

const baseMetadata = isEn
  ? {
      title: `${title} · ${regionName} Benchmark`,
      description,
    }
  : {
      title: `${title} · ${regionName}国际对标`,
      description,
    };

// Until per-drilldown enrichment lands, mark the page noindex,follow so
// thin auto-generated stubs don't erode site-wide SEO quality. Once an
// entry exists in `RegionDetail.drilldownEnrichments`, page.analysisPending
// flips to false and the page becomes regularly indexable.
const metadata = page.analysisPending ? { ...baseMetadata, robots: { index: false, follow: true } } : baseMetadata;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: benchmarkCaseProfileUpdated,
  dateModified: benchmarkCaseProfileUpdated,
  inLanguage: isEn ? 'en' : 'zh-CN',
  mainEntityOfPage: new URL(Astro.url).href,
  about: [
    { '@type': 'Thing', name: page.titleEn || page.title },
    { '@type': 'Place', name: page.region.summary.nameEn || page.region.summary.name },
  ],
  isPartOf: {
    '@type': 'WebSite',
    name: isEn ? 'Singapore AI Observatory' : '新加坡 AI 观察',
    url: isEn ? 'https://sgai.md/' : 'https://sgai.md/',
  },
};

const breadcrumbs = [
  { label: labels.benchmarkCrumb, href: localizedHref('/benchmarking/', lang) },
  { label: regionName, href: regionHref },
  { label: title },
];
---

<Layout metadata={metadata} breadcrumbs={breadcrumbs} lang={lang}>
  <JsonLd schema={articleSchema} />

  <article class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <header class="mb-8">
      <div class="mb-5 flex flex-wrap items-center gap-2 text-xs">
        <a
          href={regionHref}
          class="inline-flex items-center gap-1 bg-primary/10 text-primary px-3 py-1.5 rounded font-semibold hover:bg-primary/15 transition-colors"
        >
          <Icon name="tabler:arrow-left" class="w-3.5 h-3.5" />
          {regionName}
        </a>
        <span class="bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-3 py-1.5 rounded">
          {category}
        </span>
      </div>

      <p class="text-xs uppercase tracking-[0.18em] text-primary font-semibold mb-4">
        {labels.drilldownEyebrow}
        {benchmarkCaseProfileUpdated}
      </p>
      <h1 class="t-display text-gray-900 dark:text-white mb-3">{title}</h1>
      <p class="t-lead text-gray-700 dark:text-gray-300 mt-6">{description}</p>
    </header>

    <dl
      class="bg-surface rounded-lg border border-subtle p-5 mb-10 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4 text-sm"
    >
      {
        page.facts.map((fact) => (
          <div>
            <dt class="text-xs uppercase tracking-wider text-muted mb-1">
              {isEn ? fact.labelEn || fact.label : fact.label}
            </dt>
            <dd class="text-gray-900 dark:text-white">{isEn ? fact.valueEn || fact.value : fact.value}</dd>
          </div>
        ))
      }
    </dl>

    <section class="mb-10">
      <h2 class="t-h3 text-gray-900 dark:text-white mb-4">{labels.expandHeading}</h2>
      <p class="text-base leading-[1.85] text-gray-800 dark:text-gray-200">{body}</p>
    </section>

    {
      analysisSources && analysisSources.length > 0 && (
        <section class="mb-10">
          <h2 class="t-h3 text-gray-900 dark:text-white mb-4">{labels.sourcesHeading}</h2>
          <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
            {analysisSources.map((source) => (
              <li>
                <a
                  href={source.url}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-1 text-primary hover:text-secondary"
                >
                  {isEn ? source.labelEn || source.label : source.label}
                  {source.date && <span class="text-muted ml-1 text-xs">· {source.date}</span>}
                  <Icon name="tabler:external-link" class="w-3.5 h-3.5" />
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      (!analysisSources || analysisSources.length === 0) && inheritedSources.length > 0 && (
        <section class="mb-10">
          <h2 class="t-h3 text-gray-900 dark:text-white mb-4">{labels.sourcesHeading}</h2>
          <ul class="space-y-1 text-sm text-gray-500 dark:text-gray-400">
            {inheritedSources.map((source) => (
              <li>• {source}</li>
            ))}
          </ul>
        </section>
      )
    }

    {
      relatedDrilldowns.length > 0 && (
        <section class="mb-10">
          <h2 class="t-h3 text-gray-900 dark:text-white mb-4">{labels.relatedHeading}</h2>
          <div class="grid gap-3 md:grid-cols-2">
            {relatedDrilldowns.map((related) => (
              <a
                href={`${benchmarkRoot}${related.slug}/`}
                class="group bg-surface rounded-lg p-4 border border-subtle hover:border-primary/50 hover:shadow-sm transition-all"
              >
                <p class="text-xs text-muted">{isEn ? related.categoryEn || related.category : related.category}</p>
                <h3 class="mt-1 font-semibold text-gray-900 dark:text-white group-hover:text-primary">
                  {isEn ? related.titleEn || related.title : related.title}
                </h3>
                <p class="mt-2 text-xs text-gray-600 dark:text-gray-400 line-clamp-2">
                  {isEn ? related.descriptionEn || related.description : related.description}
                </p>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <section class="mb-10 pt-6 border-t border-subtle">
      <h2 class="text-sm uppercase tracking-wider text-muted font-semibold mb-3">{labels.dataNoteHeading}</h2>
      <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">{labels.dataNote}</p>
    </section>

    <nav class="mt-12 pt-6 border-t border-subtle">
      <a href={regionHref} class="text-sm text-primary hover:text-secondary font-medium inline-flex items-center gap-1">
        <Icon name="tabler:arrow-left" class="w-4 h-4" />
        {labels.backTo}
      </a>
    </nav>
  </article>
</Layout>
