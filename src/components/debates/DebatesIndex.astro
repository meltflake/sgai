        implemented: '已落实',
        inProgress: '进行中',
        stillDiscussing: '仍在讨论',
        currentBalance: '当前平衡：',
        clickPeriod: '点击任意时期，筛选该阶段的辩论记录。',
        clickControversy: '点击任意争议焦点，筛选相关辩论。',
        clickMp: '点击任意议员卡片，筛选该议员参与的辩论。',
        clickSignal: '点击任意信号，筛选该政策信号首次出现的年份。',
      };

const typeMap: Record<string, string> = isJa
  ? {
      'Oral Answers to Questions': '口头答复',
      'Written Answers to Questions': '书面答复',
      Budget: '予算討論',
      Motions: '動議',
    }
  : isEn
    ? {
        'Oral Answers to Questions': 'Oral Answers',
        'Written Answers to Questions': 'Written Answers',
        Budget: 'Budget Debate',
        Motions: 'Motions',
      }
    : {
        'Oral Answers to Questions': '口头答复',
        'Written Answers to Questions': '书面答复',
        Budget: '预算辩论',
        Motions: '动议',
      };

const controversyLabels: Record<number, string> = isJa
  ? {
      1: '信息发布',
      2: '温和质询',
      3: '实质辩论',
      4: '激烈争议',
      5: '高度对立',
    }
  : isEn
    ? {
        1: 'Information',
        2: 'Mild scrutiny',
        3: 'Substantive debate',
        4: 'Heated controversy',
        5: 'Sharp opposition',
      }
    : {
        1: '信息发布',
        2: '温和质询',
        3: '实质辩论',
        4: '激烈争议',
        5: '高度对立',
      };

const controversyColors: Record<number, string> = {
  1: 'bg-surface text-muted border border-subtle',
  2: 'bg-surface text-muted border border-subtle',
  3: 'bg-surface text-default border border-subtle',
  4: 'bg-primary/10 text-primary border border-primary/30',
  5: 'bg-primary/15 text-primary border border-primary/40 font-semibold',
};

const statusColors: Record<string, string> = {
  ongoing: 'bg-surface text-muted border border-subtle',
  escalating: 'bg-primary/10 text-primary border border-primary/30',
  resolved: 'bg-surface text-default border border-subtle',
};

const statusLabels: Record<string, string> = {
  ongoing: isJa ? '討論継続中' : isEn ? 'Ongoing' : '持续讨论中',
  escalating: isJa ? '争点エスカレーション' : isEn ? 'Escalating' : '争议升级',
  resolved: isJa ? '定論済み' : isEn ? 'Resolved' : '已有定论',
};

const significanceColors: Record<string, string> = {
  high: 'border-l-primary',
  medium: 'border-l-subtle',
  low: 'border-l-subtle',
};

const topicLabels: Record<string, string> = isJa
  ? {
      'AI Economy & Industry': 'AI 经济与产业',
      'AI & Employment': 'AI 与就业',
      'AI Governance & Regulation': 'AI 治理与监管',
      'AI & National Security': 'AI 与国家安全',
      'AI in Public Sector': 'AI 与公共部门',
      'AI Infrastructure & Research': 'AI 基础设施与研究',
      'AI Safety & Ethics': 'AI 安全与伦理',
      'AI in Education': 'AI 与教育',
      'AI in Healthcare': 'AI 与医疗',
      'AI Strategy': 'AI 战略',
      'Deepfakes & Disinformation': '深度伪造与虚假信息',
    }
  : isEn
    ? {
        'AI Economy & Industry': 'AI Economy & Industry',
        'AI & Employment': 'AI & Employment',
        'AI Governance & Regulation': 'AI Governance & Regulation',
        'AI & National Security': 'AI & National Security',
        'AI in Public Sector': 'AI in Public Sector',
        'AI Infrastructure & Research': 'AI Infrastructure & Research',
        'AI Safety & Ethics': 'AI Safety & Ethics',
        'AI in Education': 'AI in Education',
        'AI in Healthcare': 'AI in Healthcare',
        'AI Strategy': 'AI Strategy',
        'Deepfakes & Disinformation': 'Deepfakes & Disinformation',
      }
    : {
        'AI Economy & Industry': 'AI 经济与产业',
        'AI & Employment': 'AI 与就业',
        'AI Governance & Regulation': 'AI 治理与监管',
        'AI & National Security': 'AI 与国家安全',
        'AI in Public Sector': 'AI 与公共部门',
        'AI Infrastructure & Research': 'AI 基础设施与研究',
        'AI Safety & Ethics': 'AI 安全与伦理',
        'AI in Education': 'AI 与教育',
        'AI in Healthcare': 'AI 与医疗',
        'AI Strategy': 'AI 战略',
        'Deepfakes & Disinformation': '深度伪造与虚假信息',
      };

const topicCounts = new Map<string, number>();
for (const d of debates) {
  for (const topic of new Set(d.topics || [])) {
    topicCounts.set(topic, (topicCounts.get(topic) || 0) + 1);
  }
}

const topicEntries = Object.entries(topicLabels)
  .map(([topic, label]) => ({ topic, label, count: topicCounts.get(topic) || 0 }))
  .filter((entry) => entry.count > 0)
  .sort((a, b) => b.count - a.count);

const maxCount = Math.max(...Object.values(DEBATE_STATS.byYear));
const latestDate = debates[0]?.date || String(DEBATE_STATS.yearRange.to);
const latestYear = latestDate.slice(0, 4);

const controversyDebateCounts = RECURRING_CONTROVERSIES.map((c) => {
  const relTopics = (c as { relatedTopics: string[] }).relatedTopics || [];
  return debates.filter((d) => relTopics.some((topic) => d.topics.includes(topic))).length;
});

const speakerCounts = new Map<string, number>();
for (const d of debates) {
  for (const speaker of d.speakers) {
    if (speaker && speaker.length > 1) {
      speakerCounts.set(speaker, (speakerCounts.get(speaker) || 0) + 1);
    }
  }
}

const frequentSpeakers = [...speakerCounts.entries()]
  .filter(([, count]) => count >= 3)
  .sort((a, b) => b[1] - a[1])
  .map(([name, count]) => ({ name, count }));

const quickFilters = isEn
  ? [
      { label: 'Latest sitting', dimension: 'keyword', value: latestDate },
      { label: latestYear, dimension: 'year', value: latestYear },
      { label: 'Data sovereignty', dimension: 'keyword', value: 'data sovereignty' },
      { label: 'Employment', dimension: 'topic', value: 'AI & Employment' },
      { label: 'Governance', dimension: 'topic', value: 'AI Governance & Regulation' },
      { label: 'National security', dimension: 'topic', value: 'AI & National Security' },
      { label: 'Healthcare', dimension: 'topic', value: 'AI in Healthcare' },
      { label: 'High controversy', dimension: 'controversy', value: '4' },
    ]
  : [
      { label: '最新场次', dimension: 'keyword', value: latestDate },
      { label: latestYear, dimension: 'year', value: latestYear },
      { label: '数据主权', dimension: 'keyword', value: '数据主权' },
      { label: '就业', dimension: 'topic', value: 'AI & Employment' },
      { label: '治理', dimension: 'topic', value: 'AI Governance & Regulation' },
      { label: '国家安全', dimension: 'topic', value: 'AI & National Security' },
      { label: '医疗', dimension: 'topic', value: 'AI in Healthcare' },
      { label: '高争议', dimension: 'controversy', value: '4' },
    ];

const jsAttr = (s: string) => String(s).replace(/\\/g, '\\\\').replace(/'/g, "\\'");

const truncate = (text: string | null | undefined, max: number) => {
  const s = String(text || '')
    .replace(/\s+/g, ' ')
    .trim();
  return s.length > max ? `${s.slice(0, max).trim()}...` : s;
};

const debateTitle = (d: (typeof debates)[number]) => (isEn ? d.titleEn || d.title : d.title);
const debateSummary = (d: (typeof debates)[number]) =>
  isEn ? d.summaryEn || d.summary : d.summary || d.summaryEn || '';
const debateSignal = (d: (typeof debates)[number]) =>
  isEn ? d.policySignalEn || d.policySignal : d.policySignal || d.policySignalEn;
const debateQuote = (d: (typeof debates)[number]) =>
  isEn ? d.notableQuoteEn || d.notableQuote : d.notableQuote || d.notableQuoteEn;
const debateKeyPoints = (d: (typeof debates)[number]) =>
  isEn && d.keyPointsEn && d.keyPointsEn.length > 0 ? d.keyPointsEn : d.keyPoints;
const debateGovStance = (d: (typeof debates)[number]) =>
  isEn ? d.governmentStanceEn || d.governmentStance : d.governmentStance || d.governmentStanceEn;
const debateOppStance = (d: (typeof debates)[number]) =>
  isEn ? d.oppositionStanceEn || d.oppositionStance : d.oppositionStance || d.oppositionStanceEn;

const searchBlob = (d: (typeof debates)[number]) =>
  [
    d.date,
    d.type,
    d.title,
    d.titleEn,
    debateSummary(d),
    debateSignal(d),
    ...(d.topics || []),
    ...(d.speakers || []),
    ...(debateKeyPoints(d) || []),
  ]
    .join(' ')
    .toLowerCase();

const speakerDisplay = (raw: string) => {
  const pid = findPersonId(raw);
  const person = pid ? getPerson(pid) : undefined;
  const label = person ? (isEn ? person.nameEn || person.name || raw : person.name || person.nameEn || raw) : raw;
  const href = pid ? localizedHref(`/voices/${pid}/`, lang) : null;
  return { label, href, title: raw };
};

const debateHref = (id: string) => localizedHref(`/debates/${id}/`, lang);
const yearRangeLabel = `${DEBATE_STATS.yearRange.from}-${DEBATE_STATS.yearRange.to}`;
const typeMixLabel = Object.entries(DEBATE_STATS.byType)
  .map(([type, count]) => `${typeMap[type] || type} ${count}`)
  .join(' / ');
---

<Layout metadata={meta} breadcrumbs={[{ label: L.crumb }]} lang={lang}>
  <div class="max-w-7xl mx-auto px-4 py-8 md:py-10 overflow-x-hidden">
    <div
      class="mb-6 flex flex-col gap-2 rounded-lg bg-blue-50 dark:bg-slate-800 border border-blue-200 dark:border-slate-600 px-4 py-3 md:flex-row md:items-center md:justify-between md:px-5"
    >
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
        <span class="font-semibold text-blue-800 dark:text-blue-300">{L.updated}: {DATA_UPDATED}</span>
        <span class="text-gray-500 dark:text-gray-400">{DEBATE_STATS.total} {L.recordCount}</span>
      </div>
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-500 dark:text-gray-400">
        <span>
          {L.source}: <a href="https://sprs.parl.gov.sg/search/" target="_blank" class="text-blue-600 hover:underline"
            >SPRS Hansard</a
          > · <a href="https://search.pair.gov.sg/" target="_blank" class="text-blue-600 hover:underline">PAIR Search</a
          >
        </span>
        <span class="hidden text-gray-300 dark:text-gray-600 sm:inline">|</span>
        <span>{L.digestNote}</span>
      </div>
    </div>

    <header class="mb-6 md:mb-8">
      <div class="flex items-center gap-3 mb-3 min-w-0">
        <span class="text-3xl md:text-4xl shrink-0">🏛️</span>
        <h1 class="t-h1 text-gray-900 dark:text-white min-w-0">{L.title}</h1>
      </div>
      <p class="text-gray-600 dark:text-gray-400 text-base md:text-lg max-w-3xl leading-relaxed">{L.intro}</p>
    </header>

    <section
      class="mb-7 rounded-xl border border-subtle bg-surface p-4 shadow-sm md:p-5"
      aria-labelledby="debate-finder-title"
    >
      <div class="mb-4 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
        <div>
          <h2 id="debate-finder-title" class="t-h3 text-gray-900 dark:text-white">{L.finderTitle}</h2>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{L.finderHint}</p>
        </div>
        <button
          id="clear-filters-btn"
          onclick="clearFilters()"
          class="hidden self-start rounded-lg border border-red-200 px-3 py-1.5 text-sm text-red-500 transition-all hover:border-red-400 hover:text-red-700 md:self-auto"
        >
          {L.clear}
        </button>
      </div>

      <div class="grid grid-cols-1 gap-3 md:grid-cols-12">
        <input
          id="search-input"
          type="text"
          placeholder={L.searchPlaceholder}
          class="min-w-0 rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-gray-800 dark:border-slate-600 dark:bg-slate-700 dark:text-gray-200 md:col-span-5"
        />
        <select
          id="type-filter"
