                          <ul class="space-y-1">
                            {keyPoints.slice(0, 4).map((point) => (
                              <li class="text-xs text-gray-600 dark:text-gray-400">• {point}</li>
                            ))}
                          </ul>
                        </div>
                      )}

                      {(govStance || oppStance) && (
                        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
                          {govStance && (
                            <div class="rounded-lg bg-blue-50 p-2.5 dark:bg-blue-900/20">
                              <div class="mb-1 text-xs font-semibold text-blue-600 dark:text-blue-400">
                                {L.government}
                              </div>
                              <div class="text-xs text-gray-700 dark:text-gray-300">{govStance}</div>
                            </div>
                          )}
                          {oppStance && (
                            <div class="rounded-lg bg-orange-50 p-2.5 dark:bg-orange-900/20">
                              <div class="mb-1 text-xs font-semibold text-orange-600 dark:text-orange-400">
                                {L.opposition}
                              </div>
                              <div class="text-xs text-gray-700 dark:text-gray-300">{oppStance}</div>
                            </div>
                          )}
                        </div>
                      )}

                      {quote && (
