        listHint: '列表默认压缩；展开卡片或进入详情页看完整摘要。',
        noResults: '没有找到匹配的辩论记录',
        details: '展开摘要、立场与原文',
        keyPoints: '要点',
        government: '政府立场',
        opposition: '质询立场',
        signal: '政策信号',
        quote: '关键引文',
