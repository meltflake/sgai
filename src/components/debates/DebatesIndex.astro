                  </h3>

                  {isEn ? null : <p class="mb-2 text-xs italic text-gray-400">{truncate(d.titleEn || '', 120)}</p>}

                  <div class="mb-3 flex flex-wrap gap-1.5">
                    {(d.topics || []).map((topic) => (
                      <button
                        type="button"
                        onclick={`filterBy('topic','${jsAttr(topic)}')`}
