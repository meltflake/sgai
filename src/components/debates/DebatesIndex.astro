            const oppStance = debateOppStance(d);
            const signal = debateSignal(d);
            const quote = debateQuote(d);
            return (
              <article
                data-debate-card
                data-type={d.type}
                data-year={yearStr}
                data-controversy={cLevel}
                data-topics={(d.topics || []).join('|')}
