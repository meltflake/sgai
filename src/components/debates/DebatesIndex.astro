                    <span class={`rounded-full px-2 py-0.5 text-xs ${cColor}`}>{cLabel}</span>
                  </div>

                  <h3 class="mb-2 text-base font-bold leading-snug text-gray-900 dark:text-white md:text-lg">
                    <a href={debateHref(d.id)} class="hover:text-primary">
                      {title}
