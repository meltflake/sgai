                      {d.transcriptEn && (
                        <details class="rounded-lg border border-subtle bg-white p-3 dark:bg-slate-800">
                          <summary class="cursor-pointer text-xs font-semibold text-gray-500">{L.transcript}</summary>
                          <div class="mt-2 max-h-64 overflow-y-auto whitespace-pre-wrap text-xs leading-relaxed text-gray-600 dark:text-gray-400">
                            {d.transcriptEn}
                          </div>
                        </details>
                      )}
                    </div>
                  </details>
                </div>
              </article>
            );
