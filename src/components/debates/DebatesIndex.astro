---
import Layout from '~/layouts/PageLayout.astro';
import {
  debates,
  DEBATE_STATS,
  POLICY_EVOLUTION,
  RECURRING_CONTROVERSIES,
  MP_PROFILES,
  KEY_INSIGHTS,
  POLICY_SIGNALS,
  TENSION_MAP,
} from '~/data/debates';
import { pickLocalized, localizedHref, t, type Lang } from '~/i18n';
import { findPersonId, getPerson } from '~/utils/people';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
// `isEn` is true for any non-zh locale — the page-local L dictionary only
// distinguishes zh vs. non-zh, and non-default locales (en, ja, ...) all
// fall back to the English copy until per-locale strings are added.
const isJa = lang === 'ja';
const isEn = lang !== 'zh';
const DATA_UPDATED = '2026-05-03';

const meta = {
