                        {L.signal}: {signal}
                      </span>
                    </div>
                  )}

                  <div class="mt-4 flex flex-col gap-3 border-t border-subtle pt-3 text-xs sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex min-w-0 flex-wrap items-center gap-1">
                      <span class="text-gray-400">🎙️</span>
                      {(d.speakers || []).slice(0, 5).map((speaker, index) => {
                        const display = speakerDisplay(speaker);
                        return (
                          <>
                            {index > 0 && <span class="text-gray-300">·</span>}
                            {display.href ? (
                              <a
                                href={display.href}
                                class="text-gray-500 transition-colors hover:text-purple-600 hover:underline"
                                title={display.title}
                              >
                                {display.label}
                              </a>
                            ) : (
                              <span class="text-gray-500" title={display.title}>
                                {display.label}
                              </span>
                            )}
                          </>
                        );
                      })}
                    </div>
                    <div class="flex shrink-0 flex-wrap gap-3">
                      <a href={debateHref(d.id)} class="text-blue-600 hover:underline">
                        {L.detailPage} →
                      </a>
                      {d.sourceUrl && (
                        <a href={d.sourceUrl} target="_blank" rel="noopener" class="text-blue-600 hover:underline">
                          {L.hansard} ↗
                        </a>
                      )}
                    </div>
                  </div>

                  <details class="mt-3 rounded-lg border border-subtle bg-gray-50 p-3 dark:bg-slate-700/40">
                    <summary class="cursor-pointer text-sm font-semibold text-gray-700 dark:text-gray-200">
