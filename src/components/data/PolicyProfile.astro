---
import { Icon } from 'astro-icon/components';

import EcosystemProse from '~/components/data/EcosystemProse.astro';
import RelatedRail from '~/components/data/RelatedRail.astro';
import { categories, type Policy, type PolicyResource } from '~/data/policies';
import { levers } from '~/data/levers';
import { localizedHref, pickLocalized, t, type Lang } from '~/i18n';
import { leverSlug } from '~/utils/entity-pages';
import { getPerson, personDisplayName } from '~/utils/people';

type PolicyWithCategory = Policy & {
  _categoryName?: string;
  _categoryNameEn?: string;
  _categoryIcon?: string;
};

interface Props {
  policy: PolicyWithCategory;
  lang: Lang;
}

const { policy, lang } = Astro.props;
const isEn = lang === 'en';

const title = pickLocalized<string>(policy, 'title', lang) || policy.title;
const subtitle = policy.titleEn && policy.titleEn !== title ? policy.titleEn : undefined;
const summary = pickLocalized<string>(policy, 'summary', lang) || '';
const content = pickLocalized<string>(policy, 'content', lang) || '';
const source = pickLocalized<string>(policy, 'source', lang) || policy.source;
const categoryName =
  pickLocalized<string>({ name: policy._categoryName, nameEn: policy._categoryNameEn }, 'name', lang) ||
  policy._categoryName ||
  '';
const authors = (policy.authorPersonIds || []).map((id) => getPerson(id)).filter(Boolean);
const linkedLevers = (policy.relatedLeverNumbers || [])
  .map((n) => levers.find((lv) => lv.number === n))
  .filter(Boolean);

const labels = {
  back: isEn ? 'Back to Policy Library' : '返回政策库',
  profile: isEn ? 'Policy / Project Profile' : '政策 / 项目档案',
  category: isEn ? 'Category' : '分类',
  date: isEn ? 'Published / Updated' : '发布 / 更新',
  source: isEn ? 'Issuing body' : '发布机构',
  ministry: isEn ? 'Lead ministry' : '主管部委',
  levers: isEn ? 'Linked levers' : '关联抓手',
  debates: isEn ? 'Parliament links' : '国会记录',
  timeline: isEn ? 'Timeline years' : '时间线年份',
  verified: isEn ? 'Last checked' : '信息校验',
  details: isEn ? 'Detailed Notes' : '展开信息',
  signals: isEn ? 'Strategic Context' : '战略位置',
  milestones: isEn ? 'Milestones' : '关键里程碑',
  resources: isEn ? 'Resources' : '资源入口',
  sameCategory: isEn ? 'More in This Category' : '同类档案',
  officialSite: isEn ? 'Issuing body site' : '发布机构官网',
};

function pickFactField(
  item: { label: string; labelEn?: string; value: string; valueEn?: string },
  field: 'label' | 'value'
): string {
  if (field === 'label') return isEn ? item.labelEn || item.label : item.label;
  return isEn ? item.valueEn || item.value : item.value;
}

function resourceLabel(resource: PolicyResource): string {
  return isEn ? resource.labelEn || resource.label : resource.label;
}

function resourceIcon(kind: PolicyResource['kind']): string {
  if (kind === 'pdf' || kind === 'report') return 'tabler:file-text';
  if (kind === 'translation') return 'tabler:language';
  if (kind === 'tool') return 'tabler:tools';
  if (kind === 'dataset') return 'tabler:database';
  return 'tabler:external-link';
}

function isExternal(url: string): boolean {
  return /^https?:\/\//.test(url);
}

const facts = [
  { label: labels.category, value: categoryName },
  { label: labels.date, value: policy.date },
  { label: labels.source, value: source },
  { label: labels.ministry, value: policy.ministry },
  {
    label: labels.levers,
    value:
      linkedLevers.length > 0
        ? linkedLevers
            .map((lv) => `${isEn ? 'Lever' : '抓手'} ${lv!.number}: ${isEn ? lv!.nameEn || lv!.name : lv!.name}`)
            .join(' / ')
        : undefined,
  },
  {
    label: labels.debates,
    value:
      policy.relatedDebateIds && policy.relatedDebateIds.length > 0
        ? `${policy.relatedDebateIds.length} ${isEn ? 'records' : '条'}`
        : undefined,
  },
  {
    label: labels.timeline,
    value:
      policy.relatedTimelineYears && policy.relatedTimelineYears.length > 0
        ? policy.relatedTimelineYears.join(', ')
        : undefined,
  },
  { label: labels.verified, value: policy.lastVerified },
  ...(policy.keyFacts || []).map((fact) => ({
    label: pickFactField(fact, 'label'),
    value: pickFactField(fact, 'value'),
  })),
].filter((fact): fact is { label: string; value: string } => Boolean(fact.value));

const sections =
  policy.sections && policy.sections.length > 0
    ? policy.sections
        .map((section) => ({
          title: isEn ? section.titleEn || section.title : section.title,
          body: isEn ? section.bodyEn || section.body : section.body,
        }))
        .filter((section) => section.body)
    : [{ title: labels.details, body: content }];

const baseResources: PolicyResource[] = [
  ...(policy.sourceOrgUrl
    ? [{ label: labels.officialSite, labelEn: labels.officialSite, url: policy.sourceOrgUrl, kind: 'website' as const }]
    : []),
  ...(policy.sourceUrl
    ? [{ label: t(lang, 'source'), labelEn: t(lang, 'source'), url: policy.sourceUrl, kind: 'source' as const }]
    : []),
  ...(policy.pdfUrl
    ? [{ label: t(lang, 'sourcePdf'), labelEn: t(lang, 'sourcePdf'), url: policy.pdfUrl, kind: 'pdf' as const }]
    : []),
  ...(policy.translatedPdfUrl
    ? [
        {
          label: t(lang, 'translation'),
          labelEn: t(lang, 'translation'),
          url: policy.translatedPdfUrl,
          kind: 'translation' as const,
        },
      ]
    : []),
];

const resources: PolicyResource[] = [];
const seenUrls = new Set<string>();
for (const resource of [...baseResources, ...(policy.resources || [])]) {
  if (seenUrls.has(resource.url)) continue;
  seenUrls.add(resource.url);
  resources.push(resource);
}

const signals = [
  linkedLevers.length > 0
    ? {
        icon: 'tabler:target-arrow',
        title: labels.levers,
        body: isEn
          ? `Connected to ${linkedLevers.length} national AI lever${linkedLevers.length > 1 ? 's' : ''}.`
          : `已连接到 ${linkedLevers.length} 个国家 AI 抓手，说明它不是孤立文件，而是执行体系里的节点。`,
      }
    : null,
  policy.relatedDebateIds && policy.relatedDebateIds.length > 0
    ? {
        icon: 'tabler:building-bank',
        title: labels.debates,
        body: isEn
          ? `${policy.relatedDebateIds.length} parliamentary record${policy.relatedDebateIds.length > 1 ? 's' : ''} linked.`
          : `已关联 ${policy.relatedDebateIds.length} 条国会记录，方便追踪政策在议会里的问答和解释。`,
      }
    : null,
  policy.relatedTimelineYears && policy.relatedTimelineYears.length > 0
    ? {
        icon: 'tabler:timeline',
        title: labels.timeline,
        body: isEn
          ? `Appears in the timeline around ${policy.relatedTimelineYears.join(', ')}.`
          : `已进入 ${policy.relatedTimelineYears.join('、')} 年时间线，可放回新加坡 AI 战略演进里看。`,
      }
    : null,
  policy.relatedPostSlugs && policy.relatedPostSlugs.length > 0
    ? {
        icon: 'tabler:article',
        title: isEn ? 'Analysis links' : '观点链接',
        body: isEn
          ? `${policy.relatedPostSlugs.length} editorial analysis page${policy.relatedPostSlugs.length > 1 ? 's' : ''} linked.`
          : `已关联 ${policy.relatedPostSlugs.length} 篇观点文章，方便从档案跳到判断。`,
      }
    : null,
].filter((signal): signal is { icon: string; title: string; body: string } => Boolean(signal));

const sameCategoryPolicies = categories
  .flatMap((category) =>
    category.policies.map((candidate) => ({
      ...candidate,
      _categoryName: category.name,
      _categoryNameEn: category.nameEn,
    }))
  )
  .filter((candidate) => candidate.id !== policy.id && candidate._categoryName === policy._categoryName)
  .slice(0, 4);

function policyTitle(candidate: Policy): string {
  return pickLocalized<string>(candidate, 'title', lang) || candidate.title;
}

function policySource(candidate: Policy): string {
  return pickLocalized<string>(candidate, 'source', lang) || candidate.source;
}
---

<article class="max-w-4xl mx-auto px-4 sm:px-6 py-10 md:py-12">
  <div class="mb-6 flex flex-wrap items-center gap-2 text-xs">
    <a
      href={localizedHref('/policies/', lang)}
      class="inline-flex items-center gap-1 bg-primary/10 text-primary px-3 py-1.5 rounded font-semibold hover:bg-primary/15 transition-colors"
    >
      <Icon name="tabler:arrow-left" class="w-3.5 h-3.5" />
      {labels.back}
    </a>
    <span class="bg-slate-100 dark:bg-slate-800 text-gray-700 dark:text-gray-300 px-3 py-1.5 rounded">
      {policy._categoryIcon}
      {categoryName}
    </span>
    <span
      class="bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300 px-3 py-1.5 rounded font-medium"
    >
      {policy.date}
    </span>
  </div>

  <p class="text-sm uppercase tracking-wider text-gray-500 dark:text-gray-400 font-semibold mb-2">{labels.profile}</p>
  <h1 class="t-display text-gray-900 dark:text-white mb-3">{title}</h1>
  {subtitle && <p class="text-base md:text-lg text-gray-500 dark:text-gray-400 italic mb-5">{subtitle}</p>}
  <p
    class="font-serif text-lg leading-[1.85] text-gray-800 dark:text-gray-200 mb-8 border-l-4 border-primary pl-5 italic"
  >
    {summary}
  </p>

  <dl
    class="bg-surface rounded-lg border border-subtle p-5 mb-8 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm"
  >
    {
      facts.map((fact) => (
        <div>
          <dt class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-1">{fact.label}</dt>
          <dd class="text-gray-900 dark:text-white leading-relaxed">{fact.value}</dd>
        </div>
      ))
    }
  </dl>

  {
    signals.length > 0 && (
      <section class="mb-10">
        <h2 class="t-h3 text-gray-900 dark:text-white mb-4">{labels.signals}</h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {signals.map((signal) => (
            <div class="bg-surface rounded-lg border border-subtle p-4">
              <div class="flex items-center gap-2 font-semibold text-gray-900 dark:text-white mb-2">
                <Icon name={signal.icon} class="w-4 h-4 text-primary" />
                {signal.title}
              </div>
              <p class="text-sm text-muted leading-relaxed">{signal.body}</p>
            </div>
          ))}
        </div>
      </section>
    )
  }

  {
    sections.map((section) => (
      <section class="mb-10">
        <h2 class="t-h3 text-gray-900 dark:text-white mb-4">{section.title}</h2>
        <EcosystemProse content={section.body} />
      </section>
    ))
  }

  {
    policy.milestones && policy.milestones.length > 0 && (
      <section class="mb-10">
        <h2 class="t-h3 text-gray-900 dark:text-white mb-4">{labels.milestones}</h2>
        <ol class="relative border-l-2 border-primary/30 ml-2 pl-6 space-y-5">
          {policy.milestones.map((milestone) => (
            <li class="relative">
              <span class="absolute -left-[33px] top-1 w-3 h-3 rounded-full bg-primary ring-4 ring-primary/10" />
              <div class="text-xs font-mono text-gray-500 dark:text-gray-400 mb-1">{milestone.date}</div>
              <div class="font-semibold text-gray-900 dark:text-white">
                {isEn ? milestone.titleEn || milestone.title : milestone.title}
              </div>
              {(isEn ? milestone.descriptionEn || milestone.description : milestone.description) && (
                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1 leading-relaxed">
                  {isEn ? milestone.descriptionEn || milestone.description : milestone.description}
                </p>
              )}
            </li>
          ))}
        </ol>
      </section>
    )
  }

  {
    authors.length > 0 && (
      <section class="mb-10 pt-6 border-t border-subtle">
        <h2 class="text-sm uppercase tracking-wider text-gray-500 dark:text-gray-400 font-semibold mb-3">
          {t(lang, 'authors')}
        </h2>
        <ul class="flex flex-wrap gap-x-4 gap-y-2">
          {authors.map((person) => (
            <li>
              <a
                href={localizedHref(`/voices/${person!.id}/`, lang)}
                class="text-primary hover:text-secondary text-sm font-medium"
              >
                {isEn ? person!.name : personDisplayName(person!.id)}
              </a>
              <span class="text-xs text-gray-500 dark:text-gray-400 ml-1">
                {isEn ? person!.title : person!.zhTitle || person!.title}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    resources.length > 0 && (
      <section class="mb-10 pt-6 border-t border-subtle">
        <h2 class="text-sm uppercase tracking-wider text-gray-500 dark:text-gray-400 font-semibold mb-3">
          {labels.resources}
        </h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {resources.map((resource) => (
            <a
              href={resource.url}
              target={isExternal(resource.url) ? '_blank' : undefined}
              rel={isExternal(resource.url) ? 'noopener' : undefined}
              class="flex items-center justify-between gap-3 bg-surface rounded-lg border border-subtle p-4 hover:border-primary/40 hover:shadow-sm transition-all"
            >
              <span class="text-sm font-medium text-gray-900 dark:text-white">{resourceLabel(resource)}</span>
              <Icon name={resourceIcon(resource.kind)} class="w-4 h-4 text-primary" />
            </a>
          ))}
        </div>
      </section>
    )
  }

  {
    linkedLevers.length > 0 && (
      <section class="mb-10">
        <h2 class="t-h3 text-gray-900 dark:text-white mb-4">{labels.levers}</h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {linkedLevers.map((lever) => (
            <a
              href={localizedHref(`/levers/${leverSlug(lever!)}/`, lang)}
              class="group bg-surface rounded-lg border border-subtle p-4 hover:border-primary/40 hover:shadow-sm transition-all"
            >
              <p class="text-xs text-muted mb-1">{isEn ? `Lever ${lever!.number}` : `抓手 ${lever!.number}`}</p>
              <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-primary">
                {isEn ? lever!.nameEn || lever!.name : lever!.name}
              </h3>
              <p class="text-xs text-muted mt-1">{isEn ? lever!.subtitleEn || lever!.subtitle : lever!.subtitle}</p>
            </a>
          ))}
        </div>
      </section>
    )
  }

  {
    sameCategoryPolicies.length > 0 && (
      <section class="mb-10">
        <h2 class="t-h3 text-gray-900 dark:text-white mb-4">{labels.sameCategory}</h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {sameCategoryPolicies.map((candidate) => (
            <a
              href={localizedHref(`/policies/${candidate.id}/`, lang)}
              class="group bg-surface rounded-lg border border-subtle p-4 hover:border-primary/40 hover:shadow-sm transition-all"
            >
              <p class="text-xs text-muted mb-1">{candidate.date}</p>
              <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-primary">
                {policyTitle(candidate)}
              </h3>
              <p class="text-xs text-muted mt-1">{policySource(candidate)}</p>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <RelatedRail entity={{ type: 'policy', id: policy.id! }} variant="full" hideWhenEmpty={true} lang={lang} />
</article>
