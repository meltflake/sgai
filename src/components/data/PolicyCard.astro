---
import { Icon } from 'astro-icon/components';

import type { Policy } from '~/data/policies';
import { localizedHref, pickLocalized, type Lang } from '~/i18n';

interface Props {
  policy: Policy;
  lang: Lang;
  categoryIcon?: string;
}

const { policy, lang, categoryIcon } = Astro.props;
// `isEn` is true for any non-zh locale — local label dictionaries only
// branch zh vs. non-zh; ja falls back to en until per-locale strings land.
const isEn = lang !== 'zh';

const title = pickLocalized<string>(policy, 'title', lang) || policy.title;
const subtitle = policy.titleEn && policy.titleEn !== title ? policy.titleEn : undefined;
const source = pickLocalized<string>(policy, 'source', lang) || policy.source;
const summary = pickLocalized<string>(policy, 'summary', lang) || policy.summary;
const content = pickLocalized<string>(policy, 'content', lang) || policy.content;
const href = localizedHref(`/policies/${policy.id!}/`, lang);

function plainText(raw: string): string {
  return raw
    .replace(/\*\*([^*]+)\*\*/g, '$1')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/^[-•]\s+/gm, '')
    .replace(/\s+/g, ' ')
    .trim();
}

const preview = plainText(content);
const relatedCount =
  (policy.relatedDebateIds?.length || 0) +
  (policy.relatedLeverNumbers?.length || 0) +
  (policy.relatedTimelineYears?.length || 0) +
  (policy.authorPersonIds?.length || 0) +
  (policy.relatedPostSlugs?.length || 0);

const labels = {
  source: isEn ? 'Source' : '来源',
  related: isEn ? 'related links' : '项关联',
  profile: isEn ? 'View profile' : '查看档案',
};
---

<a
  href={href}
  class="group flex h-full flex-col bg-surface rounded-lg shadow-md border border-subtle p-5 hover:border-primary/40 hover:shadow-lg transition-all focus-visible:outline-primary"
  aria-label={`${labels.profile}: ${title}`}
>
  <div class="flex items-start justify-between gap-3 mb-3">
    <div class="min-w-0">
      <p class="text-xs text-primary mb-1">
        {categoryIcon ? `${categoryIcon} ` : ''}
        {source}
      </p>
      <h3 class="text-lg font-bold text-gray-900 dark:text-white group-hover:text-primary transition-colors">
        {title}
      </h3>
      {subtitle && <p class="text-sm text-muted mt-1 italic">{subtitle}</p>}
    </div>
    <span class="text-xs bg-slate-100 dark:bg-slate-800 px-2 py-0.5 rounded whitespace-nowrap">{policy.date}</span>
  </div>

  <p class="text-sm font-medium text-gray-800 dark:text-gray-200 mb-2 leading-relaxed">{summary}</p>
  <p class="text-sm text-muted leading-relaxed line-clamp-3">{preview}</p>

  <div class="mt-auto pt-4 border-t border-subtle flex items-center justify-between gap-3">
    <span class="text-xs text-muted">
      {relatedCount > 0 ? `${relatedCount} ${labels.related}` : labels.source}
    </span>
    <span class="inline-flex items-center gap-1 text-sm font-medium text-primary group-hover:text-secondary">
      {labels.profile}
      <Icon name="tabler:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-0.5" />
    </span>
  </div>
</a>
