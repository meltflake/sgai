---
// Phase 4.1 — Knowledge-graph cross-link rail.
//
// Two layouts (controlled by `variant` prop):
//   - 'compact'  : single-line chip strip, embedded into list-page cards
//                  (/policies, /levers, /timeline). Only renders when at
//                  least one related entity exists. Zero visual cost when empty.
//   - 'full'     : grouped sections with headings, used at the bottom of
//                  blog post detail pages. Renders an empty placeholder note
//                  when no relations exist (configurable via `hideWhenEmpty`).
//
// Source of truth: pass an `EntityRef` and the component calls getRelated()
// from src/utils/graph.ts. Alternatively pass a pre-built `bundle` (used by
// blog posts which build their own bundle from frontmatter).
//
// SAFE BY DEFAULT: when there is nothing to render and hideWhenEmpty=true
// (the default), the component emits an empty Astro fragment — no <div>,
// no whitespace shift on the host page.

import { getRelated, type EntityRef, type RelatedBundle } from '~/utils/graph';
import { getLangFromPath, localizedHref, type Lang } from '~/i18n';
import { leverSlug } from '~/utils/entity-pages';

interface Props {
  /** Anchor entity. The component resolves relations via getRelated(). */
  entity?: EntityRef;
  /** Pre-built bundle (alternative to `entity`). Used when caller already
   *  resolved relations from frontmatter / non-standard sources. */
  bundle?: RelatedBundle;
  /** 'compact' (default) | 'full'. */
  variant?: 'compact' | 'full';
  /** When true (default), render nothing if all groups are empty. */
  hideWhenEmpty?: boolean;
  /** Optional: hide specific groups even if non-empty. Useful when the host
   *  page already shows "people" or similar inline (e.g. /debates speakers). */
  exclude?: Array<keyof RelatedBundle>;
  /** Optional class for outer wrapper. */
  class?: string;
  /** Override the lang detected from URL. */
  lang?: Lang;
}

const {
  entity,
  bundle,
  variant = 'compact',
  hideWhenEmpty = true,
  exclude = [],
  class: extraClass = '',
  lang: langOverride,
} = Astro.props;

const lang: Lang = langOverride ?? getLangFromPath(new URL(Astro.url).pathname);
const isEn = lang === 'en';

// Localized labels.
const L = {
  rel: isEn ? 'Related: ' : '关联：',
  relatedReading: isEn ? 'Related Reading' : '相关阅读',
  noneYet: isEn ? 'No related references yet.' : '尚未关联其他资源。',
  hPeople: isEn ? 'People' : '人物',
  hPolicies: isEn ? 'Policies' : '政策',
  hDebates: isEn ? 'Parliamentary debates' : '国会辩论',
  hLevers: isEn ? 'Levers' : '抓手',
  hTimeline: isEn ? 'Timeline' : '时间节点',
  hAnalyses: isEn ? 'Opinions' : '观点',
  moreDebates: (n: number) => (isEn ? `… and ${n} more` : `…另有 ${n} 条`),
  moreDebatesInline: (n: number) => (isEn ? `+${n} more debates` : `+${n} 条辩论`),
  ariaPerson: (name: string) => (isEn ? `Related person: ${name}` : `相关人物：${name}`),
  ariaPolicy: (title: string) => (isEn ? `Related policy: ${title}` : `相关政策：${title}`),
  ariaDebate: (title: string) => (isEn ? `Related debate: ${title}` : `相关辩论：${title}`),
  ariaLever: (n: number, name: string) => (isEn ? `Related lever: ${n} ${name}` : `相关抓手：${name}`),
  ariaTimeline: (year: string | number, title: string) =>
    isEn ? `Related milestone: ${year} ${title}` : `相关时间节点：${year} ${title}`,
  ariaAnalysis: (slug: string) => (isEn ? `Related opinion: ${slug}` : `相关观点：${slug}`),
  leverTag: (n: number, name: string) => (isEn ? `Lever ${n} · ${name}` : `抓手 ${n}：${name}`),
};

// Localized field pickers.
const personLabel = (p: { name: string; zhName?: string }) => (isEn ? p.name : p.zhName || p.name);
const personSub = (p: { title?: string; zhTitle?: string }) => (isEn ? p.title : p.zhTitle);
const policyLabel = (p: { title: string; titleEn?: string }) => (isEn ? p.titleEn || p.title : p.title);
const debateLabel = (d: { title: string; zhTitle?: string }) => (isEn ? d.title : d.zhTitle || d.title);
const leverNameLabel = (lv: { name: string; nameEn?: string }) => (isEn ? lv.nameEn || lv.name : lv.name);
const leverSub = (lv: { subtitle: string; subtitleEn?: string }) => (isEn ? lv.subtitleEn || lv.subtitle : lv.subtitle);
const tlTitle = (e: { title: string; titleEn?: string }) => (isEn ? e.titleEn || e.title : e.title);

const linkPolicies = localizedHref('/policies/', lang);
const linkTimeline = localizedHref('/timeline/', lang);

const empty = (): RelatedBundle => ({
  policies: [],
  debates: [],
  levers: [],
  timeline: [],
  people: [],
  postSlugs: [],
});

const data: RelatedBundle = bundle ?? (entity ? getRelated(entity) : empty());

// Apply exclusions.
const filtered: RelatedBundle = { ...data };
for (const key of exclude) {
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  (filtered as any)[key] = [];
}

const totalCount =
  filtered.people.length +
  filtered.policies.length +
  filtered.debates.length +
  filtered.levers.length +
  filtered.timeline.length +
  filtered.postSlugs.length;

const isEmpty = totalCount === 0;
const renderEmpty = !hideWhenEmpty && isEmpty;
const skip = isEmpty && hideWhenEmpty;
---

{
  !skip && variant === 'compact' && (
    <div class={`mt-3 pt-3 border-t border-dashed border-subtle text-xs ${extraClass}`}>
      <span class="text-gray-400 dark:text-gray-500 font-medium mr-2">{L.rel}</span>
      <div class="inline-flex flex-wrap gap-x-2 gap-y-1 align-baseline">
        {filtered.people.map((p) => {
          const name = personLabel(p);
          return (
            <a
              href={localizedHref(`/voices/${p.id}/`, lang)}
              class="text-blue-600 dark:text-blue-400 hover:underline"
              title={p.name}
              aria-label={L.ariaPerson(name)}
            >
              👤 {name}
            </a>
          );
        })}
        {filtered.policies.map((p) => {
          const title = policyLabel(p);
          return (
            <a
              href={p.id ? localizedHref(`/policies/${p.id}/`, lang) : linkPolicies}
              class="text-purple-600 dark:text-purple-400 hover:underline"
              aria-label={L.ariaPolicy(title)}
            >
              📋 {title}
            </a>
          );
        })}
        {filtered.debates.slice(0, 5).map((d) => {
          const title = debateLabel(d);
          const trimmed = title.length > 24 ? title.slice(0, 24) + '…' : title;
          return (
            <a
              href={localizedHref(`/debates/${d.id}/`, lang)}
              class="text-amber-700 dark:text-amber-400 hover:underline"
              aria-label={L.ariaDebate(title)}
            >
              🏛️ {trimmed}
            </a>
          );
        })}
        {filtered.debates.length > 5 && (
          <span class="text-gray-400">{L.moreDebatesInline(filtered.debates.length - 5)}</span>
        )}
        {filtered.levers.map((lv) => {
          const name = leverNameLabel(lv);
          return (
            <a
              href={localizedHref(`/levers/${leverSlug(lv)}/`, lang)}
              class="text-emerald-700 dark:text-emerald-400 hover:underline"
              aria-label={L.ariaLever(lv.number, name)}
            >
              🎯 {L.leverTag(lv.number, name)}
            </a>
          );
        })}
        {filtered.timeline.map((e) => (
          <a
            href={linkTimeline}
            class="text-rose-700 dark:text-rose-400 hover:underline"
            aria-label={L.ariaTimeline(e.year, tlTitle(e))}
          >
            📅 {e.year}
          </a>
        ))}
        {filtered.postSlugs.map((slug) => (
          <a
            href={localizedHref(`/${slug}/`, lang)}
            class="text-indigo-700 dark:text-indigo-400 hover:underline"
            aria-label={L.ariaAnalysis(slug)}
          >
            📝 {slug}
          </a>
        ))}
      </div>
    </div>
  )
}

{
  !skip && variant === 'full' && (
    <aside class={`mt-12 pt-8 border-t border-subtle ${extraClass}`} aria-label="Related references">
      <h2 class="t-h3 text-gray-800 dark:text-white mb-5 flex items-center gap-2">
        <span>🔗</span> {L.relatedReading}
      </h2>

      {renderEmpty ? (
        <p class="text-sm text-gray-400 italic">{L.noneYet}</p>
      ) : (
        <div class="grid gap-5 md:grid-cols-2">
          {filtered.people.length > 0 && (
            <section>
              <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">
                {L.hPeople}
              </h3>
              <ul class="space-y-1.5">
                {filtered.people.map((p) => {
                  const sub = personSub(p);
                  return (
                    <li>
                      <a
                        href={localizedHref(`/voices/${p.id}/`, lang)}
                        class="text-sm text-blue-600 dark:text-blue-400 hover:underline"
                      >
                        {personLabel(p)}
                      </a>
                      {sub && <span class="text-xs text-gray-500 ml-2">{sub}</span>}
                    </li>
                  );
                })}
              </ul>
            </section>
          )}

          {filtered.policies.length > 0 && (
            <section>
              <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">
                {L.hPolicies}
              </h3>
              <ul class="space-y-1.5">
                {filtered.policies.map((p) => (
                  <li class="text-sm">
                    <a
                      href={p.id ? localizedHref(`/policies/${p.id}/`, lang) : linkPolicies}
                      class="text-purple-600 dark:text-purple-400 hover:underline"
                    >
                      {policyLabel(p)}
                    </a>
                    {p.date && <span class="text-xs text-gray-500 ml-2">{p.date}</span>}
                  </li>
                ))}
              </ul>
            </section>
          )}

          {filtered.debates.length > 0 && (
            <section>
              <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">
                {L.hDebates}
              </h3>
              <ul class="space-y-1.5">
                {filtered.debates.slice(0, 8).map((d) => (
                  <li class="text-sm">
                    <a
                      href={localizedHref(`/debates/${d.id}/`, lang)}
                      class="text-amber-700 dark:text-amber-400 hover:underline"
                    >
                      {debateLabel(d)}
                    </a>
                    <span class="text-xs text-gray-500 ml-2">{d.date}</span>
                  </li>
                ))}
                {filtered.debates.length > 8 && (
                  <li class="text-xs text-gray-400 italic">{L.moreDebates(filtered.debates.length - 8)}</li>
                )}
              </ul>
            </section>
          )}

          {filtered.levers.length > 0 && (
            <section>
              <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">
                {L.hLevers}
              </h3>
              <ul class="space-y-1.5">
                {filtered.levers.map((lv) => (
                  <li class="text-sm">
                    <a
                      href={localizedHref(`/levers/${leverSlug(lv)}/`, lang)}
                      class="text-emerald-700 dark:text-emerald-400 hover:underline"
                    >
                      {L.leverTag(lv.number, leverNameLabel(lv))}
                    </a>
                    <span class="text-xs text-gray-500 ml-2">{leverSub(lv)}</span>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {filtered.timeline.length > 0 && (
            <section>
              <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">
                {L.hTimeline}
              </h3>
              <ul class="space-y-1.5">
                {filtered.timeline.map((e) => (
                  <li class="text-sm">
                    <a href={linkTimeline} class="text-rose-700 dark:text-rose-400 hover:underline">
                      {e.year} · {tlTitle(e)}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          {filtered.postSlugs.length > 0 && (
            <section>
              <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">
                {L.hAnalyses}
              </h3>
              <ul class="space-y-1.5">
                {filtered.postSlugs.map((slug) => (
                  <li class="text-sm">
                    <a
                      href={localizedHref(`/${slug}/`, lang)}
                      class="text-indigo-700 dark:text-indigo-400 hover:underline"
                    >
                      {slug}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </div>
      )}
    </aside>
  )
}
