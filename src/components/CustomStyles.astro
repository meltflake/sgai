---
// Phase 3 — Visual identity wiring.
//
// Fonts: Source Serif 4 (Latin) + Noto Serif SC (CJK, chinese-simplified
// subset only — full font is ~6 MB, subset is ~250 KB across needed weights).
// We load 400/600/700 only; rare weights fall back via font-synthesis.
//
// Palette: single signature Vermillion (#C8102E), warm paper, ink for body,
// muted ink for secondary, plus an accent-growth green reserved for
// data-positive points only (charts / freshness signals).

import '@fontsource/source-serif-4/400.css';
import '@fontsource/source-serif-4/600.css';
import '@fontsource/source-serif-4/700.css';

import '@fontsource/noto-serif-sc/chinese-simplified-400.css';
import '@fontsource/noto-serif-sc/chinese-simplified-600.css';
import '@fontsource/noto-serif-sc/chinese-simplified-700.css';
---

<style is:inline>
  :root {
    /* Stack order: Latin serif first, then CJK serif, then system fallback.
       Browsers walk the stack per glyph, so Latin renders Source Serif 4
       and Chinese renders Noto Serif SC without a JS shim. */
    --aw-font-sans: 'Source Serif 4', 'Noto Serif SC', ui-serif, Georgia, 'PingFang SC', 'Microsoft YaHei', serif;
    --aw-font-serif: 'Source Serif 4', 'Noto Serif SC', ui-serif, Georgia, 'PingFang SC', 'Microsoft YaHei', serif;
    --aw-font-heading: 'Source Serif 4', 'Noto Serif SC', ui-serif, Georgia, 'PingFang SC', 'Microsoft YaHei', serif;

    /* Signature color: FT-adjacent vermillion. Used for primary CTAs,
       links on hover, and the single accent moment per page. */
    --aw-color-primary: rgb(200 16 46);
    --aw-color-secondary: rgb(170 14 39);
    --aw-color-accent: rgb(11 110 79);

    /* Ink / paper neutrals — warm-tinted, research-feel. */
    --aw-color-text-heading: rgb(26 26 26);
    --aw-color-text-default: rgb(26 26 26);
    --aw-color-text-muted: rgb(107 107 102);
    --aw-color-bg-page: rgb(250 247 242);

    /* Surface = card / chip background, slightly elevated from page bg.
       Border-subtle = consistent divider used everywhere. Both warm-tinted
       to keep the FT/Stratechery editorial feel coherent across components. */
    --aw-color-bg-surface: rgb(255 252 247);
    --aw-color-border-subtle: rgb(228 222 211);

    --aw-color-bg-page-dark: rgb(15 15 18);

    /* Optional: accent-growth reserved for charts only (not surfaced as a
       Tailwind token to discourage decorative use). */
    --color-accent-growth: rgb(11 110 79);

    ::selection {
      background-color: rgb(200 16 46 / 18%);
    }
  }

  .dark {
    --aw-font-sans: 'Source Serif 4', 'Noto Serif SC', ui-serif, Georgia, 'PingFang SC', 'Microsoft YaHei', serif;
    --aw-font-serif: 'Source Serif 4', 'Noto Serif SC', ui-serif, Georgia, 'PingFang SC', 'Microsoft YaHei', serif;
    --aw-font-heading: 'Source Serif 4', 'Noto Serif SC', ui-serif, Georgia, 'PingFang SC', 'Microsoft YaHei', serif;

    --aw-color-primary: rgb(244 96 116);
    --aw-color-secondary: rgb(232 64 90);
    --aw-color-accent: rgb(72 187 120);

    --aw-color-text-heading: rgb(247 245 240);
    --aw-color-text-default: rgb(229 226 220);
    --aw-color-text-muted: rgb(160 158 152);
    --aw-color-bg-page: rgb(15 15 18);

    /* Dark surface: warm-tinted lift from page bg (#0F0F12 → #16161A).
       Same hue, just brighter, so cards don't introduce a cool slate-blue. */
    --aw-color-bg-surface: rgb(22 22 26);
    --aw-color-border-subtle: rgb(48 47 52);

    ::selection {
      background-color: rgb(232 64 90 / 28%);
      color: rgb(247 245 240);
    }
  }

  /* Typography polish: enable proportional alt punctuation for CJK,
     softer line-height for body, slightly tighter for headings.
     `palt` collapses CJK fullwidth punctuation gaps; `kern` fixes Latin. */
  html {
    font-feature-settings:
      'palt' on,
      'kern' on;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    line-height: 1.75;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
</style>
