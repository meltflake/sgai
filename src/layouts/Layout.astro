---
import '~/assets/styles/tailwind.css';

import { I18N } from 'astrowind:config';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import Analytics from '~/components/common/Analytics.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';

// Comment the line below to disable View Transitions
import { ClientRouter } from 'astro:transitions';

import type { MetaData as MetaDataType } from '~/types';
import { LOCALES, ROUTE_DEFAULT_LOCALE, type Lang } from '~/i18n';

export interface Props {
  metadata?: MetaDataType;
  lang?: Lang;
}

const { metadata = {}, lang } = Astro.props;
const { textDirection } = I18N;
// Default to ROUTE_DEFAULT_LOCALE when no explicit lang prop is passed.
const currentLang: Lang = (lang && (LOCALES as string[]).includes(lang) ? lang : ROUTE_DEFAULT_LOCALE) as Lang;
// HTML lang attribute uses BCP 47 codes (zh-CN, en, ja).
const HTML_LANG: Record<Lang, string> = { zh: 'zh-CN', en: 'en', ja: 'ja' };
const htmlLang = HTML_LANG[currentLang];
// Pass locale list + route default into the inline localStorage rewrite
// script so it generalizes across all configured languages.
const localeRewrite = { locales: LOCALES, routeDefault: ROUTE_DEFAULT_LOCALE, currentLang };
---

<!doctype html>
<html lang={htmlLang} dir={textDirection} class="2xl:text-[20px]">
  <head>
    {
      /* Phase-2 routing: only the user's stored choice triggers a one-time
        rewrite. Browser-language preference is treated as a hint surfaced
        by LangBanner, not as a reason to silently change URLs. This keeps
        deep-link / search-engine traffic on the URL the user / crawler
        actually requested. */
    }
    <script is:inline define:vars={{ localeRewrite }}>
      (function () {
        try {
          const { locales, routeDefault, currentLang } = localeRewrite;
          const stored = localStorage.getItem('sgai_lang');
          if (!locales.includes(stored)) return;
          if (stored === currentLang) return;
          // Strip the current locale prefix (if any) to recover a base path.
          const path = location.pathname;
          let basePath = path;
          for (const l of locales) {
            if (l === routeDefault) continue;
            const p = '/' + l;
            if (path === p || path === p + '/') {
              basePath = '/';
              break;
            }
            if (path.indexOf(p + '/') === 0) {
              basePath = path.slice(p.length);
              break;
            }
          }
          // Re-prefix with the stored locale (or strip if storing the route default).
          const newPrefix = stored === routeDefault ? '' : '/' + stored;
          const dest = newPrefix + (basePath === '/' && newPrefix ? '/' : basePath);
          if (dest === path) return;
          location.replace(dest + location.search + location.hash);
        } catch {
          /* localStorage / navigator unavailable — leave page as-is */
        }
      })();
    </script>

    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} lang={currentLang} />
    <SiteVerification />
    <Analytics />

    <!-- Comment the line below to disable View Transitions -->
    <ClientRouter fallback="swap" />
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <slot />

    <BasicScripts />
  </body>
</html>
